{
  "ci": {
    "collect": {
      "numberOfRuns": 3,
      "startServerCommand": "npm run build && npm run preview -- --host 127.0.0.1 --port 4321",
      "startServerReadyPattern": "Local",
      "url": [
        "http://127.0.0.1:4321/",
        "http://127.0.0.1:4321/zh/docs/v2/",
        "http://127.0.0.1:4321/zh/docs/v2/getting-started/intro/",
        "http://127.0.0.1:4321/en/docs/v2/getting-started/intro/"
      ],
      "settings": {
        "preset": "desktop"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": [
          "warn",
          {
            "minScore": 0.9
          }
        ],
        "largest-contentful-paint": [
          "warn",
          {
            "maxNumericValue": 2500
          }
        ],
        "interactive": [
          "warn",
          {
            "maxNumericValue": 3800
          }
        ],
        "total-blocking-time": [
          "warn",
          {
            "maxNumericValue": 200
          }
        ]
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": ".lighthouseci"
    }
  }
}
