---
import Header from "../Header.astro";

const route = Astro.locals.starlightRoute;
const locale = route?.locale === "en" ? "en" : "zh";
const entryId = route?.entry?.id ?? "";
const segments = entryId.split("/").filter(Boolean);

const version =
  segments.find((segment) => /^v\d+$/i.test(segment))?.toLowerCase() ?? "v2";
const versionIndex = segments.findIndex((segment) => /^v\d+$/i.test(segment));
const rest = versionIndex >= 0 ? segments.slice(versionIndex + 1) : [];
const normalizedRest =
  rest.length > 0 && rest[rest.length - 1] === "index" ? rest.slice(0, -1) : rest;
const slug = normalizedRest.join("/");
---

<Header
  lang={locale}
  version={version}
  slug={slug || undefined}
  as="div"
  sticky={false}
/>

<script>
  function setupStarlightSidebarTop() {
    const sidebarContent = document.querySelector(".sidebar-content") as HTMLElement | null;
    if (!sidebarContent || sidebarContent.querySelector(".stl-sidebar-top")) return;

    const isZh = document.documentElement.lang.toLowerCase().startsWith("zh");
    const langPrefix = isZh ? "/zh" : "/en";

    const top = document.createElement("div");
    top.className = "stl-sidebar-top";

    const form = document.createElement("form");
    form.className = "stl-sidebar-search";
    form.method = "get";
    form.action = `${langPrefix}/search/`;

    const input = document.createElement("input");
    input.type = "search";
    input.name = "q";
    input.placeholder = isZh ? "搜索" : "Search";
    input.autocomplete = "off";

    const keys = document.createElement("span");
    keys.className = "stl-sidebar-search-keys";
    keys.textContent = "⌘ K";

    form.append(input, keys);
    top.appendChild(form);
    sidebarContent.insertBefore(top, sidebarContent.firstChild);
  }

  function normalizeLanguage(raw: string) {
    return raw.trim().toLowerCase().replace(/^language-/, "");
  }

  function languageDisplayName(raw: string, isZh: boolean) {
    const lang = normalizeLanguage(raw);
    const labels: Record<string, string> = {
      js: "JavaScript",
      javascript: "JavaScript",
      jsx: "JSX",
      ts: "TypeScript",
      tsx: "TSX",
      json: "JSON",
      bash: "Bash",
      sh: "Shell",
      shell: "Shell",
      zsh: "Zsh",
      cmd: "CMD",
      powershell: "PowerShell",
      ps1: "PowerShell",
      py: "Python",
      python: "Python",
      yaml: "YAML",
      yml: "YAML",
      toml: "TOML",
      md: "Markdown",
      markdown: "Markdown",
      html: "HTML",
      css: "CSS",
      sql: "SQL",
      plaintext: isZh ? "文本" : "Text",
      text: isZh ? "文本" : "Text",
      txt: isZh ? "文本" : "Text",
    };
    return labels[lang] ?? (lang ? lang[0].toUpperCase() + lang.slice(1) : isZh ? "文本" : "Text");
  }

  function extractLanguage(pre: HTMLPreElement, code: HTMLElement) {
    const dataLang = pre.dataset.language || pre.getAttribute("data-language") || "";
    const classLang = Array.from(code.classList)
      .find((name) => name.startsWith("language-"))
      ?.replace(/^language-/, "");
    return normalizeLanguage(dataLang || classLang || "text");
  }

  function getCodeLinesFromMarkup(code: HTMLElement) {
    if (code.querySelector(":scope > .codeLine")) return null;

    const expressiveLines = Array.from(code.querySelectorAll(":scope > .ec-line"));
    if (expressiveLines.length > 0) {
      return expressiveLines.map((line) => {
        if (!(line instanceof HTMLElement)) return " ";
        const source = (line.querySelector(":scope > .code") as HTMLElement | null) ?? line;
        return source.innerHTML || " ";
      });
    }

    return code.innerHTML.replace(/\r\n?/g, "\n").split("\n");
  }

  function wrapCodeLines(code: HTMLElement) {
    const lineHtmlList = getCodeLinesFromMarkup(code);
    if (!lineHtmlList) return;

    const normalized = lineHtmlList.length > 0 ? lineHtmlList : [" "];
    code.innerHTML = normalized
      .map((lineHtml) => `<span class="codeLine">${lineHtml || " "}</span>`)
      .join("");
  }

  async function copyText(text: string) {
    try {
      await navigator.clipboard.writeText(text);
      return true;
    } catch {
      const textarea = document.createElement("textarea");
      textarea.value = text;
      textarea.setAttribute("readonly", "true");
      textarea.style.position = "absolute";
      textarea.style.left = "-9999px";
      document.body.appendChild(textarea);
      textarea.select();
      const ok = document.execCommand("copy");
      document.body.removeChild(textarea);
      return ok;
    }
  }

  function enhanceStarlightCodeBlocks() {
    const isZh = document.documentElement.lang.toLowerCase().startsWith("zh");
    const copyLabel = isZh ? "复制" : "Copy";
    const copiedLabel = isZh ? "已复制" : "Copied";

    const codes = document.querySelectorAll(".sl-markdown-content pre > code");
    codes.forEach((codeNode) => {
      if (!(codeNode instanceof HTMLElement)) return;
      const pre = codeNode.parentElement;
      if (!(pre instanceof HTMLPreElement)) return;
      if (pre.closest(".stl-code-card")) return;

      const figureHost = pre.closest("figure.frame") as HTMLElement | null;
      const expressiveRoot = pre.closest(".expressive-code") as HTMLElement | null;
      const mountParent = expressiveRoot?.parentElement ?? pre.parentElement;
      if (!mountParent) return;
      if (expressiveRoot?.previousElementSibling?.classList.contains("stl-code-card")) return;
      if (!expressiveRoot && pre.previousElementSibling?.classList.contains("stl-code-card")) return;

      if (figureHost) figureHost.classList.add("stl-code-host");

      wrapCodeLines(codeNode);
      const lang = languageDisplayName(extractLanguage(pre, codeNode), isZh);

      const card = document.createElement("div");
      card.className = "stl-code-card";
      card.dataset.lang = lang;

      const toolbar = document.createElement("div");
      toolbar.className = "stl-code-toolbar";

      const toolbarRight = document.createElement("div");
      toolbarRight.className = "stl-code-toolbar-right";

      const language = document.createElement("div");
      language.className = "stl-code-lang";
      language.textContent = lang;

      const copyButton = document.createElement("button");
      copyButton.type = "button";
      copyButton.className = "stl-code-copy";
      copyButton.textContent = copyLabel;
      copyButton.setAttribute("aria-label", copyLabel);
      copyButton.addEventListener("click", async () => {
        const sourceText = codeNode.innerText;
        const ok = await copyText(sourceText);
        if (!ok) return;
        copyButton.dataset.state = "copied";
        copyButton.textContent = copiedLabel;
        window.setTimeout(() => {
          copyButton.dataset.state = "idle";
          copyButton.textContent = copyLabel;
        }, 1000);
      });

      toolbarRight.append(language, copyButton);
      toolbar.appendChild(toolbarRight);

      const body = document.createElement("div");
      body.className = "stl-code-body";
      card.append(toolbar, body);

      if (expressiveRoot) {
        mountParent.insertBefore(card, expressiveRoot);
        body.appendChild(expressiveRoot);
      } else {
        mountParent.insertBefore(card, pre);
        body.appendChild(pre);
      }
    });
  }

  function setupStarlightTocPicker() {
    const tocNav = document.querySelector(
      ".right-sidebar-panel starlight-toc nav",
    ) as HTMLElement | null;
    if (!tocNav || tocNav.hasAttribute("data-picker-ready")) return;
    tocNav.setAttribute("data-picker-ready", "true");

    const isZh = document.documentElement.lang.toLowerCase().startsWith("zh");
    const tocTitle = tocNav.querySelector("h2")?.textContent?.trim() || "On this page";
    const primaryLabel = isZh ? "本页内容" : "On this page";
    const resourceLabel = isZh ? "示例 / 资源" : "Examples / Resources";
    const resourceHeading = /^(示例|资源|examples?|resources?)$/i;

    const linkNodes = Array.from(tocNav.querySelectorAll("a[href^='#']")) as HTMLAnchorElement[];
    if (linkNodes.length === 0) return;

    const items = linkNodes
      .map((link) => {
        const sectionId = link.getAttribute("href")?.replace(/^#/, "");
        if (!sectionId) return null;
        const label = link.textContent?.trim() || sectionId;
        const li = link.closest("li");
        const depth = Number.parseInt(li?.style.getPropertyValue("--depth") || "0", 10) || 0;
        return { link, sectionId, label, depth };
      })
      .filter(Boolean) as Array<{
      link: HTMLAnchorElement;
      sectionId: string;
      label: string;
      depth: number;
    }>;
    if (items.length === 0) return;

    const primaryItems: typeof items = [];
    const resourceItems: typeof items = [];
    let insideResourceSection = false;

    items.forEach((item) => {
      if (item.depth === 0 && resourceHeading.test(item.label)) {
        insideResourceSection = true;
        resourceItems.push(item);
        return;
      }
      if (insideResourceSection && item.depth === 0) {
        insideResourceSection = false;
      }
      if (insideResourceSection) {
        resourceItems.push(item);
      } else {
        primaryItems.push(item);
      }
    });

    const picker = document.createElement("details");
    picker.className = "stl-toc-picker";

    const summary = document.createElement("summary");
    const label = document.createElement("span");
    label.className = "stl-toc-picker-label";
    label.textContent = tocTitle;
    const value = document.createElement("span");
    value.className = "stl-toc-picker-value";
    value.textContent = items[0].label || tocTitle;
    summary.append(label, value);

    const panel = document.createElement("div");
    panel.className = "stl-toc-picker-panel";

    const setValue = (text?: string | null) => {
      const next = text?.trim();
      if (!next) return;
      value.textContent = next;
    };

    const appendGroup = (groupLabel: string, groupItems: typeof items) => {
      if (groupItems.length === 0) return;
      const group = document.createElement("div");
      group.className = "stl-toc-picker-group";

      const title = document.createElement("p");
      title.className = "stl-toc-picker-group-title";
      title.textContent = groupLabel;

      const list = document.createElement("div");
      list.className = "stl-toc-picker-group-list";

      groupItems.forEach((item) => {
        const button = document.createElement("button");
        button.type = "button";
        button.className = "stl-toc-picker-btn";
        button.dataset.depth = String(item.depth);
        button.textContent = item.label;
        button.addEventListener("click", () => {
          const target = document.getElementById(item.sectionId);
          if (!target) return;
          target.scrollIntoView({ behavior: "smooth", block: "start" });
          setValue(item.label);
          picker.removeAttribute("open");
        });
        list.appendChild(button);

        if (!item.link.hasAttribute("data-picker-listener")) {
          item.link.setAttribute("data-picker-listener", "true");
          item.link.addEventListener("click", () => {
            setValue(item.label);
            picker.removeAttribute("open");
          });
        }
      });

      group.append(title, list);
      panel.appendChild(group);
    };

    appendGroup(primaryLabel, primaryItems);
    appendGroup(resourceLabel, resourceItems);

    picker.append(summary, panel);
    tocNav.insertBefore(picker, tocNav.firstChild);

    const targets = items
      .map((item) => document.getElementById(item.sectionId))
      .filter(Boolean) as HTMLElement[];
    if (targets.length === 0) return;

    const state = window as Window & { __stlTocPickerObserver?: IntersectionObserver };
    state.__stlTocPickerObserver?.disconnect();
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const match = items.find((item) => item.sectionId === entry.target.id);
          setValue(match?.label);
        });
      },
      { rootMargin: "-90px 0px -60% 0px" },
    );
    targets.forEach((target) => observer.observe(target));
    state.__stlTocPickerObserver = observer;
  }

  if (!document.documentElement.hasAttribute("data-starlight-picker-load-bound")) {
    document.documentElement.setAttribute("data-starlight-picker-load-bound", "true");
    document.addEventListener("astro:page-load", () => {
      setupStarlightSidebarTop();
      enhanceStarlightCodeBlocks();
      setupStarlightTocPicker();
    });
  }
  setupStarlightSidebarTop();
  enhanceStarlightCodeBlocks();
  setupStarlightTocPicker();
</script>
