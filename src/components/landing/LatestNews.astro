---
import { getCollection } from "astro:content";
import { getBlogUrl, parseBlogId, sortBlog } from "../../lib/blog";
import { Play, Book, Code, FileText, Smartphone } from "@lucide/astro";

type Props = {
  lang?: string;
  limit?: number;
  title?: string;
};

const { lang = "zh", limit = 6, title } = Astro.props;
const isZh = lang === "zh";
const resolvedTitle = title ?? (isZh ? "最新文章" : "Latest");
const viewAllText = isZh ? "查看全部" : "View all";

const entries = (await getCollection("blog"))
  .filter((e) => parseBlogId(e.id).lang === lang && !e.data.draft)
  .sort(sortBlog)
  .slice(0, limit);

const getGradient = (index: number) => {
  const gradients = [
    "linear-gradient(135deg, #DCEB7A 0%, #C8DB5A 100%)",
    "linear-gradient(135deg, #FF9B26 0%, #FF7A00 100%)",
    "linear-gradient(135deg, #C4B5FD 0%, #A78BFA 100%)",
    "linear-gradient(135deg, #A8EDDF 0%, #68D391 100%)",
    "linear-gradient(135deg, #FFB086 0%, #FA897B 100%)",
    "linear-gradient(135deg, #93C5FD 0%, #60A5FA 100%)",
  ];
  return gradients[index % gradients.length];
};

const getIcon = (category: string = "") => {
  const cat = category.toLowerCase();
  if (cat.includes("video")) return "play";
  if (cat.includes("guide") || cat.includes("tutorial")) return "book";
  if (cat.includes("code") || cat.includes("engineering")) return "code";
  if (cat.includes("app") || cat.includes("mobile")) return "smartphone";
  return "doc";
};

const getCategoryLabel = (category: string, zh: boolean) => {
  if (!zh) return category;
  const cat = category.toLowerCase();
  if (cat.includes("research")) return "研究";
  if (cat.includes("engineering") || cat.includes("code")) return "工程";
  if (cat.includes("guide") || cat.includes("tutorial")) return "指南";
  if (cat.includes("video")) return "视频";
  if (cat.includes("app") || cat.includes("mobile")) return "应用";
  return category;
};
---

{
  entries.length > 0 && (
    <section class="latest-section">
      <div class="container">
        <div class="header">
          <h2 class="title">{resolvedTitle}</h2>
          <a class="view-all" href={getBlogUrl({ lang })}>
            {viewAllText}
          </a>
        </div>

        <div class="grid">
          {entries.map((e, index) => {
            const p = parseBlogId(e.id);
            const href = getBlogUrl({ lang, slug: p.slug });
            const cat = e.data.category || (isZh ? "研究" : "Research");
            const iconType = getIcon(cat);
            const catLabel = getCategoryLabel(cat, isZh);

            return (
              <a class="card group" href={href}>
                <div class="thumb" style={`background: ${getGradient(index)}`}>
                  <div class="thumb-icon">
                    {iconType === "play" && (
                      <Play size={24} stroke-width={1.5} />
                    )}
                    {iconType === "book" && (
                      <Book size={24} stroke-width={1.5} />
                    )}
                    {iconType === "code" && (
                      <Code size={24} stroke-width={1.5} />
                    )}
                    {iconType === "smartphone" && (
                      <Smartphone size={24} stroke-width={1.5} />
                    )}
                    {iconType === "doc" && (
                      <FileText size={24} stroke-width={1.5} />
                    )}
                  </div>
                </div>

                <div class="body">
                  <h3 class="card-title">{e.data.title}</h3>
                  {e.data.description && (
                    <p class="desc">{e.data.description}</p>
                  )}

                  <div class="meta">
                    {iconType === "play" ? (
                      <Play class="meta-ic" size={14} stroke-width={1.5} />
                    ) : iconType === "code" ? (
                      <Code class="meta-ic" size={14} stroke-width={1.5} />
                    ) : (
                      <FileText class="meta-ic" size={14} stroke-width={1.5} />
                    )}
                    <span class="meta-text">{catLabel}</span>
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )
}

<style>
  .latest-section {
    padding: 4rem 0;
    background-color: var(--bg);
    color: var(--fg);
    display: flex;
    justify-content: center;
  }

  .header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 1.75rem;
  }

  .title {
    font-size: 1.25rem;
    font-weight: 600;
    margin: 0;
    color: var(--fg);
    letter-spacing: -0.01em;
  }

  .view-all {
    color: var(--muted);
    text-decoration: none;
    font-size: 0.875rem;
    transition: color 0.2s;
  }

  @media (hover: hover) and (pointer: fine) {
    .view-all:hover {
      color: var(--accent);
    }
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    column-gap: 4rem;
    row-gap: 2.25rem;
  }

  .card {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
    text-decoration: none;
    color: inherit;
    background: transparent;
    border: none;
    padding: 0;
    -webkit-tap-highlight-color: transparent;
  }

  .card:hover {
    text-decoration: none;
  }

  @media (hover: none), (pointer: coarse) {
    .card:active {
      transform: scale(0.99);
    }
  }

  .thumb {
    flex: 0 0 100px;
    width: 100px;
    height: 100px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .thumb-icon {
    color: rgba(255, 255, 255, 0.9);
    display: flex;
  }

  .body {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    padding-top: 0.25rem;
  }

  .card-title {
    margin: 0 0 0.5rem 0;
    font-size: 1.05rem;
    line-height: 1.4;
    font-weight: 600;
    color: var(--fg);
    letter-spacing: -0.01em;
    transition: color 0.2s ease;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (hover: hover) and (pointer: fine) {
    .card:hover .card-title {
      color: var(--accent);
    }
  }

  .desc {
    margin: 0 0 1rem 0;
    color: var(--muted);
    font-size: 0.875rem;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .meta {
    margin-top: auto;
    display: flex;
    align-items: center;
    gap: 0.375rem;
    color: var(--muted);
    font-size: 0.8125rem;
  }

  .meta-ic {
    opacity: 0.7;
  }

  .meta-text {
    opacity: 0.9;
  }

  @media (max-width: 768px) {
    .latest-section {
      padding: 3rem 0;
    }

    .grid {
      grid-template-columns: 1fr;
      column-gap: 0;
      row-gap: 1.5rem;
    }

    .header {
      margin-bottom: 1.25rem;
    }

    .card {
      gap: 1rem;
    }
  }

  @media (max-width: 480px) {
    .latest-section {
      padding: 2.5rem 0;
    }

    .title {
      font-size: 1.125rem;
    }

    .view-all {
      font-size: 0.8125rem;
    }

    .grid {
      row-gap: 1.125rem;
    }

    .thumb {
      flex: 0 0 64px;
      width: 64px;
      height: 64px;
      border-radius: 7px;
    }

    .thumb-icon :global(svg) {
      width: 18px;
      height: 18px;
    }

    .card-title {
      margin-bottom: 0.3rem;
      font-size: 1rem;
      line-height: 1.35;
    }

    .desc {
      margin-bottom: 0.6rem;
      -webkit-line-clamp: 1;
    }

    .meta {
      gap: 0.3rem;
    }
  }
</style>
