---
import { getCollection } from "astro:content";
import { getBlogUrl, parseBlogId, sortBlog } from "../../lib/blog";
import { Play, Book, Code, FileText, Smartphone } from "@lucide/astro";

type Props = {
  lang?: string;
  limit?: number;
  title?: string;
};

const { lang = "zh", limit = 6, title = "Latest" } = Astro.props;

const entries = (await getCollection("blog"))
  .filter((e) => parseBlogId(e.id).lang === lang && !e.data.draft)
  .sort(sortBlog)
  .slice(0, limit);

// 1:1 OpenAI Style Gradients
const getGradient = (index: number) => {
  const gradients = [
    "linear-gradient(135deg, #DCEB7A 0%, #C8DB5A 100%)", // Soft Lime
    "linear-gradient(135deg, #FF9B26 0%, #FF7A00 100%)", // OpenAI Orange
    "linear-gradient(135deg, #C4B5FD 0%, #A78BFA 100%)", // Soft Purple
    "linear-gradient(135deg, #A8EDDF 0%, #68D391 100%)", // Teal/Green
    "linear-gradient(135deg, #FFB086 0%, #FA897B 100%)", // Peach/Pink
    "linear-gradient(135deg, #93C5FD 0%, #60A5FA 100%)", // Sky Blue
  ];
  return gradients[index % gradients.length];
};

const getIcon = (category: string = "") => {
  const cat = category.toLowerCase();
  if (cat.includes("video")) return "play";
  if (cat.includes("guide") || cat.includes("tutorial")) return "book";
  if (cat.includes("code") || cat.includes("engineering")) return "code";
  if (cat.includes("app") || cat.includes("mobile")) return "smartphone";
  return "doc";
};
---

{
  entries.length > 0 && (
    <section class="latest-section">
      <div class="container">
        <div class="header">
          <h2 class="title">{title}</h2>
          <a class="view-all" href={getBlogUrl({ lang })}>
            View all
          </a>
        </div>

        <div class="grid">
          {entries.map((e, index) => {
            const p = parseBlogId(e.id);
            const href = getBlogUrl({ lang, slug: p.slug });
            const cat = e.data.category || "Research";
            const iconType = getIcon(cat);

            return (
              <a class="card group" href={href}>
                <div class="thumb" style={`background: ${getGradient(index)}`}>
                  <div class="thumb-icon">
                    {iconType === "play" && (
                      <Play size={24} stroke-width={1.5} />
                    )}
                    {iconType === "book" && (
                      <Book size={24} stroke-width={1.5} />
                    )}
                    {iconType === "code" && (
                      <Code size={24} stroke-width={1.5} />
                    )}
                    {iconType === "smartphone" && (
                      <Smartphone size={24} stroke-width={1.5} />
                    )}
                    {iconType === "doc" && (
                      <FileText size={24} stroke-width={1.5} />
                    )}
                  </div>
                </div>

                <div class="body">
                  <h3 class="card-title">{e.data.title}</h3>
                  {e.data.description && (
                    <p class="desc">{e.data.description}</p>
                  )}

                  <div class="meta">
                    {iconType === "play" ? (
                      <Play class="meta-ic" size={14} stroke-width={1.5} />
                    ) : iconType === "code" ? (
                      <Code class="meta-ic" size={14} stroke-width={1.5} />
                    ) : (
                      <FileText class="meta-ic" size={14} stroke-width={1.5} />
                    )}
                    <span class="meta-text">{cat}</span>
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )
}

<style>
  .latest-section {
    padding: 6rem 1.5rem;
    background-color: var(--bg);
    color: var(--fg);
    display: flex;
    justify-content: center;
  }

  .container {
  }

  .header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 2.5rem;
  }

  .title {
    font-size: 1.25rem; /* 20px */
    font-weight: 600;
    margin: 0;
    color: var(--fg);
    letter-spacing: -0.01em;
  }

  .view-all {
    color: var(--muted);
    text-decoration: none;
    font-size: 0.875rem; /* 14px */
    transition: color 0.2s;
  }

  .view-all:hover {
    color: var(--accent);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    column-gap: 4rem;
    row-gap: 3rem;
  }

  @media (max-width: 768px) {
    .grid {
      grid-template-columns: 1fr;
      column-gap: 0;
      row-gap: 2.5rem;
    }
  }

  .card {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
    text-decoration: none;
    color: inherit;
    background: transparent;
    border: none;
    padding: 0;
  }

  .thumb {
    flex: 0 0 100px; /* Precise size matching OpenAI */
    width: 100px;
    height: 100px;
    border-radius: 8px; /* Slight rounding for a modern feel */
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .thumb-icon {
    color: rgba(255, 255, 255, 0.9); /* Pure white icon */
    display: flex;
  }

  .body {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    padding-top: 0.25rem; /* Optical alignment with the top of the box */
  }

  .card-title {
    margin: 0 0 0.5rem 0;
    font-size: 1.05rem; /* ~17px */
    line-height: 1.4;
    font-weight: 600;
    color: var(--fg);
    letter-spacing: -0.01em;
    transition: color 0.2s ease;
  }

  .card:hover .card-title {
    color: var(--accent);
  }

  .desc {
    margin: 0 0 1rem 0;
    color: var(--muted);
    font-size: 0.875rem; /* 14px */
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .meta {
    margin-top: auto; /* Push meta to bottom if description is short */
    display: flex;
    align-items: center;
    gap: 0.375rem;
    color: var(--muted);
    font-size: 0.8125rem; /* 13px */
  }

  .meta-ic {
    opacity: 0.7;
  }

  .meta-text {
    opacity: 0.9;
  }
</style>
