---
import { ChevronDown } from "@lucide/astro";
import type { CollectionEntry } from "astro:content";
import Button from "../ui/Button.astro";
import "../../styles/footer.css";

type FooterData = CollectionEntry<"landing">["data"]["footer"];

interface Props {
  data?: FooterData;
}

const defaultFooterData: FooterData = {
  tagline: "探索智能边界",
  wordmark: "ElexvxAILab",
  columns: [
    {
      title: "研究",
      links: [
        { label: "发表论文", href: "#" },
        { label: "开源项目", href: "#" },
        { label: "开放数据", href: "#" },
      ],
    },
    {
      title: "资源",
      links: [
        { label: "技术文档", href: "#" },
        { label: "API 参考", href: "#" },
        { label: "官方博客", href: "#" },
      ],
    },
    {
      title: "开发者",
      links: [
        { label: "开发者社区", href: "#" },
        { label: "模型代码", href: "#" },
      ],
    },
    {
      title: "关于",
      links: [
        { label: "研究成果", href: "#" },
        { label: "项目合作", href: "#" },
        { label: "联系我们", href: "#" },
        { label: "关于我们", href: "#" },
        { label: "加入我们", href: "#" },
        { label: "隐私政策", href: "#" },
        { label: "服务条款", href: "#" },
      ],
    },
  ],
  copyright:
    "Copyright © 2024 ElexvxAI Lab | 隶属于 宏翔商道（南京）科技发展有限公司 | ICP备案：苏ICP备2025160017号",
};

const { data = defaultFooterData } = Astro.props;
---

<footer class="site-footer">
  <div class="footer-container">
    <div class="footer-top">
      <div class="footer-tagline">
        {data.tagline && <h2>{data.tagline}</h2>}
      </div>

      <div class="footer-nav" id="footerAccordion">
        {data.columns.map((group, index) => (
          <section class="footer-group" data-footer-group data-open="false">
            <Button
              class="footer-group-trigger"
              variant="ghost"
              size="sm"
              data-footer-trigger
              aria-expanded="false"
              aria-controls={`footer-links-${index}`}
            >
              <span>{group.title}</span>
              <ChevronDown class="footer-chevron" size={16} stroke-width={1.8} />
            </Button>

            <ul class="footer-group-links" id={`footer-links-${index}`} data-footer-panel>
              {group.links.map((link) => (
                <li><a href={link.href}>{link.label}</a></li>
              ))}
            </ul>
          </section>
        ))}
      </div>
    </div>

    <div class="footer-middle">
      {data.wordmark && <h2 class="footer-wordmark">{data.wordmark}</h2>}
    </div>

    <div class="footer-bottom">
      <div class="footer-brand">
        {data.copyright && <span class="brand-text">{data.copyright}</span>}
      </div>
    </div>
  </div>
</footer>

<script>
  function initFooterAccordion() {
    const accordion = document.getElementById("footerAccordion");
    if (!accordion) return;

    const groups = Array.from(
      accordion.querySelectorAll("[data-footer-group]"),
    ) as HTMLElement[];
    const isMobile = () => window.matchMedia("(max-width: 768px)").matches;

    const sync = () => {
      const mobile = isMobile();
      groups.forEach((group) => {
        const trigger = group.querySelector(
          "[data-footer-trigger]",
        ) as HTMLButtonElement | null;
        const panel = group.querySelector(
          "[data-footer-panel]",
        ) as HTMLElement | null;

        if (!trigger || !panel) return;

        if (mobile) {
          const open = group.getAttribute("data-open") === "true";
          trigger.setAttribute("aria-expanded", String(open));
          panel.hidden = false; // Let CSS handle visibility
        } else {
          trigger.setAttribute("aria-expanded", "true");
          panel.hidden = false;
        }
      });
    };

    if (!accordion.hasAttribute("data-accordion-init")) {
      accordion.setAttribute("data-accordion-init", "true");

      groups.forEach((group) => {
        const trigger = group.querySelector(
          "[data-footer-trigger]",
        ) as HTMLButtonElement | null;
        group.setAttribute("data-open", "false");

        if (!trigger) return;
        trigger.addEventListener("click", () => {
          if (!isMobile()) return;
          const isOpen = group.getAttribute("data-open") === "true";
          
          // Close other groups to enforce accordion behavior
          if (!isOpen) {
            groups.forEach((g) => {
              if (g !== group) {
                g.setAttribute("data-open", "false");
              }
            });
          }

          group.setAttribute("data-open", isOpen ? "false" : "true");
          sync();
        });
      });

      window.addEventListener("resize", sync);
    }

    sync();
  }

  if (!document.documentElement.hasAttribute("data-footer-page-load-bound")) {
    document.documentElement.setAttribute(
      "data-footer-page-load-bound",
      "true",
    );
    document.addEventListener("astro:page-load", initFooterAccordion);
  }
  initFooterAccordion();
</script>
