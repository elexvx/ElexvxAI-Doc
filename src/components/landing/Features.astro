---
const features = [
  {
    title: 'Core Research',
    icon: 'science',
    desc: 'Deep learning algorithms and foundation models pushing the boundaries of AI capabilities in generative tasks.',
    action: 'Learn more',
    imageColor: 'linear-gradient(135deg, #001f3f 0%, #0074D9 100%)', // Blue
  },
  {
    title: 'Open Source',
    icon: 'code',
    desc: 'Contributing state-of-the-art code, pretrained models, and large-scale datasets to the global research community.',
    action: 'View Repos',
    imageColor: 'linear-gradient(135deg, #2E2E2E 0%, #AAAAAA 100%)', // Grey/Code
  },
  {
    title: 'Industrial',
    icon: 'factory',
    desc: 'Deploying scalable AI solutions for manufacturing, logistics, and supply chain optimization.',
    action: 'Case Studies',
    imageColor: 'linear-gradient(135deg, #FF851B 0%, #FFDC00 100%)', // Orange/Yellow
  },
];
---

<section class="features-section">
  <div class="container">
    <div class="header">
      <h2 class="display-small">Research Focus</h2>
      <p class="body-large">Exploring the frontiers of machine intelligence through rigorous experimentation.</p>
      <a href="#" class="link-arrow">
        View all research areas 
        <svg class="arrow-icon" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z"/>
        </svg>
      </a>
    </div>

    <div class="grid">
      {features.map(feature => (
        <div class="card">
          <div class="card-media" style={`background: ${feature.imageColor}`}>
            <!-- Placeholder for image -->
          </div>
          <div class="card-content">
            <div class="icon-container">
              {feature.icon === 'science' && (
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19.8 18.4L14 10.67V6.5l1.35-1.69c.26-.33.03-.81-.4-.81H9.05c-.43 0-.66.48-.4.81L10 6.5v4.17L4.2 18.4c-.49.66-.02 1.6.8 1.6h14c.82 0 1.29-.94.8-1.6z"/></svg>
              )}
              {feature.icon === 'code' && (
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M9.4 16.6L4.8 12l4.6-4.6L8 6l-6 6 6 6 1.4-1.4zm5.2 0l4.6-4.6-4.6-4.6L16 6l6 6-6 6-1.4-1.4z"/></svg>
              )}
              {feature.icon === 'factory' && (
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M22 22H2V11l7-3v2h5v-2l5 3v-2l3 3z"/></svg>
              )}
            </div>
            <h3 class="headline-small">{feature.title}</h3>
            <p class="body-medium">{feature.desc}</p>
            <button class="btn-tonal">{feature.action}</button>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features-section {
    padding: 4rem 1.5rem;
    background-color: var(--md-sys-color-surface);
    color: var(--md-sys-color-on-surface);
    display: flex;
    justify-content: center;
  }

  .container {
    max-width: 1200px;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .header {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 600px;
    position: relative;
  }

  .link-arrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--md-sys-color-primary);
    text-decoration: none;
    font-weight: 500;
    margin-top: 0.5rem;
  }

  .link-arrow:hover {
    text-decoration: underline;
  }

  .arrow-icon {
    width: 18px;
    height: 18px;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  /* M3 Card */
  .card {
    background-color: var(--md-sys-color-surface-container-low); /* Slightly lighter than bg */
    border-radius: 16px;
    overflow: hidden;
    transition: transform 0.2s, box-shadow 0.2s;
    border: 1px solid var(--md-sys-color-outline-variant);
    display: flex;
    flex-direction: column;
  }

  .card:hover {
    transform: translateY(-4px);
    box-shadow: 0 4px 8px 3px rgba(0,0,0,0.15);
  }

  .card-media {
    height: 200px;
    width: 100%;
  }

  .card-content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    flex: 1;
  }

  .icon-container {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background-color: var(--md-sys-color-secondary-container);
    color: var(--md-sys-color-on-secondary-container);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .icon-container svg {
    width: 24px;
    height: 24px;
  }

  .headline-small {
    font-size: 1.5rem;
    font-weight: 400;
    margin: 0;
    color: var(--md-sys-color-on-surface);
  }

  .body-medium {
    font-size: 1rem;
    line-height: 1.5;
    color: var(--md-sys-color-on-surface-variant);
    margin: 0;
    flex: 1;
  }

  .btn-tonal {
    align-self: flex-start;
    padding: 0.75rem 1.5rem;
    background-color: var(--md-sys-color-secondary-container);
    color: var(--md-sys-color-on-secondary-container);
    border: none;
    border-radius: 100px;
    font-weight: 500;
    cursor: pointer;
    transition: background-color 0.2s;
  }

  .btn-tonal:hover {
    background-color: var(--md-sys-color-secondary-fixed-dim); /* Darker shade */
  }
</style>
