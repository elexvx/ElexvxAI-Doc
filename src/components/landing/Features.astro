---
import { PenTool, Gift, Book } from "@lucide/astro";

const features = [
  {
    title: "核心研究",
    icon: "pen-tool",
    desc: "深度学习算法与基础模型，拓展生成式任务的 AI 能力边界。",
  },
  {
    title: "开源贡献",
    icon: "gift",
    desc: "向全球研究社区贡献最前沿的代码、预训练模型和大规模数据集。",
  },
  {
    title: "工业应用",
    icon: "book",
    desc: "部署可扩展的 AI 解决方案，优化制造、物流和供应链。",
  },
];
---

<section class="features-section">
  <div class="container">
    <div class="grid">
      {
        features.map((feature, index) => (
          <a href="#" class="card group">
            <div class={`card-hover-bg preset-${index + 1}`} />
            <div class="card-content">
              <div class="icon-container">
                {feature.icon === "pen-tool" && (
                  <PenTool size={24} stroke-width={1.5} />
                )}
                {feature.icon === "gift" && (
                  <Gift size={24} stroke-width={1.5} />
                )}
                {feature.icon === "book" && (
                  <Book size={24} stroke-width={1.5} />
                )}
              </div>
              <div class="text-wrapper">
                <h3 class="headline-small">{feature.title}</h3>
                <p class="body-medium">{feature.desc}</p>
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .features-section {
    padding: 3rem 1.5rem;
    background-color: var(--bg);
    color: var(--fg);
    display: flex;
    justify-content: center;
  }

  .container {
    display: flex;
    flex-direction: column;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  @media (max-width: 767px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }

  /* 1:1 OpenAI Primary Card Style */
  .card {
    position: relative;
    background-color: #f9f9f9;
    border-radius: 8px; /* OpenAI uses 8px */
    border: none;
    overflow: hidden;
    text-decoration: none;
    min-height: 220px;
    display: flex;
    flex-direction: column;
    transition: border-color 0.2s ease;
    -webkit-tap-highlight-color: transparent;
  }

  /* The hidden gradient background that fades in on hover */
  :global([data-theme="dark"]) .card {
    background-color: rgba(255, 255, 255, 0.05);
  }

  .card-hover-bg {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.7s ease;
    z-index: 1;
  }

  /* Overlay to make text legible on bright gradients and add a subtle noise texture */
  .card-hover-bg::after {
    content: "";
    position: absolute;
    inset: 0;
    background-color: rgba(0, 0, 0, 0.1);
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
    opacity: 0.4;
    mix-blend-mode: overlay;
    pointer-events: none;
  }

  /* Soft, elegant mesh gradients */
  .preset-1 {
    background-color: #1e1b4b; /* deep indigo base */
    background-image:
      radial-gradient(at 0% 0%, #4338ca 0px, transparent 60%),
      radial-gradient(at 100% 0%, #3b82f6 0px, transparent 60%),
      radial-gradient(at 100% 100%, #8b5cf6 0px, transparent 60%);
  }

  .preset-2 {
    background-color: #2e1065; /* deep purple base */
    background-image:
      radial-gradient(at 0% 100%, #6366f1 0px, transparent 60%),
      radial-gradient(at 50% 0%, #a855f7 0px, transparent 60%),
      radial-gradient(at 100% 100%, #ec4899 0px, transparent 60%);
  }

  .preset-3 {
    background-color: #064e3b; /* deep emerald base */
    background-image:
      radial-gradient(at 0% 0%, #10b981 0px, transparent 60%),
      radial-gradient(at 100% 100%, #0ea5e9 0px, transparent 60%),
      radial-gradient(at 0% 100%, #3b82f6 0px, transparent 60%);
  }

  .card-content {
    position: relative;
    z-index: 2; /* above the hover bg */
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    height: 100%;
  }

  .icon-container {
    color: var(--fg);
    transition: color 0.7s ease;
  }

  /* Push text to the bottom to match OpenAI layout */
  .text-wrapper {
    margin-top: auto;
  }

  .headline-small {
    font-size: 1.125rem; /* 18px */
    font-weight: 600; /* slightly bolder, looks precise */
    margin: 0 0 0.5rem 0; /* slight gap to description */
    color: var(--fg);
    transition: color 0.7s ease;
  }

  .body-medium {
    font-size: 0.9375rem; /* 15px */
    line-height: 1.6;
    color: var(--muted);
    margin: 0;
    transition: color 0.7s ease;
  }

  :global([data-theme="dark"]) .body-medium {
    color: rgba(
      255,
      255,
      255,
      0.7
    ); /* ensure legibility in dark mode before hover */
  }

  @media (hover: hover), (max-width: 768px) {
    .card:hover {
      transform: none;
      box-shadow: none;
    }

    :global([data-theme="light"]) .card:hover {
      box-shadow: none;
    }

    .card:hover .card-hover-bg {
      opacity: 1;
    }

    .card:hover .icon-container {
      color: #ffffff;
    }

    .card:hover .headline-small {
      color: #ffffff;
    }

    .card:hover .body-medium {
      color: rgba(255, 255, 255, 0.9);
    }
  }

  @media (max-width: 768px) {
    .features-section {
      padding: 3rem 1rem;
    }

    .grid {
      gap: 1rem;
    }

    .card {
      min-height: unset;
    }

    .card-content {
      padding: 1.25rem;
      gap: 0.75rem;
    }

    .icon-container :global(svg) {
      width: 22px;
      height: 22px;
    }

    .headline-small {
      margin-bottom: 0.35rem;
    }

    .body-medium {
      line-height: 1.5;
    }
  }

  @media (max-width: 480px) {
    .features-section {
      padding: 2.5rem 1rem;
    }

    .grid {
      gap: 0.875rem;
    }

    .card-content {
      padding: 1rem;
    }
  }
</style>
