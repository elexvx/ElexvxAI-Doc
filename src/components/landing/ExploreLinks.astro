---
import { PenTool, Gift, Book } from "@lucide/astro";
import { getBlogUrl } from "../../lib/blog";
import { getDocUrl } from "../../lib/docs";

type Props = {
  lang?: string;
  title?: string;
};

const { lang = "zh", title = "探索" } = Astro.props;

const cards = [
  {
    label: "博客",
    href: getBlogUrl({ lang }),
    tone: "tone-blog",
    icon: "pen",
  },
  {
    label: "资源",
    href: getDocUrl({ lang, version: "v2" }),
    tone: "tone-resources",
    icon: "gift",
  },
  {
    label: "使用手册",
    href: getDocUrl({ lang, version: "v2", slug: "getting-started/quickstart" }),
    tone: "tone-cookbook",
    icon: "book",
  },
];
---

<section class="explore-section">
  <div class="container">
    <h2 class="title">{title}</h2>
    <div class="grid">
      {
        cards.map((card) => (
          <a class="item" href={card.href}>
            <span class={`explore-card ${card.tone}`}>
              <span class="icon-shell">
                {card.icon === "pen" && <PenTool size={34} stroke-width={1.7} />}
                {card.icon === "gift" && <Gift size={34} stroke-width={1.7} />}
                {card.icon === "book" && <Book size={34} stroke-width={1.7} />}
              </span>
            </span>
            <span class="label">{card.label}</span>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .explore-section {
    background: var(--bg);
    color: var(--fg);
    padding: 0 0 3.25rem;
    content-visibility: auto;
    contain-intrinsic-size: 760px;
  }

  .title {
    margin: 0 0 1.15rem;
    font-size: clamp(1.25rem, 2.1vw, 1.65rem);
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .item {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    color: inherit;
    text-decoration: none;
  }

  .explore-card {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: clamp(190px, 20vw, 320px);
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.14);
    transition:
      transform 0.25s ease,
      border-color 0.25s ease,
      filter 0.25s ease;
  }

  .explore-card::after {
    content: "";
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(255, 255, 255, 0.3) 0.6px, transparent 0.6px);
    background-size: 3px 3px;
    opacity: 0.16;
    pointer-events: none;
  }

  .tone-blog {
    background-image:
      radial-gradient(150% 120% at 18% 94%, rgba(79, 197, 255, 0.78) 0%, transparent 48%),
      radial-gradient(120% 100% at 88% 10%, rgba(188, 124, 255, 0.58) 0%, transparent 58%),
      linear-gradient(145deg, #a6b9ff 0%, #dac0f6 40%, #adc8f6 100%);
  }

  .tone-resources {
    background-image:
      radial-gradient(130% 105% at 96% 20%, rgba(132, 199, 255, 0.65) 0%, transparent 62%),
      radial-gradient(100% 90% at 6% 8%, rgba(216, 245, 255, 0.78) 0%, transparent 50%),
      linear-gradient(160deg, #eff4f9 6%, #dceaf7 44%, #d6e8f8 100%);
  }

  .tone-cookbook {
    background-image:
      radial-gradient(72% 62% at 40% 72%, rgba(173, 240, 113, 0.6) 0%, transparent 76%),
      radial-gradient(120% 110% at 84% 8%, rgba(139, 208, 255, 0.75) 0%, transparent 60%),
      linear-gradient(145deg, #82d4df 0%, #61bbe0 43%, #65b6f0 100%);
  }

  .icon-shell {
    position: relative;
    z-index: 1;
    width: clamp(64px, 6.2vw, 88px);
    height: clamp(64px, 6.2vw, 88px);
    border-radius: 12px;
    background: #f4f4f4;
    color: #0f0f10;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-shadow:
      0 16px 28px rgba(0, 0, 0, 0.12),
      0 2px 0 rgba(255, 255, 255, 0.25) inset;
  }

  .label {
    font-size: clamp(1.05rem, 1.6vw, 1.35rem);
    line-height: 1.2;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--fg);
  }

  @media (hover: hover) and (pointer: fine) {
    .item:hover {
      text-decoration: none;
    }
  }

  @media (max-width: 1150px) {
    .grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 800px) {
    .explore-section {
      padding: 0 0 2.5rem;
    }

    .grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .item {
      gap: 0.8rem;
    }
  }
</style>
