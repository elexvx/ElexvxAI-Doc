---
import { ChevronRight } from "@lucide/astro";
import type { CollectionEntry } from "astro:content";
import { getLucideIcon } from "../../lib/lucide-icons";

type HeroData = CollectionEntry<"landing">["data"]["hero"];

interface Props {
  data: HeroData;
}

const { data } = Astro.props;
const AnnouncementIcon = getLucideIcon(data.announcement?.icon);
---

<section class="hero-section">
  <div class="container">
    <div class="content">
      <h1 class="headline">
        <span class="typewriter" data-fulltext={data.headline}>
          <span class="typewriter-content">
            <span class="highlight" data-fulltext={data.headline}
            ></span><span class="caret" aria-hidden="true">|</span>
          </span>
        </span>
      </h1>

      {data.subheadline && <p class="subtitle">{data.subheadline}</p>}

      <div class="actions">
        <a href={data.primaryCta.href} class="btn-primary">
          {data.primaryCta.label}
        </a>
        {data.secondaryCta && (
          <a href={data.secondaryCta.href} class="btn-secondary">
            {data.secondaryCta.label}
          </a>
        )}
      </div>

      {data.announcement && (
        <a href={data.announcement.href} class="announcement-banner">
          <div class="banner-icon-wrapper">
            <AnnouncementIcon class="banner-icon" />
          </div>
          <div class="banner-content-text">
            <h3 class="banner-title">{data.announcement.title}</h3>
            <p class="banner-desc">{data.announcement.desc}</p>
          </div>
          <ChevronRight class="banner-arrow" />
        </a>
      )}
    </div>
  </div>
</section>

<style>
  .hero-section {
    padding: 5rem 1.5rem 3rem;
    /* Removed background-color to respect "do not modify background" instruction, assuming parent handles it or transparent is desired */
    color: var(--fg);
    display: flex;
    justify-content: center;
    align-items: center;
    text-align: center;
  }

  .container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    width: min(100%, 900px);
    max-width: 900px;
  }

  /* Headline */
  .headline {
    font-size: 3.75rem; /* Adjusted size for better coordination */
    line-height: 1.2;
    font-weight: 600; /* Increased weight slightly */
    margin: 0;
    color: var(--fg);
    letter-spacing: -0.02em;
  }

  .subtitle {
    font-size: 1.25rem;
    line-height: 1.6;
    color: var(--muted, #666);
    max-width: 600px;
    margin: 0;
    text-align: center;
  }

  /* Typewriter & Highlight effect */
  .typewriter {
    position: relative;
    display: inline-block;
    white-space: nowrap;
    text-align: left;
  }

  /* 制造占位撑开最大宽度，避免抖动 */
  .typewriter::before {
    content: attr(data-fulltext) "|";
    visibility: hidden;
    pointer-events: none;
    white-space: nowrap;
  }

  /* 真正的打字容器，绝对定位，不受外部 text-align 居中的拉扯影响 */
  .typewriter-content {
    position: absolute;
    left: 0;
    top: 0;
    display: flex;
    align-items: baseline;
    white-space: nowrap;
  }

  .highlight {
    display: inline-block;
  }

  .caret {
    display: inline-block;
    margin-left: 2px;
    animation: blink 1s step-end infinite;
    font-weight: 300;
  }

  @keyframes blink {
    50% {
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .caret {
      display: none !important;
      animation: none !important;
    }
  }

  /* Actions (Buttons) */
  .actions {
    display: flex;
    gap: 1.25rem;
    margin-top: 1.5rem;
    justify-content: center;
  }

  /* Announcement Banner */
  .announcement-banner {
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
    background-color: var(--panel-soft, #f5f5f4);
    border: 1px solid var(--border, rgba(0,0,0,0.1));
    border-radius: 12px;
    padding: 1.5rem;
    width: 100%;
    max-width: 800px;
    text-decoration: none;
    color: inherit;
    margin: 1rem 0;
  }

  .announcement-banner:hover {
    text-decoration: none;
  }

  :global([data-theme="dark"]) .announcement-banner {
    background-color: rgba(255,255,255,0.03);
    border-color: rgba(255,255,255,0.08);
  }

  .banner-icon-wrapper {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    background: linear-gradient(135deg, #6366f1 0%, #a855f7 100%);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
  }

  .banner-icon {
    width: 24px;
    height: 24px;
  }

  .banner-content-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    text-align: left;
  }

  .banner-title {
    font-size: 1.125rem;
    font-weight: 600;
    margin: 0;
    color: var(--fg);
  }

  .banner-desc {
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--muted, #666);
    margin: 0;
  }

  .banner-arrow {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    color: var(--muted, #666);
    margin-top: 14px; /* Align with title */
    transition: transform 0.2s ease, color 0.2s ease;
  }

  .announcement-banner:hover .banner-arrow {
    transform: translateX(4px);
    color: var(--fg);
  }
  
  @media (max-width: 640px) {
    .announcement-banner {
      flex-direction: column;
      text-align: center;
      align-items: center;
      padding: 1.25rem;
      gap: 1rem;
    }

    .banner-content-text {
      text-align: center;
      align-items: center;
    }

    .banner-arrow {
      display: none;
    }
  }

  .btn-primary {
    display: inline-flex;
    justify-content: center;
    align-items: center;
    min-height: 44px;
    padding: 0.875rem 2rem;
    background-color: #000;
    color: #fff;
    border-radius: 9999px;
    text-decoration: none;
    font-weight: 500;
    font-size: 1rem;
    transition:
      background-color 0.2s ease,
      color 0.2s ease,
      opacity 0.2s ease;
  }

  :global([data-theme="dark"]) .btn-primary {
    background-color: #fff;
    color: #000;
  }

  .btn-primary:hover {
    transform: none;
    box-shadow: none;
    text-decoration: none;
    opacity: 0.92;
  }

  :global([data-theme="dark"]) .btn-primary:hover {
    box-shadow: none;
  }

  .btn-secondary {
    display: inline-flex;
    justify-content: center;
    align-items: center;
    min-height: 44px;
    padding: 0.875rem 2rem;
    background-color: #f5f5f7;
    color: #1d1d1f;
    border: none;
    border-radius: 9999px;
    text-decoration: none;
    font-weight: 500;
    font-size: 1rem;
    transition:
      background-color 0.2s ease,
      color 0.2s ease;
  }

  :global([data-theme="dark"]) .btn-secondary {
    background-color: rgba(255, 255, 255, 0.1);
    color: #fff;
  }

  .btn-secondary:hover {
    background-color: #e8e8ed;
    text-decoration: none;
    color: #1d1d1f;
  }

  :global([data-theme="dark"]) .btn-secondary:hover {
    background-color: rgba(255, 255, 255, 0.15);
    color: #fff;
  }

  @media (max-width: 768px) {
    .headline {
      font-size: clamp(1.9rem, 8vw, 2.4rem);
      line-height: 1.22;
      overflow-wrap: anywhere;
    }

    .subtitle {
      font-size: 1.125rem;
      max-width: 100%;
      padding: 0 1rem;
    }

    .hero-section {
      padding: 3rem 1rem;
    }

    .content {
      gap: 1.5rem;
    }

    .typewriter {
      white-space: normal;
      text-align: center;
      display: inline;
    }

    .typewriter::before {
      content: "";
      display: none;
    }

    .typewriter-content {
      position: static;
      white-space: normal;
      display: inline;
    }
  }

  @media (max-width: 480px) {
    .headline {
      font-size: 2rem;
      line-height: 1.25;
    }

    .hero-section {
      padding: 2.5rem 1rem;
    }

    .typewriter {
      white-space: normal;
      text-align: center;
      display: inline;
    }

    .typewriter::before {
      content: "";
      display: none;
    }

    .typewriter-content {
      position: static;
      white-space: normal;
      display: inline;
    }

    .caret {
      display: none;
    }

    .actions {
      flex-direction: column;
      width: 100%;
      gap: 0.75rem;
      align-items: center;
    }

    .btn-primary,
    .btn-secondary {
      width: clamp(240px, 78vw, 320px);
      max-width: 320px;
      min-height: 46px;
      padding: 0.75rem 1.25rem;
    }
  }
</style>

<script type="module" is:inline>
  const initTypewriter = () => {
    // 检查是否有 reduced-motion 偏好
    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    const highlight = document.querySelector(".highlight");
    const caret = document.querySelector(".caret");

    if (!highlight || !caret || highlight.dataset.initialized === "true")
      return;

    const fullText = highlight.getAttribute("data-fulltext");
    if (!fullText) return;

    if (prefersReducedMotion) {
      // 降级：直接显示完整文本并隐藏光标，无动画
      highlight.textContent = fullText;
      caret.style.display = "none";
      highlight.dataset.initialized = "true";
      return;
    }

    // 初始清空文本
    highlight.textContent = "";

    // 逐字输入逻辑
    const startTyping = () => {
      let i = 0;
      // 增加随机延迟，让打字看起来更自然平滑，而不是僵硬的匀速
      const getDelay = () => 120 + Math.random() * 80;

      const typeChar = () => {
        if (i < fullText.length) {
          i++;
          highlight.textContent = fullText.slice(0, i);
          setTimeout(typeChar, getDelay());
        } else {
          // 打完后隐藏光标，避免后续闪烁干扰
          caret.style.display = "none";
          highlight.dataset.initialized = "true";
        }
      };

      // 略微延迟再开始打字，防止首屏加载后立刻瞬间闪烁
      setTimeout(typeChar, 300);
    };

    // 使用 IntersectionObserver：只在首屏/进入视口时开始
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            // 开始后立即解绑保证只播一次，不循环
            observer.disconnect();
            startTyping();
          }
        });
      },
      { threshold: 0.2 },
    );

    observer.observe(highlight);
  };

  // 支持首次加载
  initTypewriter();
  // 支持 Astro View Transitions
  if (!document.documentElement.hasAttribute("data-hero-page-load-bound")) {
    document.documentElement.setAttribute("data-hero-page-load-bound", "true");
    document.addEventListener("astro:page-load", initTypewriter);
  }
</script>
