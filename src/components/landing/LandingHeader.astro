---
import { SITE, type Lang } from "../../config/site";
import { t } from "../../i18n/ui";
import { getDocUrl } from "../../lib/docs";
import { getBlogUrl } from "../../lib/blog";
import { Sun, Moon, Rss, Menu, X, ChevronDown } from "@lucide/astro";
import IconButton from "../ui/IconButton.astro";
import Button from "../ui/Button.astro";

type Props = {
  lang: Lang;
};

const { lang } = Astro.props;
const docsHomeHref = getDocUrl({ lang, version: SITE.defaultVersion });
const apiReferenceHref = getDocUrl({
  lang,
  version: SITE.defaultVersion,
  slug: "api/rest",
});
const rssHref = "/rss.xml";
const docsLabel = lang === "zh" ? "文档" : "Docs";
const docsDescription =
  lang === "zh"
    ? "OpenAI API 的指南与概念"
    : "Guides and concepts for the OpenAI API";
const apiReferenceLabel = lang === "zh" ? "API 参考" : "API reference";
const apiReferenceDescription =
  lang === "zh" ? "端点、参数与响应" : "Endpoints, parameters, and responses";
---

<header class="hdr" data-sticky="true">
  <div class="inner container">
    <a class="logo" href="/">
      <img src="/logo/favicon.svg" alt="ElexvxAI Logo" class="logo-img" />
    </a>

    <nav class="nav">
      <a class="nav-link is-active" href="/">{t(lang, "home")}</a>
      <div class="api-nav">
        <button
          class="api-toggle"
          id="landingApiNavToggle"
          aria-expanded="false"
          aria-controls="landingApiNavMenu"
          type="button"
        >
          <span>API</span>
          <ChevronDown class="api-chevron" size={16} stroke-width={1.5} />
        </button>
        <div class="api-menu" id="landingApiNavMenu" data-open="false" role="menu">
          <a class="api-menu-item" href={docsHomeHref} role="menuitem">
            <span class="api-menu-title">{docsLabel}</span>
            <span class="api-menu-desc">{docsDescription}</span>
          </a>
          <a class="api-menu-item" href={apiReferenceHref} role="menuitem">
            <span class="api-menu-title">{apiReferenceLabel}</span>
            <span class="api-menu-desc">{apiReferenceDescription}</span>
          </a>
        </div>
      </div>
      <a class="nav-link" href={getBlogUrl({ lang })}>{t(lang, "blog")}</a>
    </nav>

    <div class="controls">
      <IconButton
        as="a"
        href={rssHref}
        target="_blank"
        rel="noopener noreferrer"
        size="md"
        class="rss-btn"
        aria-label={t(lang, "rss")}
      >
        <Rss size={18} stroke-width={1.7} />
      </IconButton>

      <IconButton id="themeToggleLanding" aria-label={t(lang, "theme")}>
        <Sun class="sun" size={20} stroke-width={1.5} />
        <Moon class="moon" size={20} stroke-width={1.5} />
      </IconButton>

      <IconButton
        class="menu-btn"
        id="landingMenuToggle"
        aria-label={lang === "zh" ? "菜单" : "Menu"}
        aria-expanded="false"
        aria-controls="landingMobileDrawer"
      >
        <Menu size={20} stroke-width={1.5} />
      </IconButton>
    </div>
  </div>

  <div class="mobile-drawer-overlay" id="landingMobileDrawerOverlay" data-open="false"></div>
  <aside class="mobile-drawer" id="landingMobileDrawer" data-open="false" aria-hidden="true">
    <div class="drawer-header">
      <span class="drawer-title">{lang === "zh" ? "菜单" : "Menu"}</span>
      <IconButton
        class="drawer-close"
        id="landingMobileDrawerClose"
        aria-label={lang === "zh" ? "关闭菜单" : "Close menu"}
      >
        <X size={20} stroke-width={1.5} />
      </IconButton>
    </div>

    <nav class="drawer-nav">
      <a class="drawer-link" data-drawer-link href="/">{t(lang, "home")}</a>
      <a class="drawer-link" data-drawer-link href={docsHomeHref}>{t(lang, "docs")}</a>
      <a class="drawer-link" data-drawer-link href={getBlogUrl({ lang })}>{t(lang, "blog")}</a>
      <a class="drawer-link" data-drawer-link href={apiReferenceHref}>{apiReferenceLabel}</a>
      <a class="drawer-link" data-drawer-link href={rssHref} target="_blank" rel="noopener noreferrer"
        >RSS</a
      >
      <Button
        id="landingDrawerThemeToggle"
        variant="ghost"
        size="md"
        data-drawer-link
        class="drawer-theme-btn"
      >
        {t(lang, "theme")}
      </Button>
    </nav>
  </aside>
</header>

<script>
  function initLandingHeader() {
    const toggleTheme = () => {
      const key = "theme";
      const cur = document.documentElement.dataset.theme || "dark";
      const next = cur === "dark" ? "light" : "dark";
      document.documentElement.dataset.theme = next;
      localStorage.setItem(key, next);
    };

    const themeBtns = [
      document.getElementById("themeToggleLanding"),
      document.getElementById("landingDrawerThemeToggle"),
    ];
    themeBtns.forEach((btn) => btn?.addEventListener("click", toggleTheme));

    const apiToggle = document.getElementById("landingApiNavToggle");
    const apiMenu = document.getElementById("landingApiNavMenu");
    if (apiToggle && apiMenu && !apiToggle.hasAttribute("data-api-nav-listener")) {
      apiToggle.setAttribute("data-api-nav-listener", "true");
      const apiNav = apiToggle.closest(".api-nav");
      const isDesktop = () => window.matchMedia("(min-width: 1025px)").matches;
      const setApiOpen = (open) => {
        apiMenu.setAttribute("data-open", open ? "true" : "false");
        apiToggle.setAttribute("aria-expanded", open ? "true" : "false");
      };

      apiToggle.addEventListener("click", (event) => {
        event.preventDefault();
        if (isDesktop()) {
          setApiOpen(true);
          return;
        }
        const isOpen = apiMenu.getAttribute("data-open") === "true";
        setApiOpen(!isOpen);
      });

      if (apiNav && !apiNav.hasAttribute("data-api-nav-hover-listener")) {
        apiNav.setAttribute("data-api-nav-hover-listener", "true");
        apiNav.addEventListener("mouseenter", () => {
          if (!isDesktop()) return;
          setApiOpen(true);
        });
        apiNav.addEventListener("mouseleave", () => {
          if (!isDesktop()) return;
          setApiOpen(false);
        });
      }

      if (!document.documentElement.hasAttribute("data-landing-api-doc-click")) {
        document.documentElement.setAttribute("data-landing-api-doc-click", "true");
        document.addEventListener("click", (event) => {
          const currentToggle = document.getElementById("landingApiNavToggle");
          const currentMenu = document.getElementById("landingApiNavMenu");
          if (!currentToggle || !currentMenu) return;
          if (
            currentToggle.contains(event.target) ||
            currentMenu.contains(event.target)
          ) {
            return;
          }
          currentMenu.setAttribute("data-open", "false");
          currentToggle.setAttribute("aria-expanded", "false");
        });
      }

      if (!document.documentElement.hasAttribute("data-landing-api-esc")) {
        document.documentElement.setAttribute("data-landing-api-esc", "true");
        document.addEventListener("keydown", (event) => {
          if (event.key !== "Escape") return;
          const currentToggle = document.getElementById("landingApiNavToggle");
          const currentMenu = document.getElementById("landingApiNavMenu");
          currentMenu?.setAttribute("data-open", "false");
          currentToggle?.setAttribute("aria-expanded", "false");
        });
      }
    }

    const menuBtn = document.getElementById("landingMenuToggle");
    const overlay = document.getElementById("landingMobileDrawerOverlay");
    const drawer = document.getElementById("landingMobileDrawer");
    const closeBtn = document.getElementById("landingMobileDrawerClose");
    if (!menuBtn || !overlay || !drawer || !closeBtn) return;

    const setDrawerOpen = (open) => {
      overlay.setAttribute("data-open", open ? "true" : "false");
      drawer.setAttribute("data-open", open ? "true" : "false");
      drawer.setAttribute("aria-hidden", open ? "false" : "true");
      menuBtn.setAttribute("aria-expanded", open ? "true" : "false");
      document.body.style.overflow = open ? "hidden" : "";
    };

    menuBtn.addEventListener("click", () => {
      const isOpen = drawer.getAttribute("data-open") === "true";
      setDrawerOpen(!isOpen);
    });
    overlay.addEventListener("click", () => setDrawerOpen(false));
    closeBtn.addEventListener("click", () => setDrawerOpen(false));

    const drawerLinks = drawer.querySelectorAll("[data-drawer-link]");
    drawerLinks.forEach((link) => link.addEventListener("click", () => setDrawerOpen(false)));

    document.addEventListener("keydown", (event) => {
      if (event.key !== "Escape") return;
      if (drawer.getAttribute("data-open") !== "true") return;
      setDrawerOpen(false);
    });

    window.addEventListener("resize", () => {
      if (window.innerWidth >= 1025) setDrawerOpen(false);
    });

    setDrawerOpen(false);
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initLandingHeader, { once: true });
  } else {
    initLandingHeader();
  }
</script>

<style>
  .hdr {
    z-index: 100;
    height: var(--header-h);
    background: color-mix(in srgb, var(--bg), transparent 20%);
    border-bottom: 1px solid var(--border);
    backdrop-filter: blur(12px);
    position: sticky;
    top: 0;
  }

  .inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
  }

  @media (min-width: 1025px) {
    .inner {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
      gap: 1.5rem;
    }
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    text-decoration: none;
    justify-self: start;
  }

  .logo-img {
    height: 30px;
    width: auto;
  }

  .nav {
    display: none;
  }

  @media (min-width: 1025px) {
    .nav {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.75rem;
    }
  }

  .nav-link {
    min-height: 2.25rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.875rem;
    padding: 0 0.95rem;
    border-radius: 0.65rem;
    color: var(--muted);
    text-decoration: none;
    font-weight: 500;
    transition:
      color 0.2s ease,
      background-color 0.2s ease;
  }

  .nav-link:hover,
  .nav-link.is-active {
    color: var(--fg);
    background-color: var(--panel);
  }

  .api-nav {
    position: relative;
  }

  .api-toggle {
    min-height: 2.25rem;
    border: none;
    border-radius: 0.65rem;
    padding: 0 0.85rem;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--muted);
    background: transparent;
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition:
      color 0.2s ease,
      background-color 0.2s ease;
  }

  .api-toggle:hover,
  .api-toggle[aria-expanded="true"] {
    color: var(--fg);
    background-color: var(--panel);
  }

  .api-chevron {
    transition: transform 0.2s ease;
  }

  .api-toggle[aria-expanded="true"] .api-chevron {
    transform: rotate(180deg);
  }

  .api-menu {
    position: absolute;
    top: calc(100% + 0.6rem);
    left: 0;
    width: min(380px, 60vw);
    border-radius: 0.75rem;
    border: 1px solid var(--border);
    background: color-mix(in srgb, var(--bg), #16181d 10%);
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.28);
    padding: 0.45rem;
    opacity: 0;
    pointer-events: none;
    transform: translateY(-8px);
    transition:
      opacity 0.2s ease,
      transform 0.2s ease;
  }

  .api-menu[data-open="true"] {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .api-menu-item {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    text-decoration: none;
    border-radius: 0.6rem;
    padding: 0.7rem 0.8rem;
    color: var(--fg);
  }

  .api-menu-item:hover {
    background: color-mix(in srgb, var(--panel), transparent 10%);
  }

  .api-menu-title {
    font-size: 0.875rem;
    font-weight: 500;
    line-height: 1.35;
  }

  .api-menu-desc {
    color: var(--muted);
    font-size: 0.875rem;
    line-height: 1.45;
  }

  .controls {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    justify-self: end;
  }

  .rss-btn {
    display: none;
  }

  @media (min-width: 1025px) {
    .rss-btn {
      display: flex;
    }
  }

  .menu-btn {
    display: flex;
  }

  @media (min-width: 1025px) {
    .menu-btn {
      display: none !important;
    }
  }

  .mobile-drawer-overlay {
    position: fixed;
    inset: 0;
    z-index: 130;
    background: color-mix(in srgb, #000, transparent 48%);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease;
  }

  .mobile-drawer-overlay[data-open="true"] {
    opacity: 1;
    pointer-events: auto;
  }

  .mobile-drawer {
    position: fixed;
    right: 0.75rem;
    top: calc(var(--header-h) + 0.5rem);
    width: min(320px, calc(100vw - 1.5rem));
    z-index: 140;
    border-radius: 0.9rem;
    border: 1px solid var(--border);
    background: var(--bg);
    box-shadow: 0 18px 48px rgba(0, 0, 0, 0.28);
    padding: 0.75rem;
    opacity: 0;
    pointer-events: none;
    transform: translateX(16px);
    transition:
      opacity 0.22s ease,
      transform 0.22s ease;
  }

  :global([data-theme="light"]) .mobile-drawer {
    box-shadow: 0 18px 42px rgba(0, 0, 0, 0.18);
  }

  .mobile-drawer[data-open="true"] {
    opacity: 1;
    pointer-events: auto;
    transform: translateX(0);
  }

  .drawer-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.25rem 0.25rem 0.5rem;
  }

  .drawer-title {
    color: var(--fg);
    font-size: 0.95rem;
    font-weight: 600;
  }

  .drawer-nav {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .drawer-link {
    min-height: 44px;
    border-radius: 0.625rem;
    display: flex;
    align-items: center;
    padding: 0 0.9rem;
    color: var(--fg);
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 500;
    border: none;
    background: transparent;
    text-align: left;
    cursor: pointer;
  }

  .drawer-link:hover {
    background: var(--panel);
    color: var(--fg);
  }

  .drawer-nav :global(.drawer-theme-btn) {
    width: 100%;
    min-height: 44px;
    border-radius: 0.625rem;
    justify-content: flex-start;
    padding-inline: 0.9rem;
    border: none;
    background: transparent;
    color: var(--fg);
    font-size: 0.95rem;
    font-weight: 500;
  }

  .drawer-nav :global(.drawer-theme-btn:hover) {
    background: var(--panel);
    color: var(--fg);
  }

  @media (max-width: 1024px) {
    .drawer-link:active {
      transform: scale(0.99);
    }
  }

  @media (min-width: 1025px) {
    .mobile-drawer-overlay,
    .mobile-drawer {
      display: none !important;
    }
  }

  :global([data-theme="dark"]) .sun {
    display: none;
  }
  :global([data-theme="light"]) .moon {
    display: none;
  }
</style>
