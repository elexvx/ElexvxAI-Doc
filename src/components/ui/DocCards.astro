---
import DocCard from "./DocCard.astro";

type CardItem = {
  title: string;
  description?: string;
  desc?: string;
  href: string;
  icon?: string;
};

type Props = {
  items: CardItem[];
  columns?: 2 | 3 | 4;
};

const { items = [], columns = 3 } = Astro.props;
const cols = columns === 2 || columns === 4 ? columns : 3;
---

<div class="doc-cards" data-cols={String(cols)}>
  {items.map((item) => <DocCard item={item} />)}
</div>

<style>
  .doc-cards {
    display: grid;
    gap: 1rem;
    margin: 1.5rem 0 2rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 48rem) {
    .doc-cards[data-cols="2"] {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .doc-cards[data-cols="3"] {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .doc-cards[data-cols="4"] {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 72rem) {
    .doc-cards[data-cols="2"] {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .doc-cards[data-cols="3"] {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .doc-cards[data-cols="4"] {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }
</style>
