---
import type { HTMLAttributes } from "astro/types";

type ButtonVariant = "default" | "secondary" | "ghost" | "destructive" | "link";
type ButtonSize = "sm" | "md" | "lg" | "icon";

type Props = HTMLAttributes<"button"> & {
  variant?: ButtonVariant;
  size?: ButtonSize;
};

const {
  variant = "default",
  size = "md",
  class: className,
  type = "button",
  ...rest
} = Astro.props as Props;

const variantClasses: Record<ButtonVariant, string> = {
  default: "ui-btn--default",
  secondary: "ui-btn--secondary",
  ghost: "ui-btn--ghost",
  destructive: "ui-btn--destructive",
  link: "ui-btn--link",
};

const sizeClasses: Record<ButtonSize, string> = {
  sm: "ui-btn--sm",
  md: "ui-btn--md",
  lg: "ui-btn--lg",
  icon: "ui-btn--icon",
};
---

<button
  type={type}
  class:list={["ui-btn", variantClasses[variant], sizeClasses[size], className]}
  {...rest}
>
  <slot />
</button>

<style>
  .ui-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    white-space: nowrap;
    border: 1px solid transparent;
    font-size: 0.875rem;
    font-weight: 500;
    line-height: 1;
    transition:
      color 0.2s ease,
      background-color 0.2s ease,
      border-color 0.2s ease,
      opacity 0.2s ease;
    cursor: pointer;
  }

  .ui-btn:focus-visible {
    outline: none;
    box-shadow: var(--ring);
  }

  .ui-btn:disabled {
    opacity: 0.5;
    pointer-events: none;
  }

  .ui-btn--default {
    background: var(--accent);
    color: var(--bg);
  }

  .ui-btn--default:hover {
    opacity: 0.9;
  }

  .ui-btn--secondary {
    background: var(--panel);
    color: var(--fg);
    border-color: var(--border);
  }

  .ui-btn--secondary:hover {
    background: var(--panel-2);
  }

  .ui-btn--ghost {
    background: transparent;
    color: var(--fg);
    border-color: transparent;
  }

  .ui-btn--ghost:hover {
    background: var(--panel);
  }

  .ui-btn--destructive {
    background: var(--danger);
    color: #fff;
  }

  .ui-btn--destructive:hover {
    opacity: 0.9;
  }

  .ui-btn--link {
    background: transparent;
    border: none;
    color: var(--accent);
    height: auto;
    padding: 0;
    text-decoration: underline;
    text-underline-offset: 4px;
    border-radius: 0;
  }

  .ui-btn--sm {
    height: 2rem;
    padding: 0 0.75rem;
    border-radius: var(--radius-sm);
  }

  .ui-btn--md {
    height: 2.5rem;
    padding: 0 1rem;
    border-radius: var(--radius-md);
  }

  .ui-btn--lg {
    height: 2.75rem;
    padding: 0 1.5rem;
    border-radius: var(--radius-lg);
  }

  .ui-btn--icon {
    height: 2.5rem;
    width: 2.5rem;
    padding: 0;
    border-radius: var(--radius-md);
  }
</style>
