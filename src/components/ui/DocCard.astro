---
import {
  Book,
  Code2,
  Gift,
  HelpCircle,
  PenTool,
  Rocket,
} from "@lucide/astro";

type CardItem = {
  title: string;
  description?: string;
  desc?: string;
  href: string;
  icon?: string;
};

type Props = {
  item: CardItem;
};

const { item } = Astro.props;

const IconMap = {
  "pen-tool": PenTool,
  gift: Gift,
  book: Book,
  code: Code2,
  rocket: Rocket,
  help: HelpCircle,
} as const;

const Icon =
  item.icon && item.icon in IconMap
    ? IconMap[item.icon as keyof typeof IconMap]
    : null;

const description = item.description ?? item.desc ?? "";
---

<a class="doc-card" href={item.href}>
  {Icon ? (
    <span class="doc-card__icon" aria-hidden="true">
      <Icon size={18} stroke-width={1.8} />
    </span>
  ) : null}
  <span class="doc-card__title">{item.title}</span>
  {description ? <span class="doc-card__desc">{description}</span> : null}
</a>

<style>
  .doc-card {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    min-height: 100%;
    padding: 1rem;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    background: var(--panel);
    color: var(--fg);
    text-decoration: none;
    box-shadow: var(--shadow-sm);
    transition:
      border-color 0.2s ease,
      background-color 0.2s ease;
  }

  .doc-card:hover {
    border-color: color-mix(in srgb, var(--accent), transparent 55%);
    background: color-mix(in srgb, var(--panel), var(--fg) 2%);
    text-decoration: none;
  }

  .doc-card__icon {
    width: 1.9rem;
    height: 1.9rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--accent), transparent 90%);
    color: var(--accent);
    border: 1px solid color-mix(in srgb, var(--accent), transparent 70%);
  }

  .doc-card__title {
    font-size: 1rem;
    line-height: 1.35;
    font-weight: 620;
    color: var(--fg);
  }

  .doc-card__desc {
    font-size: 0.925rem;
    line-height: 1.5;
    color: var(--muted);
  }
</style>
