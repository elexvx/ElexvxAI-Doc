---
import type { Lang } from "../config/site";
import { Search } from '@lucide/astro';

type Props = {
  lang: Lang;
};

const { lang } = Astro.props;
const action = `/${lang}/search/`;
const placeholder = lang === "zh" ? "搜索" : "Search";
---

<div class="searchWrap">
  <form class="search" method="get" action={action}>
    <Search class="searchIcon" size={16} stroke-width={1.5} />
    <input
      class="searchInput"
      type="search"
      name="q"
      placeholder={placeholder}
      autocomplete="off"
    />
    <span class="searchKeys" aria-hidden="true">
      <span class="searchKey">⌘</span>
      <span class="searchKey">K</span>
    </span>
  </form>
</div>

<style>
  .searchWrap {
    padding: 0.25rem 0.35rem 1.05rem;
  }

  .search {
    position: relative;
    display: flex;
    align-items: center;
    height: 42px;
    border-radius: 12px;
    background: var(--content-bg);
    border: 1px solid var(--divider);
    padding-left: 0.72rem;
  }

  .searchIcon {
    color: var(--muted-2);
    flex-shrink: 0;
  }

  .search:focus-within {
    border-color: color-mix(in srgb, var(--accent), transparent 40%);
    box-shadow: var(--ring);
  }

  .search:focus-within .searchIcon {
    color: var(--accent);
  }

  .searchInput {
    width: 100%;
    height: 100%;
    border: 0;
    background: transparent;
    color: var(--fg);
    padding: 0 3.35rem 0 0.58rem;
    font-size: 0.95rem;
    outline: none;
  }

  .searchInput::placeholder {
    color: var(--muted-2);
  }

  .searchKeys {
    position: absolute;
    right: 0.42rem;
    top: 50%;
    display: inline-flex;
    gap: 0.3rem;
    align-items: center;
    transform: translateY(-50%);
  }

  .searchKey {
    font-size: 0.78rem;
    line-height: 1;
    color: var(--muted-2);
    padding: 0.3rem 0.46rem;
    border: 1px solid var(--divider);
    border-radius: 7px;
    background: color-mix(in srgb, var(--content-bg), var(--sidebar-bg) 56%);
  }
</style>
