---
import type { SidebarGroup } from "../lib/docs";
import SearchBox from "./SearchBox.astro";
import type { Lang } from "../config/site";

type Props = {
  groups: SidebarGroup[];
  currentPath: string;
  lang: Lang;
};

const { groups, currentPath, lang } = Astro.props;

function getIcon(title: string) {
  const t = title.toLowerCase();
  if (t.includes("intro"))
    return `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" class="sidebar-icon" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`;
  if (t.includes("install"))
    return `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" class="sidebar-icon" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>`;
  if (t.includes("config"))
    return `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" class="sidebar-icon" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>`;
  if (t.includes("api") || t.includes("sdk"))
    return `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" class="sidebar-icon" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2H2v10l9.29 9.29c.94.94 2.48.94 3.42 0l6.58-6.58c.94-.94.94-2.48 0-3.42L12 2Z"/><path d="M7 7h.01"/></svg>`;
  if (t.includes("data"))
    return `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" class="sidebar-icon" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><line x1="3" x2="21" y1="9" y2="9"/><line x1="9" x2="9" y1="21" y2="9"/></svg>`;
  if (t.includes("model") || t.includes("neural"))
    return `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" class="sidebar-icon" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" x2="15.42" y1="13.51" y2="17.49"/><line x1="15.41" x2="8.59" y1="6.51" y2="10.49"/></svg>`;
  return `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" class="sidebar-icon" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" x2="8" y1="13" y2="13"/><line x1="16" x2="8" y1="17" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`;
}
---

<div class="mobileOverlay" id="sidebarOverlay"></div>
<aside class="side" id="sidebar" transition:persist="sidebar">
  <div class="mobileHeader">
    <span class="mobileTitle">Menu</span>
    <button class="closeBtn" id="sidebarClose" aria-label="Close menu">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 6 6 18"/>
        <path d="m6 6 12 12"/>
      </svg>
    </button>
  </div>
  <SearchBox lang={lang} />
  {
    groups.map((g) => (
      <details
        class="group"
        open={g.items.some(
          (it) => it.href === currentPath || it.href === `${currentPath}/`,
        )}
      >
        <summary class="groupTitle">{g.title}</summary>
        <ul class="list">
          {g.items.map((it) => {
            const active =
              it.href === currentPath || it.href === `${currentPath}/`;
            return (
              <li>
                <a class:list={["item", active && "active"]} href={it.href}>
                  <span class="icon" set:html={getIcon(it.title)} />
                  <span class="text">{it.title}</span>
                </a>
              </li>
            );
          })}
        </ul>
      </details>
    ))
  }
</aside>

<style>
  .mobileOverlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 40;
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .mobileOverlay.open {
    opacity: 1;
  }

  .mobileHeader {
    display: none;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--border-2);
  }

  .mobileTitle {
    font-weight: 600;
    font-size: 1rem;
  }

  .closeBtn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border: none;
    background: transparent;
    color: var(--muted);
    cursor: pointer;
    border-radius: 0.5rem;
  }

  .closeBtn:hover {
    color: var(--fg);
    background: var(--panel-2);
  }

  .side {
    position: sticky;
    top: var(--header-h);
    height: calc(100vh - var(--header-h));
    overflow: auto;
    padding: 0.75rem 0.75rem 1.5rem 0;
    border-right: 1px solid var(--border-2);
    display: flex;
    flex-direction: column;
  }

  .group {
    margin: 0.25rem 0 0.75rem;
    border-radius: var(--radius-md);
  }

  .groupTitle {
    list-style: none;
    font-size: 0.75rem;
    font-weight: 650;
    color: var(--muted-2);
    padding: 0.45rem 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    cursor: pointer;
    user-select: none;
  }

  details > summary::-webkit-details-marker {
    display: none;
  }

  details > summary::after {
    content: "";
    float: right;
    width: 10px;
    height: 10px;
    margin-top: 2px;
    border-right: 1.5px solid var(--muted-2);
    border-bottom: 1.5px solid var(--muted-2);
    transform: rotate(-45deg);
    opacity: 0.75;
    transition: transform 0.15s ease;
  }

  details[open] > summary::after {
    transform: rotate(45deg);
  }

  .list {
    list-style: none;
    padding: 0;
    margin: 0.5rem 0 0;
  }

  .item {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.45rem 0.6rem;
    border-radius: 12px;
    color: var(--muted);
    transition: all 0.2s ease;
    font-size: 0.95rem;
    font-weight: 500;
    margin-bottom: 2px;
  }

  .item:hover {
    color: var(--fg);
    background: color-mix(in srgb, var(--panel-2), transparent 0%);
    text-decoration: none;
  }

  .active {
    background: color-mix(in srgb, var(--accent-dim), transparent 40%);
    color: color-mix(in srgb, var(--fg), transparent 0%);
  }

  .active::before {
    content: "";
    position: absolute;
    left: -1px;
    top: 8px;
    bottom: 8px;
    width: 2px;
    border-radius: 2px;
    background: var(--accent);
  }

  .active:hover {
    background: color-mix(in srgb, var(--accent-dim), transparent 30%);
  }

  .active .sidebar-icon {
    stroke: var(--accent);
  }

  .icon {
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.8;
  }

  @media (max-width: 900px) {
    .mobileOverlay {
      display: block;
      pointer-events: none;
    }

    .mobileOverlay.open {
      pointer-events: auto;
    }

    .side {
      position: fixed;
      top: 0;
      left: 0;
      height: 100vh;
      width: 300px;
      max-width: 85vw;
      z-index: 50;
      transform: translateX(-100%);
      transition: transform 0.25s ease;
      border-right: 1px solid var(--border-2);
      background: var(--bg);
      padding: 0 0.75rem 1.5rem;
    }

    .side.open {
      transform: translateX(0);
    }

    .mobileHeader {
      display: flex;
    }
  }
</style>

<script>
  function initSidebar() {
    const sidebar = document.getElementById("sidebar");
    const overlay = document.getElementById("sidebarOverlay");
    const menuToggle = document.getElementById("menuToggle");
    const closeBtn = document.getElementById("sidebarClose");

    if (!sidebar || !overlay) return;

    const openSidebar = () => {
      sidebar.classList.add("open");
      overlay.classList.add("open");
      document.body.style.overflow = "hidden";
    };

    const closeSidebar = () => {
      sidebar.classList.remove("open");
      overlay.classList.remove("open");
      document.body.style.overflow = "";
    };

    menuToggle?.addEventListener("click", openSidebar);
    closeBtn?.addEventListener("click", closeSidebar);
    overlay.addEventListener("click", closeSidebar);

    const sidebarLinks = sidebar.querySelectorAll(".item");
    sidebarLinks.forEach((link) => {
      link.addEventListener("click", () => {
        if (window.innerWidth <= 900) {
          closeSidebar();
        }
      });
    });

    const currentPath = window.location.pathname;
    const exactMatch = Array.from(sidebarLinks).find(
      (link) =>
        link.getAttribute("href") === currentPath ||
        link.getAttribute("href") === `${currentPath}/`,
    );

    sidebarLinks.forEach((link) => link.classList.remove("active"));

    if (exactMatch) {
      exactMatch.classList.add("active");
      exactMatch.scrollIntoView({ block: "nearest" });
    }

    const groups = Array.from(sidebar.querySelectorAll("details.group"));
    const activeGroup = exactMatch?.closest("details.group");
    groups.forEach((g) => {
      (g as HTMLDetailsElement).open = g === activeGroup;
    });

    if (!activeGroup && groups.length > 0) {
      (groups[0] as HTMLDetailsElement).open = true;
    }
  }

  document.addEventListener("astro:page-load", initSidebar);
  initSidebar();
</script>
