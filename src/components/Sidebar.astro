---
import { type SidebarGroup, getDocUrl } from "../lib/docs";
import SearchBox from "./SearchBox.astro";
import { SITE, type Lang } from "../config/site";
import { t } from "../i18n/ui";
import { getBlogUrl } from "../lib/blog";
import { X } from "@lucide/astro";
import IconButton from "./ui/IconButton.astro";

type Props = {
  groups: SidebarGroup[];
  currentPath: string;
  lang: Lang;
  version: string;
};

const { groups, currentPath, lang, version } = Astro.props;
const pathSegments = currentPath.split("/").filter(Boolean);
const versionIndex = pathSegments.findIndex((segment) => /^v\d+$/i.test(segment));
const currentSlug =
  versionIndex >= 0 ? pathSegments.slice(versionIndex + 1).join("/") : "";
---

<div class="doc-drawer-overlay" id="sidebarOverlay"></div>
<aside class="doc-sidebar" id="sidebar" transition:persist="sidebar">
  <div class="sidebarTop">
    <div class="doc-drawer-header">
      <span class="mobileTitle">Menu</span>
      <IconButton id="sidebarClose" aria-label="Close menu" size="sm">
        <X size={20} stroke-width={1.5} />
      </IconButton>
    </div>

    <nav class="mobile-nav">
      <a class="mobile-nav-item" href="/">{t(lang, "home")}</a>
      <a
        class="mobile-nav-item"
        href={getDocUrl({ lang, version: SITE.defaultVersion })}
        >{t(lang, "docs")}</a
      >
      <a class="mobile-nav-item" href={getBlogUrl({ lang })}>{t(lang, "blog")}</a>
    </nav>

    <SearchBox lang={lang} />

    <div class="versionWrap">
      <label for="sidebarVersionSelect" class="versionLabel">
        {lang === "zh" ? "版本" : "Version"}
      </label>
      <select id="sidebarVersionSelect" class="versionSelect" data-version-select>
        {
          SITE.versions.map((itemVersion) => (
            <option
              value={getDocUrl({
                lang,
                version: itemVersion,
                slug: currentSlug || undefined,
              })}
              selected={itemVersion === version}
            >
              {itemVersion.toUpperCase()}
            </option>
          ))
        }
      </select>
    </div>
  </div>

  <div class="sidebarNav">
    {
      groups.map((g) => (
        <details
          class="group"
          open={g.items.some(
            (it) => it.href === currentPath || it.href === `${currentPath}/`,
          )}
        >
          <summary class="groupTitle">{g.title}</summary>
          <ul class="list">
            {g.items.map((it) => {
              const active =
                it.href === currentPath || it.href === `${currentPath}/`;
              return (
                <li>
                  <a class:list={["item", active && "active"]} href={it.href}>
                    <span class="text">{it.title}</span>
                  </a>
                </li>
              );
            })}
          </ul>
        </details>
      ))
    }
  </div>
</aside>

<style>
  .mobileTitle {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--text);
  }

  .sidebarTop {
    position: sticky;
    top: 0;
    z-index: 10;
    background: var(--sidebar-bg);
    border-bottom: 1px solid var(--divider);
    padding: 0.8rem 0.85rem 0.75rem;
  }

  .sidebarTop :global(.searchWrap) {
    padding: 0;
    margin-bottom: 0.65rem;
  }

  .versionWrap {
    padding: 0 0.35rem;
    display: grid;
    gap: 0.35rem;
  }

  .versionLabel {
    font-size: 12px;
    line-height: 1.2;
    color: var(--muted);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    font-weight: 600;
  }

  .versionSelect {
    width: 100%;
    border: 1px solid var(--divider);
    border-radius: 10px;
    background: var(--content-bg);
    color: var(--text);
    min-height: 36px;
    padding: 0 0.55rem;
    font-size: 0.92rem;
  }

  .sidebarNav {
    overflow: auto;
    height: calc(100vh - var(--header-h) - var(--sidebar-top-h, 188px));
    padding: 0.75rem 0.8rem 1.4rem;
  }

  .doc-drawer-header :global(.ui-ibtn) {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border: none;
    background: transparent;
    color: var(--muted);
    cursor: pointer;
    border-radius: 10px;
  }

  .doc-drawer-header :global(.ui-ibtn:hover) {
    color: var(--text);
    background: color-mix(in srgb, var(--content-bg), var(--sidebar-bg) 36%);
  }

  .mobile-nav {
    display: none;
  }

  .group {
    margin: 0 0 0.12rem;
    border-radius: 10px;
  }

  .groupTitle {
    list-style: none;
    font-size: 12px;
    font-weight: 620;
    color: var(--muted);
    padding: 0.52rem 0.65rem 0.45rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    cursor: pointer;
    user-select: none;
  }

  details > summary::-webkit-details-marker {
    display: none;
  }

  details > summary::after {
    content: "";
    float: right;
    width: 7px;
    height: 7px;
    margin-top: 4px;
    margin-right: 0.35rem;
    border-right: 1.3px solid var(--muted-2);
    border-bottom: 1.3px solid var(--muted-2);
    transform: rotate(-45deg);
    opacity: 0.85;
    transition:
      transform 0.16s ease,
      opacity 0.16s ease;
  }

  details[open] > summary::after {
    transform: rotate(45deg);
    opacity: 0.9;
  }

  .list {
    list-style: none;
    padding: 0;
    margin: 0.05rem 0 0.72rem;
  }

  .item {
    display: flex;
    align-items: center;
    min-height: 34px;
    padding: 0.4rem 0.7rem;
    border-radius: 10px;
    color: color-mix(in srgb, var(--text), transparent 12%);
    transition: background-color 0.16s ease;
    font-size: 0.95rem;
    font-weight: 500;
    margin-bottom: 0.08rem;
    text-decoration: none;
  }

  .item:hover {
    color: var(--text);
    background: color-mix(in srgb, var(--content-bg), var(--sidebar-bg) 65%);
    text-decoration: none;
  }

  .active {
    background: color-mix(in srgb, var(--content-bg), var(--sidebar-bg) 26%);
    color: var(--text);
    font-weight: 560;
  }

  .active:hover {
    background: color-mix(in srgb, var(--content-bg), var(--sidebar-bg) 18%);
  }

  @media (max-width: 900px) {
    .sidebarTop {
      padding: 0 0.25rem 0.65rem;
    }

    .mobile-nav {
      display: flex;
      flex-direction: column;
      padding: 0.25rem 0.35rem 0.85rem;
      gap: 0.16rem;
      border-bottom: 1px solid var(--divider);
      margin-bottom: 0.75rem;
    }

    .mobile-nav-item {
      color: var(--muted);
      text-decoration: none;
      font-weight: 500;
      padding: 0.48rem 0.62rem;
      border-radius: 10px;
      font-size: 0.9rem;
      transition: background-color 0.2s;
    }

    .mobile-nav-item:hover {
      color: var(--text);
      background: color-mix(in srgb, var(--content-bg), var(--sidebar-bg) 55%);
    }

    .sidebarNav {
      height: calc(100vh - var(--header-h) - var(--sidebar-top-h, 258px));
      padding: 0.35rem 0.2rem 1.2rem;
    }
  }
</style>

<script>
  function initSidebar() {
    const sidebar = document.getElementById("sidebar");
    const overlay = document.getElementById("sidebarOverlay");
    const menuToggle = document.getElementById("sidebarToggle");
    const closeBtn = document.getElementById("sidebarClose");

    if (!sidebar || !overlay) return;
    const sidebarTop = sidebar.querySelector(".sidebarTop");
    const sidebarNav = sidebar.querySelector(".sidebarNav");

    const openSidebar = () => {
      const currentSidebar = document.getElementById("sidebar");
      const currentOverlay = document.getElementById("sidebarOverlay");
      if (!currentSidebar || !currentOverlay) return;
      currentSidebar.classList.add("open");
      currentOverlay.classList.add("open");
      document.body.style.overflow = "hidden";
    };

    const closeSidebar = () => {
      const currentSidebar = document.getElementById("sidebar");
      const currentOverlay = document.getElementById("sidebarOverlay");
      if (!currentSidebar || !currentOverlay) return;
      currentSidebar.classList.remove("open");
      currentOverlay.classList.remove("open");
      document.body.style.overflow = "";
    };

    if (menuToggle && !menuToggle.hasAttribute("data-sidebar-listener")) {
      menuToggle.setAttribute("data-sidebar-listener", "true");
      menuToggle.addEventListener("click", openSidebar);
    }
    if (closeBtn && !closeBtn.hasAttribute("data-sidebar-listener")) {
      closeBtn.setAttribute("data-sidebar-listener", "true");
      closeBtn.addEventListener("click", closeSidebar);
    }
    if (!overlay.hasAttribute("data-sidebar-listener")) {
      overlay.setAttribute("data-sidebar-listener", "true");
      overlay.addEventListener("click", closeSidebar);
    }

    const versionSelect = sidebar.querySelector(
      "[data-version-select]",
    ) as HTMLSelectElement | null;
    if (versionSelect && !versionSelect.hasAttribute("data-sidebar-listener")) {
      versionSelect.setAttribute("data-sidebar-listener", "true");
      versionSelect.addEventListener("change", () => {
        if (!versionSelect.value) return;
        window.location.href = versionSelect.value;
      });
    }

    const syncSidebarNavHeight = () => {
      if (!(sidebarTop instanceof HTMLElement)) return;
      const topHeight = sidebarTop.offsetHeight;
      sidebar.style.setProperty("--sidebar-top-h", `${topHeight}px`);
      if (sidebarNav instanceof HTMLElement) {
        sidebarNav.style.height = `calc(100vh - var(--header-h) - ${topHeight}px)`;
      }
    };
    syncSidebarNavHeight();

    if (!document.documentElement.hasAttribute("data-sidebar-resize-listener")) {
      document.documentElement.setAttribute("data-sidebar-resize-listener", "true");
      window.addEventListener("resize", syncSidebarNavHeight);
    }

    const sidebarLinks = sidebar.querySelectorAll(".item");
    sidebarLinks.forEach((link) => {
      if (!link.hasAttribute("data-sidebar-listener")) {
        link.setAttribute("data-sidebar-listener", "true");
        link.addEventListener("click", () => {
          if (window.innerWidth <= 900) {
            closeSidebar();
          }
        });
      }
    });

    const currentPath = window.location.pathname;
    const exactMatch = Array.from(sidebarLinks).find(
      (link) =>
        link.getAttribute("href") === currentPath ||
        link.getAttribute("href") === `${currentPath}/`,
    );

    sidebarLinks.forEach((link) => link.classList.remove("active"));

    if (exactMatch) {
      exactMatch.classList.add("active");
      exactMatch.scrollIntoView({ block: "nearest" });
    }

    const groups = Array.from(sidebar.querySelectorAll("details.group"));
    const activeGroup = exactMatch?.closest("details.group");
    groups.forEach((g) => {
      (g as HTMLDetailsElement).open = g === activeGroup;
    });

    if (!activeGroup && groups.length > 0) {
      (groups[0] as HTMLDetailsElement).open = true;
    }
  }

  if (!document.documentElement.hasAttribute("data-sidebar-page-load-bound")) {
    document.documentElement.setAttribute(
      "data-sidebar-page-load-bound",
      "true",
    );
    document.addEventListener("astro:page-load", initSidebar);
  }
  initSidebar();
</script>
