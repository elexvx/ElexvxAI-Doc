---
import type { SidebarGroup } from "../lib/docs";

type Props = {
  groups: SidebarGroup[];
  currentPath: string;
};

const { groups, currentPath } = Astro.props;

function getIcon(title: string) {
  const t = title.toLowerCase();
  // Thin, 1.5px stroke icons matching the prototype
  if (t.includes("intro"))
    return `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" class="sidebar-icon" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`;
  if (t.includes("install"))
    return `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" class="sidebar-icon" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>`;
  if (t.includes("config"))
    return `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" class="sidebar-icon" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>`;
  if (t.includes("api") || t.includes("sdk"))
    return `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" class="sidebar-icon" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2H2v10l9.29 9.29c.94.94 2.48.94 3.42 0l6.58-6.58c.94-.94.94-2.48 0-3.42L12 2Z"/><path d="M7 7h.01"/></svg>`;
  if (t.includes("data"))
    return `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" class="sidebar-icon" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><line x1="3" x2="21" y1="9" y2="9"/><line x1="9" x2="9" y1="21" y2="9"/></svg>`;
  if (t.includes("model") || t.includes("neural"))
    return `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" class="sidebar-icon" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" x2="15.42" y1="13.51" y2="17.49"/><line x1="15.41" x2="8.59" y1="6.51" y2="10.49"/></svg>`;
  return `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" class="sidebar-icon" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" x2="8" y1="13" y2="13"/><line x1="16" x2="8" y1="17" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`;
}
---

<aside class="side" transition:persist="sidebar">
  {
    groups.map((g) => (
      <section class="group">
        <div class="groupTitle">{g.title}</div>
        <ul class="list">
          {g.items.map((it) => {
            const active =
              it.href === currentPath || it.href === `${currentPath}/`;
            return (
              <li>
                <a class:list={["item", active && "active"]} href={it.href}>
                  <span class="icon" set:html={getIcon(it.title)} />
                  {it.title}
                </a>
              </li>
            );
          })}
        </ul>
      </section>
    ))
  }

  <div class="helpCard">
    <div class="helpIcon">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><path
          d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"
        ></path></svg
      >
    </div>
    <div class="helpText">
      <strong>Need Help?</strong>
      <span>Join our Discord server</span>
    </div>
  </div>
</aside>

<style>
  .side {
    position: sticky;
    top: 4rem;
    height: calc(100vh - 4rem);
    overflow: auto;
    padding: 1.5rem 1rem 1.5rem 0.5rem;
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
  }

  .group {
    margin-bottom: 1.5rem;
  }

  .groupTitle {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--muted);
    padding: 0.25rem 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .list {
    list-style: none;
    padding: 0;
    margin: 0.5rem 0 0;
  }

  .item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 0.75rem;
    border-radius: 0.5rem;
    color: var(--muted);
    transition: all 0.2s ease;
    font-size: 0.95rem;
    font-weight: 500;
    margin-bottom: 2px;
  }

  .item:hover {
    color: var(--fg);
    background: var(--code-bg);
    text-decoration: none;
  }

  .active {
    background: #eff6ff;
    color: #2563eb;
  }

  /* Dark mode overrides for the active tab */
  :global([data-theme="dark"]) .active {
    background: rgba(37, 99, 235, 0.15);
    color: #60a5fa;
  }

  .active:hover {
    background: #eff6ff;
    color: #2563eb;
  }

  :global([data-theme="dark"]) .active:hover {
    background: rgba(37, 99, 235, 0.15);
    color: #60a5fa;
  }

  .active .sidebar-icon {
    stroke: #2563eb;
  }

  :global([data-theme="dark"]) .active .sidebar-icon {
    stroke: #60a5fa;
  }

  .icon {
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.8;
  }

  .helpCard {
    margin-top: auto;
    padding: 1rem;
    background: var(--code-bg);
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .helpCard:hover {
    border-color: var(--primary);
  }

  .helpIcon {
    color: var(--primary);
    background: var(--bg);
    padding: 0.5rem;
    border-radius: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
  }

  .helpText {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .helpText strong {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--fg);
  }

  .helpText span {
    font-size: 0.75rem;
    color: var(--muted);
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    const sidebarLinks = document.querySelectorAll(".side .item");
    if (!sidebarLinks.length) return;

    // Remove existing active classes
    sidebarLinks.forEach((link) => link.classList.remove("active"));

    const currentPath = window.location.pathname;
    const exactMatch = Array.from(sidebarLinks).find(
      (link) =>
        link.getAttribute("href") === currentPath ||
        link.getAttribute("href") === `${currentPath}/`,
    );

    if (exactMatch) {
      exactMatch.classList.add("active");
      // Ensure exact match is visible in sidebar
      exactMatch.scrollIntoView({ block: "nearest" });
    }
  });
</script>
