---
import type { SidebarGroup } from '../lib/docs';

type Props = {
  groups: SidebarGroup[];
  currentPath: string;
};

const { groups, currentPath } = Astro.props;
---

<aside class="side">
  {groups.map((g) => (
    <section class="group">
      <div class="groupTitle">{g.title}</div>
      <ul class="list">
        {g.items.map((it) => {
          const active = it.href === currentPath || it.href === `${currentPath}/`;
          return (
            <li>
              <a class:list={['item', active && 'active']} href={it.href}>
                {it.title}
              </a>
            </li>
          );
        })}
      </ul>
    </section>
  ))}
</aside>

<style>
  .side {
    position: sticky;
    top: 4rem;
    height: calc(100vh - 4rem);
    overflow: auto;
    padding: 1rem 0.75rem 1.5rem;
    border-right: 1px solid var(--border);
  }

  .group {
    margin-bottom: 1.1rem;
  }

  .groupTitle {
    font-size: 0.85rem;
    color: var(--muted);
    padding: 0.25rem 0.5rem;
    text-transform: capitalize;
  }

  .list {
    list-style: none;
    padding: 0;
    margin: 0.25rem 0 0;
  }

  .item {
    display: block;
    padding: 0.5rem 0.75rem;
    border-radius: 0.375rem;
    color: var(--fg);
    opacity: 0.75;
    border-left: 3px solid transparent;
    transition: all 0.2s ease;
    font-size: 0.9rem;
    margin-bottom: 2px;
  }

  .item:hover {
    opacity: 1;
    background: var(--code-bg);
    text-decoration: none;
  }

  .active {
    opacity: 1;
    background: var(--primary-dim);
    color: var(--primary);
    border-left-color: var(--primary);
    font-weight: 500;
  }
</style>
