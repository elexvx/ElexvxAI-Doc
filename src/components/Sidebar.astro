---
import { type SidebarGroup, getDocUrl } from "../lib/docs";
import SearchBox from "./SearchBox.astro";
import { SITE, type Lang } from "../config/site";
import { t } from "../i18n/ui";
import { getBlogUrl } from "../lib/blog";
import { X } from "@lucide/astro";

type Props = {
  groups: SidebarGroup[];
  currentPath: string;
  lang: Lang;
};

const { groups, currentPath, lang } = Astro.props;
---

<div class="doc-drawer-overlay" id="sidebarOverlay"></div>
<aside class="doc-sidebar" id="sidebar" transition:persist="sidebar">
  <div class="doc-drawer-header">
    <span class="mobileTitle">Menu</span>
    <button class="closeBtn" id="sidebarClose" aria-label="Close menu">
      <X size={20} stroke-width={1.5} />
    </button>
  </div>

  <nav class="mobile-nav">
    <a class="mobile-nav-item" href="/">{t(lang, "home")}</a>
    <a
      class="mobile-nav-item"
      href={getDocUrl({ lang, version: SITE.defaultVersion })}
      >{t(lang, "docs")}</a
    >
    <a class="mobile-nav-item" href={getBlogUrl({ lang })}>{t(lang, "blog")}</a>
  </nav>

  <SearchBox lang={lang} />
  {
    groups.map((g) => (
      <details
        class="group"
        open={g.items.some(
          (it) => it.href === currentPath || it.href === `${currentPath}/`,
        )}
      >
        <summary class="groupTitle">{g.title}</summary>
        <ul class="list">
          {g.items.map((it) => {
            const active =
              it.href === currentPath || it.href === `${currentPath}/`;
            return (
              <li>
                <a class:list={["item", active && "active"]} href={it.href}>
                  <span class="text">{it.title}</span>
                </a>
              </li>
            );
          })}
        </ul>
      </details>
    ))
  }
</aside>

<style>
  .mobile-nav {
    display: none;
  }

  @media (max-width: 900px) {
    .mobile-nav {
      display: flex;
      flex-direction: column;
      padding: 0.4rem 0.35rem 0.85rem;
      gap: 0.15rem;
      border-bottom: 1px solid var(--border);
      margin-bottom: 0.75rem;
    }

    .mobile-nav-item {
      color: var(--muted);
      text-decoration: none;
      font-weight: 500;
      padding: 0.5rem 0.65rem;
      border-radius: 10px;
      font-size: 0.9rem;
      transition: all 0.2s;
    }

    .mobile-nav-item:hover {
      color: var(--fg);
      background: color-mix(in srgb, var(--panel-2), transparent 25%);
    }
  }

  .mobileTitle {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--fg);
  }

  .closeBtn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border: none;
    background: transparent;
    color: var(--muted);
    cursor: pointer;
    border-radius: 10px;
  }

  .closeBtn:hover {
    color: var(--fg);
    background: var(--panel-2);
  }

  .group {
    margin: 0 0 0.2rem;
    border-radius: 10px;
  }

  .groupTitle {
    list-style: none;
    font-size: clamp(0.94rem, 0.92rem + 0.05vw, 0.98rem);
    font-weight: 630;
    color: var(--fg);
    padding: 0.65rem 0.65rem 0.5rem;
    text-transform: none;
    letter-spacing: -0.005em;
    cursor: pointer;
    user-select: none;
  }

  details > summary::-webkit-details-marker {
    display: none;
  }

  details > summary::after {
    content: "";
    float: right;
    width: 7px;
    height: 7px;
    margin-top: 7px;
    margin-right: 0.35rem;
    border-right: 1.4px solid var(--muted-2);
    border-bottom: 1.4px solid var(--muted-2);
    transform: rotate(-45deg);
    opacity: 0.85;
    transition:
      transform 0.16s ease,
      opacity 0.16s ease;
  }

  details[open] > summary::after {
    transform: rotate(45deg);
    opacity: 0.9;
  }

  .list {
    list-style: none;
    padding: 0;
    margin: 0.1rem 0 0.7rem;
  }

  .item {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    min-height: 38px;
    padding: 0.45rem 0.75rem;
    border-radius: 10px;
    color: color-mix(in srgb, var(--fg), transparent 20%);
    transition: all 0.2s ease;
    font-size: 1.03rem;
    font-weight: 500;
    margin-bottom: 0.1rem;
    text-decoration: none;
  }

  .item:hover {
    color: var(--fg);
    background: color-mix(in srgb, var(--panel-2), transparent 18%);
    text-decoration: none;
  }

  .active {
    background: color-mix(in srgb, var(--fg), transparent 92%);
    color: var(--fg);
    font-weight: 560;
  }

  .active:hover {
    background: color-mix(in srgb, var(--fg), transparent 90%);
  }
</style>

<script>
  function initSidebar() {
    const sidebar = document.getElementById("sidebar");
    const overlay = document.getElementById("sidebarOverlay");
    const menuToggle = document.getElementById("sidebarToggle");
    const closeBtn = document.getElementById("sidebarClose");

    if (!sidebar || !overlay) return;

    const openSidebar = () => {
      const currentSidebar = document.getElementById("sidebar");
      const currentOverlay = document.getElementById("sidebarOverlay");
      if (!currentSidebar || !currentOverlay) return;
      currentSidebar.classList.add("open");
      currentOverlay.classList.add("open");
      document.body.style.overflow = "hidden";
    };

    const closeSidebar = () => {
      const currentSidebar = document.getElementById("sidebar");
      const currentOverlay = document.getElementById("sidebarOverlay");
      if (!currentSidebar || !currentOverlay) return;
      currentSidebar.classList.remove("open");
      currentOverlay.classList.remove("open");
      document.body.style.overflow = "";
    };

    if (menuToggle && !menuToggle.hasAttribute("data-sidebar-listener")) {
      menuToggle.setAttribute("data-sidebar-listener", "true");
      menuToggle.addEventListener("click", openSidebar);
    }
    if (closeBtn && !closeBtn.hasAttribute("data-sidebar-listener")) {
      closeBtn.setAttribute("data-sidebar-listener", "true");
      closeBtn.addEventListener("click", closeSidebar);
    }
    if (!overlay.hasAttribute("data-sidebar-listener")) {
      overlay.setAttribute("data-sidebar-listener", "true");
      overlay.addEventListener("click", closeSidebar);
    }

    const sidebarLinks = sidebar.querySelectorAll(".item");
    sidebarLinks.forEach((link) => {
      if (!link.hasAttribute("data-sidebar-listener")) {
        link.setAttribute("data-sidebar-listener", "true");
        link.addEventListener("click", () => {
          if (window.innerWidth <= 900) {
            closeSidebar();
          }
        });
      }
    });

    const currentPath = window.location.pathname;
    const exactMatch = Array.from(sidebarLinks).find(
      (link) =>
        link.getAttribute("href") === currentPath ||
        link.getAttribute("href") === `${currentPath}/`,
    );

    sidebarLinks.forEach((link) => link.classList.remove("active"));

    if (exactMatch) {
      exactMatch.classList.add("active");
      exactMatch.scrollIntoView({ block: "nearest" });
    }

    const groups = Array.from(sidebar.querySelectorAll("details.group"));
    const activeGroup = exactMatch?.closest("details.group");
    groups.forEach((g) => {
      (g as HTMLDetailsElement).open = g === activeGroup;
    });

    if (!activeGroup && groups.length > 0) {
      (groups[0] as HTMLDetailsElement).open = true;
    }
  }

  if (!document.documentElement.hasAttribute("data-sidebar-page-load-bound")) {
    document.documentElement.setAttribute(
      "data-sidebar-page-load-bound",
      "true",
    );
    document.addEventListener("astro:page-load", initSidebar);
  }
  initSidebar();
</script>
