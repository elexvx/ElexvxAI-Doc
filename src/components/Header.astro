---
import { SITE, type Lang } from "../config/site";
import { t } from "../i18n/ui";
import { getDocUrl } from "../lib/docs";
import { getBlogUrl } from "../lib/blog";
import { Sun, Moon, Rss, Menu, ListTree } from "@lucide/astro";

type Props = {
  lang: Lang;
  version?: string;
  slug?: string;
  kind?: "docs" | "blog" | "search";
};

const { lang, version, slug, kind = "docs" } = Astro.props;
const otherLang = lang === "zh" ? "en" : "zh";

const docsVersion = version ?? SITE.defaultVersion;

const currentHref =
  kind === "blog"
    ? getBlogUrl({ lang, slug })
    : kind === "search"
      ? `/${lang}/search/`
      : getDocUrl({ lang, version: docsVersion, slug });

const otherLangHref =
  kind === "blog"
    ? getBlogUrl({ lang: otherLang, slug })
    : kind === "search"
      ? `/${otherLang}/search/`
      : getDocUrl({ lang: otherLang, version: docsVersion, slug });

const brandHref =
  kind === "blog"
    ? getBlogUrl({ lang })
    : kind === "search"
      ? getDocUrl({ lang, version: docsVersion })
      : getDocUrl({ lang, version: docsVersion });
---

<header class="hdr" transition:persist="header">
  <div class="inner container">
    <!-- Logo -->
    <a class="logo" href="/">
      <img src="/logo/favicon.svg" alt="ElexvxAI Logo" class="logo-img" />
    </a>

    <!-- Links -->
    <nav class="nav">
      <div class="nav-item">
        <a class="nav-link" href="/">{t(lang, "home")}</a>
      </div>
      <div class="nav-item">
        <a class="nav-link" href={getDocUrl({ lang, version: docsVersion })}
          >{t(lang, "docs")}</a
        >
      </div>
      <div class="nav-item">
        <a class="nav-link" href={getBlogUrl({ lang })}>{t(lang, "blog")}</a>
      </div>
    </nav>

    <!-- Controls -->
    <div class="controls">
      <button
        class="icon-btn"
        type="button"
        id="themeToggle"
        aria-label={t(lang, "theme")}
      >
        <Sun class="sun" size={20} stroke-width={1.5} />
        <Moon class="moon" size={20} stroke-width={1.5} />
      </button>

      <a class="icon-btn" href="/rss.xml" aria-label="RSS">
        <Rss size={20} stroke-width={1.5} />
      </a>

      <button
        class="icon-btn toc-btn"
        id="tocToggle"
        aria-label="Table of Contents"
      >
        <ListTree size={20} stroke-width={1.5} />
      </button>

      <button
        class="icon-btn menu-btn"
        id="menuToggle"
        aria-label="Toggle menu"
      >
        <Menu size={20} stroke-width={1.5} />
      </button>
    </div>
  </div>
</header>

<script>
  import { t } from "../i18n/ui";

  // The Header is persisted across view transitions, so we need to run initialization logic on every page load
  // to ensure state (like current language/version) correctly reflects the URL.
  document.addEventListener("astro:page-load", () => {
    // Theme toggle Logic
    const btn = document.getElementById("themeToggle");
    if (btn && !btn.hasAttribute("data-theme-listener")) {
      btn.setAttribute("data-theme-listener", "true");
      btn.addEventListener("click", () => {
        const key = "theme";
        const cur = document.documentElement.dataset.theme || "dark";
        const next = cur === "dark" ? "light" : "dark";
        document.documentElement.dataset.theme = next;
        localStorage.setItem(key, next);
      });
    }

    // Toggle context buttons
    const tocBtn = document.getElementById("tocToggle");
    const menuBtn = document.getElementById("menuToggle");
    if (tocBtn) {
      const hasToc = document.querySelector(".toc");
      hasToc
        ? tocBtn.removeAttribute("data-hidden")
        : tocBtn.setAttribute("data-hidden", "true");
    }
    if (menuBtn) {
      const hasSidebar = document.querySelector(".side");
      hasSidebar
        ? menuBtn.removeAttribute("data-hidden")
        : menuBtn.setAttribute("data-hidden", "true");
    }
  });
</script>

<style>
  .hdr {
    position: sticky;
    top: 0;
    z-index: 100;
    height: var(--header-h);
    background: color-mix(in srgb, var(--bg), transparent 20%);
    border-bottom: 1px solid var(--border);
    backdrop-filter: blur(12px);
  }

  .inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
  }

  @media (min-width: 1025px) {
    .inner {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
      gap: 1.5rem;
    }
  }

  .logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    justify-self: start;
  }

  .logo-img {
    height: 32px;
    width: auto;
  }

  .nav {
    display: none;
  }

  @media (min-width: 1025px) {
    .nav {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 2rem;
    }
  }

  .nav-link {
    display: flex;
    align-items: center;
    font-size: 0.875rem;
    padding: 0.375rem 0.75rem;
    border-radius: 0.375rem;
    color: var(--muted);
    text-decoration: none;
    font-weight: 500;
    transition: all 0.2s;
  }

  .nav-link:hover {
    color: var(--fg);
    background-color: var(--panel);
  }

  .controls {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    justify-self: end;
  }

  .icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 0.375rem;
    color: var(--muted);
    background: transparent;
    border: none;
    cursor: pointer;
    transition: all 0.2s;
    padding: 0;
  }

  .icon-btn:hover {
    color: var(--fg);
    background-color: var(--panel);
  }

  .menu-btn,
  .toc-btn {
    display: flex;
  }

  .menu-btn[data-hidden="true"],
  .toc-btn[data-hidden="true"] {
    display: none !important;
  }

  @media (min-width: 1025px) {
    .menu-btn,
    .toc-btn {
      display: none !important;
    }
  }

  /* Theme toggle icons */
  :global([data-theme="dark"]) .sun {
    display: none;
  }
  :global([data-theme="light"]) .moon {
    display: none;
  }
</style>
