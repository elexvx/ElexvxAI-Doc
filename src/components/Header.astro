---
import { SITE, type Lang } from "../config/site";
import { t } from "../i18n/ui";
import { getDocUrl } from "../lib/docs";
import { getBlogUrl } from "../lib/blog";

type Props = {
  lang: Lang;
  version?: string;
  slug?: string;
  kind?: "docs" | "blog" | "search";
};

const { lang, version, slug, kind = "docs" } = Astro.props;
const otherLang = lang === "zh" ? "en" : "zh";

const docsVersion = version ?? SITE.defaultVersion;

const currentHref =
  kind === "blog"
    ? getBlogUrl({ lang, slug })
    : kind === "search"
      ? `/${lang}/search/`
      : getDocUrl({ lang, version: docsVersion, slug });

const otherLangHref =
  kind === "blog"
    ? getBlogUrl({ lang: otherLang, slug })
    : kind === "search"
      ? `/${otherLang}/search/`
      : getDocUrl({ lang: otherLang, version: docsVersion, slug });

const brandHref =
  kind === "blog"
    ? getBlogUrl({ lang })
    : kind === "search"
      ? getDocUrl({ lang, version: docsVersion })
      : getDocUrl({ lang, version: docsVersion });
---

<header class="hdr" transition:persist="header">
  <button class="menuBtn" id="menuToggle" aria-label="Toggle menu">
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <line x1="4" x2="20" y1="12" y2="12"/>
      <line x1="4" x2="20" y1="6" y2="6"/>
      <line x1="4" x2="20" y1="18" y2="18"/>
    </svg>
  </button>
  <div class="brand">
    <a class="logo" href={brandHref}>{SITE.title}</a>
  </div>
  <nav class="nav">
    <a class="navLink" href={getDocUrl({ lang, version: docsVersion })}
      >{t(lang, "docs")}</a
    >
    <a class="navLink" href={getBlogUrl({ lang })}>{t(lang, "blog")}</a>
    <a class="navLink" href={`/${lang}/search/`}>{t(lang, "search")}</a>
  </nav>
  <div class="controls">
    {
      kind === "docs" ? (
        <div class="select">
          <span class="label">{t(lang, "version")}</span>
          <select id="versionSelect" aria-label={t(lang, "version")}>
            {SITE.versions.map((v) => (
              <option value={v} selected={v === docsVersion}>
                {v}
              </option>
            ))}
          </select>
        </div>
      ) : null
    }
    <div class="select">
      <span class="label">{t(lang, "language")}</span>
      <select id="langSelect" aria-label={t(lang, "language")}>
        <option value={lang} selected>
          {lang.toUpperCase()}
        </option>
        <option value={otherLang}>{otherLang.toUpperCase()}</option>
      </select>
    </div>
    <button
      class="btn"
      type="button"
      id="themeToggle"
      aria-label="Toggle theme"
    >
      Theme
    </button>
  </div>
</header>

<script>
  import { navigate } from "astro:transitions/client";

  // The Header is persisted across view transitions, so we need to run initialization logic on every page load
  // to ensure state (like current language/version) correctly reflects the URL.
  document.addEventListener("astro:page-load", () => {
    // Theme toggle Logic
    const btn = document.getElementById("themeToggle");
    if (btn && !btn.hasAttribute("data-theme-listener")) {
      btn.setAttribute("data-theme-listener", "true");
      const syncThemeLabel = () => {
        const cur = document.documentElement.dataset.theme || "dark";
        btn.textContent = cur === "dark" ? "Dark" : "Light";
      };
      syncThemeLabel();
      btn.addEventListener("click", () => {
        const key = "theme";
        const cur = document.documentElement.dataset.theme || "dark";
        const next = cur === "dark" ? "light" : "dark";
        document.documentElement.dataset.theme = next;
        localStorage.setItem(key, next);
        syncThemeLabel();
      });
    }

    const currentPathname = window.location.pathname;
    const matchLang = currentPathname.match(/^\/(en|zh)/);
    const currentLang = matchLang ? matchLang[1] : "en";

    // Update active state in dom for language selector based on current URL path
    const langSelect = document.getElementById(
      "langSelect",
    ) as HTMLSelectElement;
    if (langSelect) {
      if (langSelect.value !== currentLang) {
        langSelect.value = currentLang;
      }

      if (!langSelect.hasAttribute("data-nav-listener")) {
        langSelect.setAttribute("data-nav-listener", "true");
        langSelect.addEventListener("change", (e) => {
          const targetLang = (e.target as HTMLSelectElement).value;
          // Only replace the leading language segment
          const newPathname = currentPathname.replace(
            /^\/(en|zh)/,
            `/${targetLang}`,
          );
          navigate(newPathname);
        });
      }
    }

    // Update active state in dom for version selector based on current URL path
    const versionSelect = document.getElementById(
      "versionSelect",
    ) as HTMLSelectElement;
    if (versionSelect) {
      // Find the version in the URL. Assuming structure like /en/docs/v2/...
      const versionMatch = currentPathname.match(/^\/[a-z]{2}\/docs\/(v\d+)/);
      if (versionMatch) {
        const currentVersion = versionMatch[1];
        if (versionSelect.value !== currentVersion) {
          versionSelect.value = currentVersion;
        }
      }

      if (!versionSelect.hasAttribute("data-nav-listener")) {
        versionSelect.setAttribute("data-nav-listener", "true");
        versionSelect.addEventListener("change", (e) => {
          const targetVersion = (e.target as HTMLSelectElement).value;
          // Identify where the version is right now and swap it out
          // Works for /en/docs/v2/...  or /zh/docs/v2/...
          const newPathname = currentPathname.replace(
            /(\/[a-z]{2}\/docs\/)v\d+/,
            `$1${targetVersion}`,
          );
          navigate(newPathname);
        });
      }
    }
  });
</script>

<style>
  .hdr {
    position: sticky;
    top: 0;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    height: var(--header-h);
    padding: 0 20px;
    background: color-mix(in srgb, var(--bg), transparent 35%);
    border-bottom: 1px solid var(--border-2);
    backdrop-filter: blur(14px);
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    min-width: 12rem;
  }

  .logo {
    font-weight: 700;
    letter-spacing: -0.5px;
    font-size: 1.2rem;
    color: var(--fg);
  }

  .nav {
    display: flex;
    gap: 1rem;
    flex: 1;
  }

  .navLink {
    color: var(--fg);
    opacity: 0.78;
  }

  .navLink:hover {
    opacity: 1;
    text-decoration: none;
  }

  .controls {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .select {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.35rem 0.5rem;
    border: 1px solid var(--border-2);
    border-radius: 0.7rem;
    background: color-mix(in srgb, var(--panel-2), transparent 0%);
    box-shadow: var(--shadow-sm);
  }

  .label {
    font-size: 0.85rem;
    color: var(--muted);
  }

  select {
    appearance: none;
    border: 0;
    background: transparent;
    color: var(--fg);
    font-size: 0.9rem;
    padding-right: 0.75rem;
    cursor: pointer;
  }

  .btn {
    border: 1px solid var(--border-2);
    background: color-mix(in srgb, var(--panel-2), transparent 0%);
    color: var(--fg);
    padding: 0.5rem 0.75rem;
    border-radius: 0.7rem;
    cursor: pointer;
    box-shadow: var(--shadow-sm);
  }

  .menuBtn {
    display: none;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: 1px solid var(--border-2);
    background: color-mix(in srgb, var(--panel-2), transparent 0%);
    color: var(--fg);
    border-radius: 0.5rem;
    cursor: pointer;
    padding: 0;
  }

  @media (max-width: 900px) {
    .nav {
      display: none;
    }
    .menuBtn {
      display: flex;
    }
    .brand {
      min-width: auto;
    }
  }

  @media (max-width: 600px) {
    .hdr {
      padding: 0 12px;
    }
    .select {
      padding: 0.25rem 0.4rem;
    }
    .label {
      display: none;
    }
    select {
      font-size: 0.85rem;
    }
    .btn {
      padding: 0.4rem 0.6rem;
      font-size: 0.85rem;
    }
  }
</style>
