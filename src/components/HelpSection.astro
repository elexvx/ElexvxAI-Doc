---
import { LifeBuoy, Users, Sparkles, Rss } from "@lucide/astro";
---

<div class="help-section">
  <div class="help-container container">
    <a href="#" class="help-card">
      <div class="icon-wrapper">
        <LifeBuoy size={24} stroke-width={1.5} />
      </div>
      <h3>Help center</h3>
      <p>Frequently asked account and billing questions</p>
    </a>

    <a href="#" class="help-card">
      <div class="icon-wrapper">
        <Users size={24} stroke-width={1.5} />
      </div>
      <h3>Developer forum</h3>
      <p>Discuss topics with other developers</p>
    </a>

    <a href="#" class="help-card">
      <div class="icon-wrapper">
        <Sparkles size={24} stroke-width={1.5} />
      </div>
      <h3>OpenAI for startups</h3>
      <p>Resources for ambitious founders building with OpenAI</p>
    </a>

    <a href="#" class="help-card">
      <div class="icon-wrapper">
        <Rss size={24} stroke-width={1.5} />
      </div>
      <h3>Status</h3>
      <p>Check the status of OpenAI services</p>
    </a>
  </div>
</div>

<style>
  .help-section {
    padding: 4rem 1.5rem;
    background-color: var(--bg);
    border-top: 1px solid var(--border);
  }

  .help-container {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }

  .help-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    text-decoration: none;
    color: inherit;
  }

  .icon-wrapper {
    margin-bottom: 1rem;
    color: var(--fg);
  }

  h3 {
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 0.5rem;
    color: var(--fg);
  }

  p {
    font-size: 0.875rem;
    color: var(--muted);
    margin: 0;
    line-height: 1.5;
  }

  @media (max-width: 900px) {
    .help-container {
      grid-template-columns: repeat(2, 1fr);
      gap: 3rem 2rem;
    }
  }

  @media (max-width: 600px) {
    .help-container {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
