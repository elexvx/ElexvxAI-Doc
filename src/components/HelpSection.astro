---
import type { CollectionEntry } from "astro:content";
import { getLucideIcon } from "../lib/lucide-icons";

type HelpItem = CollectionEntry<"landing">["data"]["help"][number];

interface Props {
  data: HelpItem[];
}

const { data: helpItems } = Astro.props;
---

<div class="help-section">
  <div class="help-container container">
    {helpItems.map((item) => {
      const Icon = getLucideIcon(item.icon);
      return (
        <a href={item.href} class="help-card">
          <div class="icon-wrapper">
            <Icon size={24} stroke-width={1.5} />
          </div>
          <h3>{item.title}</h3>
          <p>{item.desc}</p>
        </a>
      );
    })}
  </div>
</div>

<style>
  .help-section {
    padding: 3rem 1.5rem;
    background-color: var(--bg);
    border-top: 1px solid var(--border);
  }

  .help-container {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .help-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    text-decoration: none;
    color: inherit;
    gap: 0.35rem;
  }

  .icon-wrapper {
    margin-bottom: 0.4rem;
    color: var(--fg);
  }

  h3 {
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 0.5rem;
    color: var(--fg);
  }

  p {
    font-size: 0.875rem;
    color: var(--muted);
    margin: 0;
    line-height: 1.5;
  }

  @media (max-width: 900px) {
    .help-section {
      padding: 2.75rem 1rem;
    }

    .help-container {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.25rem;
    }
  }

  @media (max-width: 600px) {
    .help-section {
      padding: 2.5rem 1rem;
    }

    .help-container {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
  }
</style>
