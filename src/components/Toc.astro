---
type Heading = { depth: number; slug: string; text: string };

type Props = {
  headings: Heading[];
  title: string;
};

const { headings, title } = Astro.props;
const items = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

<aside class="toc">
  <div class="tocTitle">{title}</div>
  <ul class="tocList" id="toc-list">
    {
      items.map((h) => (
        <li class:list={["tocItem", h.depth === 3 && "d3"]}>
          <a href={`#${h.slug}`}>{h.text}</a>
        </li>
      ))
    }
  </ul>

  <div class="railLinks">
    <a
      class="railLink"
      href="https://github.com/elexvx/ElexvxAI-Doc"
      target="_blank"
      rel="noopener noreferrer"
      >GitHub</a
    >
    <a
      class="railLink"
      href="https://github.com/elexvx/ElexvxAI-Doc/discussions"
      target="_blank"
      rel="noopener noreferrer"
      >Community</a
    >
  </div>
</aside>

<script>
  function setupToc() {
    const updateToc = () => {
      const headings = Array.from(
        document.querySelectorAll(
          ".article-content h2, .article-content h3, article h2, article h3",
        ),
      ) as HTMLElement[];
      const tocItems = Array.from(document.querySelectorAll(".tocItem"));

      if (headings.length === 0 || tocItems.length === 0) return;

      let current = headings[0];
      for (const h of headings) {
        if (window.scrollY >= h.offsetTop - 120) {
          current = h;
        }
      }

      tocItems.forEach((item) => {
        item.classList.remove("active");
        const href = item.querySelector("a")?.getAttribute("href");
        if (href === `#${current.id}`) {
          item.classList.add("active");
        }
      });
    };

    window.addEventListener("scroll", updateToc, { passive: true });
    setTimeout(updateToc, 100);
  }

  document.addEventListener("astro:page-load", setupToc);
  // Also run on first load if View Transitions aren't taking over initially
  setupToc();
</script>

<style>
  .toc {
    position: sticky;
    top: var(--header-h);
    height: calc(100vh - var(--header-h));
    overflow: auto;
    padding: 1.25rem 0 1.5rem 1rem;
    border-left: 1px solid var(--border-2);
    display: flex;
    flex-direction: column;
  }

  .tocTitle {
    font-size: 0.75rem;
    font-weight: 650;
    color: var(--muted-2);
    padding: 0.25rem 0.25rem 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .tocList {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem;
  }

  .tocItem {
    position: relative;
    padding: 0.25rem 0 0.25rem 1rem;
    border-left: 2px solid transparent;
    transition: all 0.2s ease;
    margin-bottom: 4px;
  }

  .tocItem.active {
    border-left-color: var(--accent);
  }

  .tocItem.active a {
    color: var(--fg);
    font-weight: 550;
  }

  .tocItem.d3 {
    padding-left: 1.5rem;
  }

  .tocItem a {
    color: var(--muted);
    text-decoration: none;
    font-size: 0.85rem;
    transition: color 0.2s ease;
    display: block;
  }

  .tocItem a:hover {
    color: var(--fg);
  }

  .railLinks {
    margin-top: auto;
    display: flex;
    gap: 0.75rem;
    padding: 0.75rem 0.25rem 0;
  }

  .railLink {
    font-size: 0.85rem;
    color: var(--muted);
    padding: 0.25rem 0;
  }

  .railLink:hover {
    color: var(--fg);
  }
</style>
