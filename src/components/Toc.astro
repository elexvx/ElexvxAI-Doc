---
import { Github, MessageSquare, X } from "@lucide/astro";
import IconButton from "./ui/IconButton.astro";

type Heading = { depth: number; slug: string; text: string };

type Props = {
  headings: Heading[];
  title: string;
};

const { headings, title } = Astro.props;
const items = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
const isZh = /[\u4e00-\u9fff]/.test(title);
const resourceGroupTitle = isZh ? "示例 / 资源" : "Examples / Resources";
const dropdownItems = items.filter((h) => h.depth === 2);

function isResourceHeading(text: string): boolean {
  const value = text.trim();
  return /^(示例|资源)$/i.test(value) || /^(example|examples|resource|resources)$/i.test(value);
}

const primaryItems: Heading[] = [];
const resourceItems: Heading[] = [];
let collectResources = false;
for (const heading of items) {
  if (heading.depth === 2) {
    collectResources = isResourceHeading(heading.text);
  }
  if (collectResources) resourceItems.push(heading);
  else primaryItems.push(heading);
}
---

<div class="doc-drawer-overlay" id="tocOverlay"></div>
<aside class="doc-toc" id="tocSidebar">
  <div class="doc-drawer-header">
    <span class="mobileTitle">{title}</span>
    <IconButton id="tocClose" aria-label="Close table of contents" size="sm">
      <X size={20} stroke-width={1.5} />
    </IconButton>
  </div>
  <details class="tocPicker" id="tocPicker">
    <summary>
      <span class="pickerLabel">{title}</span>
      <span class="pickerValue" id="tocPickerValue">{title}</span>
    </summary>
    <div class="tocPickerPanel">
      {
        dropdownItems.map((h) => (
          <button class="tocPickBtn" type="button" data-toc-target={h.slug}>
            {h.text}
          </button>
        ))
      }
    </div>
  </details>

  <div class="tocScroll" id="toc-list">
    <section class="tocGroup">
      <div class="tocGroupTitle">{title}</div>
      <ul class="doc-toc-list">
        {
          primaryItems.map((h) => (
            <li class:list={["tocItem", h.depth === 3 && "d3"]}>
              <a href={`#${h.slug}`}>{h.text}</a>
            </li>
          ))
        }
      </ul>
    </section>

    {
      resourceItems.length > 0 ? (
        <section class="tocGroup">
          <div class="tocGroupTitle">{resourceGroupTitle}</div>
          <ul class="doc-toc-list">
            {resourceItems.map((h) => (
              <li class:list={["tocItem", h.depth === 3 && "d3"]}>
                <a href={`#${h.slug}`}>{h.text}</a>
              </li>
            ))}
          </ul>
        </section>
      ) : null
    }
  </div>

  <div class="railLinks">
    <a
      class="railLink"
      href="https://github.com/elexvx/ElexvxAI-Doc"
      target="_blank"
      rel="noopener noreferrer"
    >
      <Github size={14} stroke-width={1.5} />
      GitHub
    </a>
    <a
      class="railLink"
      href="https://github.com/elexvx/ElexvxAI-Doc/discussions"
      target="_blank"
      rel="noopener noreferrer"
    >
      <MessageSquare size={14} stroke-width={1.5} />
      Community
    </a>
  </div>
</aside>

<script>
  function setupToc() {
    const tocSidebar = document.getElementById("tocSidebar");
    const overlay = document.getElementById("tocOverlay");
    const tocToggle = document.getElementById("tocToggle");
    const closeBtn = document.getElementById("tocClose");

    if (!tocSidebar || !overlay) return;

    const openToc = () => {
      const currentToc = document.getElementById("tocSidebar");
      const currentOverlay = document.getElementById("tocOverlay");
      if (!currentToc || !currentOverlay) return;
      currentToc.classList.add("open");
      currentOverlay.classList.add("open");
      document.body.style.overflow = "hidden";
    };

    const closeToc = () => {
      const currentToc = document.getElementById("tocSidebar");
      const currentOverlay = document.getElementById("tocOverlay");
      if (!currentToc || !currentOverlay) return;
      currentToc.classList.remove("open");
      currentOverlay.classList.remove("open");
      document.body.style.overflow = "";
    };

    if (tocToggle && !tocToggle.hasAttribute("data-toc-listener")) {
      tocToggle.setAttribute("data-toc-listener", "true");
      tocToggle.addEventListener("click", openToc);
    }
    if (closeBtn && !closeBtn.hasAttribute("data-toc-listener")) {
      closeBtn.setAttribute("data-toc-listener", "true");
      closeBtn.addEventListener("click", closeToc);
    }
    if (!overlay.hasAttribute("data-toc-listener")) {
      overlay.setAttribute("data-toc-listener", "true");
      overlay.addEventListener("click", closeToc);
    }

    const picker = tocSidebar.querySelector("#tocPicker") as HTMLDetailsElement | null;
    const pickerValue = tocSidebar.querySelector("#tocPickerValue");
    const pickerButtons = tocSidebar.querySelectorAll(".tocPickBtn");
    const links = tocSidebar.querySelectorAll(".tocItem a");

    const setPickerLabel = (text?: string | null) => {
      if (!(pickerValue instanceof HTMLElement)) return;
      const value = text?.trim();
      if (!value) return;
      pickerValue.textContent = value;
    };

    const setActiveById = (id: string) => {
      const tocItems = Array.from(tocSidebar.querySelectorAll(".tocItem"));
      tocItems.forEach((item) => {
        item.classList.remove("active");
        const href = item.querySelector("a")?.getAttribute("href");
        if (href === `#${id}`) item.classList.add("active");
      });
    };

    pickerButtons.forEach((button) => {
      if (button.hasAttribute("data-toc-listener")) return;
      button.setAttribute("data-toc-listener", "true");
      button.addEventListener("click", () => {
        const targetId = button.getAttribute("data-toc-target");
        if (!targetId) return;
        const target = document.getElementById(targetId);
        if (!target) return;
        setPickerLabel(button.textContent);
        setActiveById(targetId);
        target.scrollIntoView({ behavior: "smooth", block: "start" });
        picker?.removeAttribute("open");
        if (window.innerWidth <= 1024) closeToc();
      });
    });

    links.forEach((link) => {
      if (!link.hasAttribute("data-toc-listener")) {
        link.setAttribute("data-toc-listener", "true");
        link.addEventListener("click", () => {
          const href = link.getAttribute("href") ?? "";
          const sectionId = href.replace(/^#/, "");
          if (sectionId) {
            setPickerLabel(link.textContent);
            setActiveById(sectionId);
          }
          picker?.removeAttribute("open");
          if (window.innerWidth <= 1024) closeToc();
        });
      }
    });

    const headings = Array.from(
      document.querySelectorAll(
        ".article-content h2, .article-content h3, article h2, article h3",
      ),
    ) as HTMLElement[];
    const tocItems = Array.from(tocSidebar.querySelectorAll(".tocItem"));

    const state = window as Window & { __tocObserver?: IntersectionObserver };
    state.__tocObserver?.disconnect();

    if (headings.length === 0 || tocItems.length === 0) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const currentId = entry.target.id;
            setActiveById(currentId);
            const matchedLink = tocSidebar.querySelector(
              `.tocItem a[href="#${currentId}"]`,
            );
            setPickerLabel(matchedLink?.textContent);
          }
        });
      },
      { rootMargin: "-80px 0px -60% 0px" },
    );

    headings.forEach((h) => observer.observe(h));
    state.__tocObserver = observer;
  }

  if (!document.documentElement.hasAttribute("data-toc-page-load-bound")) {
    document.documentElement.setAttribute("data-toc-page-load-bound", "true");
    document.addEventListener("astro:page-load", setupToc);
  }
  setupToc();
</script>

<style>
  .mobileTitle {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--text);
  }

  .doc-drawer-header :global(.ui-ibtn) {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border: none;
    background: transparent;
    color: var(--muted);
    cursor: pointer;
    border-radius: 10px;
  }

  .doc-drawer-header :global(.ui-ibtn:hover) {
    color: var(--text);
    background: color-mix(in srgb, var(--content-bg), var(--rail-bg) 55%);
  }

  .tocPicker {
    margin: 0 0 0.75rem;
    border: 1px solid var(--divider);
    border-radius: 10px;
    background: var(--content-bg);
    overflow: hidden;
  }

  .tocPicker summary {
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.6rem;
    min-height: 40px;
    padding: 0 0.65rem;
    cursor: pointer;
  }

  .tocPicker summary::-webkit-details-marker {
    display: none;
  }

  .tocPicker summary::after {
    content: "";
    width: 7px;
    height: 7px;
    border-right: 1.35px solid var(--muted);
    border-bottom: 1.35px solid var(--muted);
    transform: rotate(45deg);
    margin-left: 0.28rem;
  }

  .tocPicker[open] summary::after {
    transform: rotate(-135deg);
    margin-top: 4px;
  }

  .pickerLabel {
    font-size: 12px;
    color: var(--muted);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-weight: 620;
  }

  .pickerValue {
    max-width: 70%;
    text-align: right;
    font-size: 0.86rem;
    color: var(--text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .tocPickerPanel {
    border-top: 1px solid var(--divider);
    background: color-mix(in srgb, var(--content-bg), var(--rail-bg) 45%);
    padding: 0.32rem;
    display: grid;
    gap: 0.25rem;
  }

  .tocPickBtn {
    appearance: none;
    border: 0;
    background: transparent;
    color: var(--text);
    text-align: left;
    border-radius: 8px;
    padding: 0.45rem 0.5rem;
    font-size: 0.85rem;
    line-height: 1.3;
    cursor: pointer;
  }

  .tocPickBtn:hover {
    background: color-mix(in srgb, var(--content-bg), var(--rail-bg) 70%);
  }

  .tocScroll {
    overflow: auto;
    padding-right: 2px;
    margin-bottom: 0.9rem;
    scrollbar-width: thin;
  }

  .tocGroup {
    margin-bottom: 1rem;
  }

  .tocGroupTitle {
    font-size: 12px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-weight: 620;
    margin-bottom: 0.4rem;
    padding: 0 0.12rem;
  }

  .doc-toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .tocItem {
    padding: 0;
    margin: 0 0 0.1rem;
  }

  .tocItem.active a {
    color: var(--text);
    background: color-mix(in srgb, var(--content-bg), var(--rail-bg) 30%);
    font-weight: 560;
  }

  .tocItem.d3 {
    margin-left: 0.72rem;
  }

  .tocItem a {
    color: color-mix(in srgb, var(--text), transparent 34%);
    text-decoration: none;
    font-size: 0.9rem;
    line-height: 1.35;
    transition: color 0.18s ease;
    display: block;
    border-radius: 8px;
    padding: 0.38rem 0.42rem;
  }

  .tocItem a:hover {
    color: var(--text);
    background: color-mix(in srgb, var(--content-bg), var(--rail-bg) 62%);
  }

  .railLinks {
    margin-top: auto;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    padding: 0.8rem 0 0;
    border-top: 1px solid var(--divider);
  }

  .railLink {
    font-size: 0.86rem;
    color: var(--muted);
    padding: 0.24rem 0.2rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .railLink:hover {
    color: var(--text);
  }

  @media (max-width: 1024px) {
    .tocScroll {
      max-height: calc(100vh - 240px);
    }
  }
</style>
