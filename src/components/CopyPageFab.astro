---
import { Copy, Check, ChevronDown } from '@lucide/astro';
import Button from "./ui/Button.astro";
---

<Button
  variant="secondary"
  size="md"
  id="copyPageFab"
  aria-live="polite"
>
  <span class="icon-idle"><Copy size={16} stroke-width={1.5} /></span>
  <span class="icon-success"><Check size={16} stroke-width={1.5} /></span>
  <span class="text">Copy Page</span>
  <span class="icon-more"><ChevronDown size={14} stroke-width={1.6} /></span>
</Button>

<script>
  async function copyText(text: string) {
    if (navigator.clipboard?.writeText) {
      await navigator.clipboard.writeText(text);
      return;
    }
    const ta = document.createElement("textarea");
    ta.value = text;
    ta.style.position = "fixed";
    ta.style.opacity = "0";
    document.body.appendChild(ta);
    ta.focus();
    ta.select();
    document.execCommand("copy");
    ta.remove();
  }

  function initCopyPageFab() {
    const btn = document.getElementById("copyPageFab");
    if (!(btn instanceof HTMLButtonElement)) return;
    if (btn.hasAttribute("data-copy-listener")) return;
    btn.setAttribute("data-copy-listener", "true");

    const textSpan = btn.querySelector(".text");
    const isZh = document.documentElement.lang.startsWith("zh");
    const labels = isZh
      ? { idle: "复制页", copied: "已复制", failed: "复制失败" }
      : { idle: "Copy Page", copied: "Copied", failed: "Failed" };
    if (textSpan) textSpan.textContent = labels.idle;

    btn.addEventListener("click", async () => {
      const url = window.location.href;
      try {
        await copyText(url);
        if (textSpan) textSpan.textContent = labels.copied;
        btn.setAttribute("data-state", "copied");
        window.setTimeout(() => {
          if (textSpan) textSpan.textContent = labels.idle;
          btn.removeAttribute("data-state");
        }, 1000);
      } catch {
        if (textSpan) textSpan.textContent = labels.failed;
        btn.setAttribute("data-state", "error");
        window.setTimeout(() => {
          if (textSpan) textSpan.textContent = labels.idle;
          btn.removeAttribute("data-state");
        }, 1000);
      }
    });
  }

  if (!document.documentElement.hasAttribute("data-copy-fab-bound")) {
    document.documentElement.setAttribute("data-copy-fab-bound", "true");
    document.addEventListener("astro:page-load", initCopyPageFab);
  }
  initCopyPageFab();
</script>

<style>
  #copyPageFab {
    position: fixed;
    right: 18px;
    bottom: 18px;
    z-index: 30;
    height: 42px;
    padding: 0 11px 0 12px;
    border-radius: 14px;
    border: 1px solid var(--border);
    background: var(--panel);
    color: var(--fg);
    font-size: 0.96rem;
    font-weight: 500;
    cursor: pointer;
    box-shadow: var(--shadow-sm);
    display: flex;
    align-items: center;
    gap: 8px;
    transition: all 0.2s ease;
  }

  .icon-success {
    display: none;
  }

  .icon-more {
    display: flex;
    color: var(--muted-2);
    margin-left: 2px;
  }

  #copyPageFab[data-state="copied"] .icon-idle {
    display: none;
  }

  #copyPageFab[data-state="copied"] .icon-success {
    display: flex;
    color: var(--accent);
  }

  #copyPageFab:hover {
    border-color: var(--border-strong);
    background: var(--panel-2);
    transform: translateY(-1px);
  }

  #copyPageFab[data-state="copied"] {
    border-color: var(--border-strong);
    background: color-mix(in srgb, var(--fg), transparent 95%);
  }

  #copyPageFab[data-state="error"] {
    border-color: var(--danger);
  }
  @media (max-width: 900px) {
    #copyPageFab {
      right: 12px;
      bottom: 12px;
      height: 39px;
      font-size: 0.89rem;
    }
  }
</style>
