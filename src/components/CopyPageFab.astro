<button class="fab" type="button" id="copyPageFab" aria-live="polite">
  Copy Page
</button>

<script>
  async function copyText(text: string) {
    if (navigator.clipboard?.writeText) {
      await navigator.clipboard.writeText(text);
      return;
    }
    const ta = document.createElement("textarea");
    ta.value = text;
    ta.style.position = "fixed";
    ta.style.opacity = "0";
    document.body.appendChild(ta);
    ta.focus();
    ta.select();
    document.execCommand("copy");
    ta.remove();
  }

  document.addEventListener("astro:page-load", () => {
    const btn = document.getElementById("copyPageFab");
    if (!(btn instanceof HTMLButtonElement)) return;
    if (btn.hasAttribute("data-copy-listener")) return;
    btn.setAttribute("data-copy-listener", "true");

    btn.addEventListener("click", async () => {
      const url = window.location.href;
      try {
        await copyText(url);
        btn.textContent = "Copied";
        btn.setAttribute("data-state", "copied");
        window.setTimeout(() => {
          btn.textContent = "Copy Page";
          btn.removeAttribute("data-state");
        }, 1000);
      } catch {
        btn.textContent = "Failed";
        btn.setAttribute("data-state", "error");
        window.setTimeout(() => {
          btn.textContent = "Copy Page";
          btn.removeAttribute("data-state");
        }, 1000);
      }
    });
  });
</script>

<style>
  .fab {
    position: fixed;
    right: 16px;
    bottom: 16px;
    z-index: 30;
    height: 40px;
    padding: 0 14px;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: color-mix(in srgb, var(--panel), transparent 0%);
    color: var(--fg);
    font-size: 0.9rem;
    font-weight: 550;
    cursor: pointer;
    box-shadow: var(--shadow-md);
    backdrop-filter: blur(10px);
  }

  .fab:hover {
    border-color: color-mix(in srgb, var(--accent), transparent 50%);
  }

  .fab[data-state="copied"] {
    border-color: color-mix(in srgb, var(--accent), transparent 35%);
    background: color-mix(in srgb, var(--accent-dim), var(--panel) 70%);
  }

  .fab[data-state="error"] {
    border-color: color-mix(in srgb, var(--danger), transparent 35%);
  }
  @media (max-width: 900px) {
    .fab {
      right: 12px;
      bottom: 12px;
    }
  }
</style>
