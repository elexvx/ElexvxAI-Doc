---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import Toc from '../components/Toc.astro';
import { t } from '../i18n/ui';
import type { Lang } from '../config/site';
import type { SidebarGroup } from '../lib/docs';

type Heading = { depth: number; slug: string; text: string };

type Props = {
  lang: Lang;
  version: string;
  slug?: string;
  title: string;
  description?: string;
  sidebarGroups: SidebarGroup[];
  headings: Heading[];
};

const { lang, version, slug, title, description, sidebarGroups, headings } = Astro.props;
const path = Astro.url.pathname;

let breadcrumbs: { text: string; href?: string }[] = [];

// Try to find the current page in sidebar groups to build breadcrumbs
for (const group of sidebarGroups) {
  const item = group.items.find((i) => i.href === path || i.href === `${path}/` || path === `${i.href}/`);
  if (item) {
    breadcrumbs = [
      { text: group.title }, // Group title usually isn't a link in this structure
      { text: item.title, href: item.href }
    ];
    break;
  }
}
// Fallback if not found in sidebar (e.g. some root page)
if (breadcrumbs.length === 0) {
  breadcrumbs = [{ text: title }];
}
---

<BaseLayout lang={lang} title={`${title} · ${version}`} description={description}>
  <Header lang={lang} version={version} slug={slug} />
  <div class="wrap">
    <Sidebar groups={sidebarGroups} currentPath={path} />
    <main class="content" data-pagefind-body>
      <span class="pf" data-pagefind-filter="Type">Docs</span>
      <span class="pf" data-pagefind-filter="Version">{version}</span>
      <span class="pf" data-pagefind-filter="Language">{lang}</span>
      
      <nav class="breadcrumbs">
        <span class="crumb">Docs</span>
        {breadcrumbs.map((crumb) => (
          <>
            <span class="sep">/</span>
            <span class={`crumb ${crumb.href ? 'active' : ''}`}>{crumb.text}</span>
          </>
        ))}
      </nav>

      <article class="article">
        <h1 data-pagefind-meta="title">{title}</h1>
        {description ? <p class="desc">{description}</p> : null}
        <div class="article-content">
          <slot />
        </div>
      </article>
    </main>
    <Toc headings={headings} title={t(lang, 'onThisPage')} />
  </div>
</BaseLayout>

<style>
  .wrap {
    display: grid;
    grid-template-columns: 280px minmax(0, 1fr) 260px;
    max-width: 1440px;
    margin: 0 auto;
  }

  .content {
    padding: 2rem 3rem 4rem;
    min-height: calc(100vh - 4rem);
  }

  .breadcrumbs {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--muted);
    margin-bottom: 1.5rem;
  }

  .sep {
    opacity: 0.5;
  }

  .crumb.active {
    color: var(--fg);
    font-weight: 500;
  }

  .article {
    max-width: 820px;
  }

  /* Improve typography for the article content */
  .article-content :global(p) {
    margin-bottom: 1.25rem;
    font-size: 1.05rem;
    line-height: 1.75;
    color: color-mix(in srgb, var(--fg), transparent 10%);
  }
  
  .article-content :global(li) {
    margin-bottom: 0.5rem;
  }
  
  .article-content :global(ul), .article-content :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .desc {
    color: var(--muted);
    font-size: 1.2rem;
    line-height: 1.6;
    margin-top: 0.5rem;
    margin-bottom: 2rem;
    border-bottom: 1px solid var(--border);
    padding-bottom: 1.5rem;
  }

  .pf {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
  }


  @media (max-width: 1100px) {
    .wrap {
      grid-template-columns: 280px minmax(0, 1fr);
    }
    :global(.toc) {
      display: none;
    }
  }

  @media (max-width: 900px) {
    .wrap {
      grid-template-columns: 1fr;
    }
    :global(.side) {
      display: none;
    }
  }
</style>
