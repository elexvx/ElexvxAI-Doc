---
import BaseLayout from "./BaseLayout.astro";
import Header from "../components/Header.astro";
import Sidebar from "../components/Sidebar.astro";
import Toc from "../components/Toc.astro";
import CopyPageFab from "../components/CopyPageFab.astro";
import { t } from "../i18n/ui";
import type { Lang } from "../config/site";
import type { SidebarGroup } from "../lib/docs";

type Heading = { depth: number; slug: string; text: string };

type Props = {
  lang: Lang;
  version: string;
  slug?: string;
  title: string;
  description?: string;
  sidebarGroups: SidebarGroup[];
  headings: Heading[];
};

const { lang, version, slug, title, description, sidebarGroups, headings } =
  Astro.props;
const path = Astro.url.pathname;
---

<BaseLayout
  lang={lang}
  title={`${title} · ${version}`}
  description={description}
>
  <Header lang={lang} version={version} slug={slug} />
  <div class="doc-shell">
    <Sidebar
      groups={sidebarGroups}
      currentPath={path}
      lang={lang}
      version={version}
    />
    <main class="doc-main" data-pagefind-body>
      <span class="pf" data-pagefind-filter="Type">Docs</span>
      <span class="pf" data-pagefind-filter="Version">{version}</span>
      <span class="pf" data-pagefind-filter="Language">{lang}</span>

      <div class="doc-main-inner">
        <article class="article doc-card">
          <h1 data-pagefind-meta="title">{title}</h1>
          {description ? <p class="desc">{description}</p> : null}
          <div class="article-content">
            <slot />
          </div>
        </article>
      </div>
    </main>
    <Toc headings={headings} title={t(lang, "onThisPage")} />
  </div>
  <CopyPageFab />
</BaseLayout>

<script>
  const LANGUAGE_LABELS: Record<string, string> = {
    js: "JavaScript",
    jsx: "JSX",
    ts: "TypeScript",
    tsx: "TSX",
    json: "JSON",
    bash: "Bash",
    sh: "Shell",
    shell: "Shell",
    zsh: "Zsh",
    yaml: "YAML",
    yml: "YAML",
    html: "HTML",
    css: "CSS",
    scss: "SCSS",
    md: "Markdown",
    markdown: "Markdown",
    python: "Python",
    py: "Python",
    go: "Go",
    rust: "Rust",
    java: "Java",
    c: "C",
    cpp: "C++",
    csharp: "C#",
    cs: "C#",
    sql: "SQL",
    xml: "XML",
    text: "Text",
    plaintext: "Text",
  };

  const COPY_LABEL = "复制";
  const COPIED_LABEL = "已复制";

  function toLanguageLabel(rawLang: string): string {
    if (!rawLang) return "Text";
    const normalized = rawLang.toLowerCase();
    return LANGUAGE_LABELS[normalized] ?? normalized.toUpperCase();
  }

  function detectLanguage(pre: HTMLPreElement, code: HTMLElement): string {
    const classNames = `${pre.className} ${code.className}`;
    const match = classNames.match(/language-([a-z0-9#+-]+)/i);
    const fromClass = match?.[1] ?? "";
    const fromData = pre.dataset.language ?? code.dataset.language ?? "";
    return toLanguageLabel(fromClass || fromData);
  }

  function wrapCodeLines(code: HTMLElement): void {
    if (code.dataset.linesEnhanced === "true") return;
    const rawHtml = code.innerHTML.replace(/\n$/, "");
    const lines = rawHtml.split("\n");
    code.innerHTML = lines
      .map((line) => `<span class="codeLine">${line.length > 0 ? line : " "}</span>`)
      .join("");
    code.dataset.linesEnhanced = "true";
  }

  async function copyText(text: string): Promise<void> {
    if (navigator.clipboard?.writeText) {
      await navigator.clipboard.writeText(text);
      return;
    }

    const textArea = document.createElement("textarea");
    textArea.value = text;
    textArea.style.position = "fixed";
    textArea.style.opacity = "0";
    document.body.appendChild(textArea);
    textArea.select();
    document.execCommand("copy");
    textArea.remove();
  }

  function enhanceCodeBlocks(articleContent: Element): void {
    const codeBlocks = articleContent.querySelectorAll("pre > code");
    codeBlocks.forEach((codeEl) => {
      if (!(codeEl instanceof HTMLElement)) return;
      const pre = codeEl.parentElement;
      if (!(pre instanceof HTMLPreElement)) return;
      if (pre.closest(".codeCard")) return;

      const legacyWrapper = pre.parentElement;
      if (legacyWrapper?.classList.contains("code-wrapper")) {
        legacyWrapper.replaceWith(pre);
      }

      const parent = pre.parentElement;
      if (!parent) return;

      const language = detectLanguage(pre, codeEl);
      const rawText = codeEl.innerText.replace(/\n$/, "");

      wrapCodeLines(codeEl);

      const card = document.createElement("div");
      card.className = "codeCard";
      card.dataset.lang = language;

      const toolbar = document.createElement("div");
      toolbar.className = "codeToolbar";

      const codeLang = document.createElement("div");
      codeLang.className = "codeLang";
      codeLang.textContent = language;

      const copyBtn = document.createElement("button");
      copyBtn.type = "button";
      copyBtn.className = "codeCopy";
      copyBtn.textContent = COPY_LABEL;
      copyBtn.setAttribute("aria-label", "Copy code");

      copyBtn.addEventListener("click", async () => {
        try {
          await copyText(rawText);
          copyBtn.textContent = COPIED_LABEL;
          copyBtn.setAttribute("data-state", "copied");
          window.setTimeout(() => {
            copyBtn.textContent = COPY_LABEL;
            copyBtn.removeAttribute("data-state");
          }, 1000);
        } catch (error) {
          console.error("Copy failed:", error);
        }
      });

      toolbar.append(codeLang, copyBtn);

      const body = document.createElement("div");
      body.className = "codeBody";

      parent.insertBefore(card, pre);
      card.append(toolbar, body);
      body.appendChild(pre);
    });
  }

  function setupDocFeatures() {
    const articleContent = document.querySelector(".article-content");
    if (!articleContent) return;

    // 1) Setup tabs (idempotent)
    const groups = articleContent.querySelectorAll(".code-group");
    groups.forEach((group) => {
      const tabs = group.querySelectorAll(".code-group__tab");
      const panels = group.querySelectorAll(".code-group__panel");

      tabs.forEach((tab) => {
        if (!tab.hasAttribute("data-tab-listener")) {
          tab.setAttribute("data-tab-listener", "true");
          tab.addEventListener("click", () => {
            tabs.forEach((t) => {
              t.classList.remove("active");
              t.setAttribute("aria-selected", "false");
              t.setAttribute("tabindex", "-1");
            });
            panels.forEach((p) => {
              p.classList.remove("active");
              if (p instanceof HTMLElement) p.style.display = "none";
            });

            tab.classList.add("active");
            tab.setAttribute("aria-selected", "true");
            tab.setAttribute("tabindex", "0");

            const panelId = tab.getAttribute("aria-controls");
            if (panelId) {
              const panel = group.querySelector(`#${panelId}`);
              if (panel) {
                panel.classList.add("active");
                if (panel instanceof HTMLElement) panel.style.display = "block";
              }
            }
          });
        }
      });
    });

    // 2) Setup code cards with toolbar + line numbers + copy (idempotent)
    enhanceCodeBlocks(articleContent);

    // 3) Setup table wrapping (idempotent)
    const tables = articleContent.querySelectorAll("table");
    tables.forEach((table) => {
      const parent = table.parentElement;
      if (parent?.classList.contains("table-wrap")) return;

      const container = document.createElement("div");
      container.className = "table-wrap";
      parent?.insertBefore(container, table);
      container.appendChild(table);
    });
  }

  function initFeatures() {
    const state = window as Window & {
      __docFeatureIdleId?: number;
      __docFeatureTimeoutId?: number;
    };

    if ("cancelIdleCallback" in window && state.__docFeatureIdleId) {
      cancelIdleCallback(state.__docFeatureIdleId);
    }
    if (state.__docFeatureTimeoutId) {
      clearTimeout(state.__docFeatureTimeoutId);
    }

    if ("requestIdleCallback" in window) {
      state.__docFeatureIdleId = requestIdleCallback(setupDocFeatures, {
        timeout: 1200,
      });
    } else {
      state.__docFeatureTimeoutId = window.setTimeout(setupDocFeatures, 16);
    }
  }

  function initWebVitals() {
    const state = window as Window & {
      __docVitalsInit?: boolean;
      __docVitalsData?: Array<Record<string, unknown>>;
    };
    if (state.__docVitalsInit) return;
    state.__docVitalsInit = true;

    const collect = async () => {
      const { onCLS, onFCP, onINP, onLCP, onTTFB } = await import(
        "web-vitals/attribution"
      );
      const report = (metric) => {
        if (!state.__docVitalsData) state.__docVitalsData = [];
        const data = {
          id: metric.id,
          name: metric.name,
          value: metric.value,
          rating: metric.rating,
          path: window.location.pathname,
          timestamp: Date.now(),
        };
        state.__docVitalsData.push(data);
        document.dispatchEvent(new CustomEvent("doc:web-vitals", { detail: data }));
      };

      onCLS(report, { reportAllChanges: false });
      onFCP(report);
      onINP(report);
      onLCP(report);
      onTTFB(report);
    };

    if ("requestIdleCallback" in window) {
      requestIdleCallback(() => {
        void collect();
      }, { timeout: 2000 });
    } else {
      setTimeout(() => {
        void collect();
      }, 500);
    }
  }

  if (!document.documentElement.hasAttribute("data-doc-page-load-bound")) {
    document.documentElement.setAttribute("data-doc-page-load-bound", "true");
    document.addEventListener("astro:page-load", initFeatures);
  }

  initWebVitals();
  initFeatures();
</script>

<style>
  .doc-main-inner {
    margin: 24px auto;
    max-width: 920px;
  }

  .article.doc-card {
    width: 100%;
    max-width: 860px;
    margin: 0 auto;
    background: var(--content-bg);
    border: 1px solid var(--divider);
    border-radius: var(--radius-lg);
    padding: 32px;
  }

  .article h1 {
    font-size: clamp(2rem, 1.6rem + 1vw, 2.6rem);
    font-weight: 620;
    line-height: 1.15;
    margin: 0 0 0.75rem;
    letter-spacing: -0.02em;
  }

  .article-content :global(h2) {
    font-size: clamp(1.5rem, 1.35rem + 0.45vw, 1.85rem);
    font-weight: 620;
    margin: 2.25rem 0 0.75rem;
    line-height: 1.28;
    letter-spacing: -0.015em;
  }

  .article-content :global(h3) {
    font-size: clamp(1.2rem, 1.1rem + 0.28vw, 1.4rem);
    font-weight: 610;
    margin: 1.6rem 0 0.6rem;
    line-height: 1.35;
  }

  .article-content :global(h4) {
    font-size: 1.04rem;
    font-weight: 600;
    margin: 1.2rem 0 0.45rem;
  }

  .article-content :global(p) {
    margin: 0 0 1.05rem;
    font-size: 1rem;
    line-height: 1.65;
    color: var(--text);
  }

  .article-content :global(li) {
    margin-bottom: 0.35rem;
    font-size: 1rem;
    color: var(--text);
  }

  .article-content :global(ul),
  .article-content :global(ol) {
    padding-left: 1.35rem;
    margin-bottom: 1.2rem;
  }

  .desc {
    color: var(--muted);
    font-size: clamp(1.05rem, 0.98rem + 0.2vw, 1.2rem);
    line-height: 1.6;
    margin-top: 0;
    margin-bottom: 1.75rem;
  }

  .article-content :global(.doc-cards) {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.2rem;
    margin: 2rem 0;
  }

  .article-content :global(.doc-card) {
    display: flex;
    flex-direction: column;
    padding: 1.4rem;
    background: var(--content-bg);
    border: 1px solid var(--divider);
    border-radius: 14px;
    text-decoration: none;
    color: inherit;
    transition: background-color 0.18s ease;
  }

  .article-content :global(.doc-card:hover) {
    background: color-mix(in srgb, var(--content-bg), var(--sidebar-bg) 34%);
    text-decoration: none;
  }

  .article-content :global(.doc-card-icon) {
    width: 2.35rem;
    height: 2.35rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: color-mix(in srgb, var(--text), transparent 94%);
    border-radius: 10px;
    color: var(--text);
    margin-bottom: 1rem;
    border: 1px solid var(--divider);
  }

  .article-content :global(.doc-card h3) {
    margin: 0 0 0.5rem 0 !important;
    font-size: 1.1rem !important;
    font-weight: 600 !important;
    border: none !important;
    padding: 0 !important;
  }

  .article-content :global(.doc-card p) {
    margin: 0 0 1.15rem 0 !important;
    font-size: 0.95rem !important;
    color: var(--muted) !important;
    line-height: 1.5 !important;
    flex: 1;
  }

  .article-content :global(.doc-card-link) {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text);
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .article-content :global(.doc-card-link svg) {
    transition: transform 0.2s ease;
  }

  .article-content :global(.doc-card:hover .doc-card-link svg) {
    transform: translateX(4px);
  }

  .article-content :global(.callout) {
    padding: 1rem 1.2rem;
    border-radius: 12px;
    background: color-mix(in srgb, var(--sidebar-bg), #fff 40%);
    border: 1px solid var(--divider);
    margin: 1.4rem 0;
    display: flex;
    gap: 0.7rem;
  }

  .article-content :global(.callout-icon) {
    color: var(--text);
    margin-top: 0.1rem;
  }

  .article-content :global(.callout-content p) {
    margin: 0 !important;
    color: var(--text);
    font-size: 0.95rem !important;
  }

  .article-content :global(.callout-title) {
    font-weight: 600;
    margin-bottom: 0.2rem;
    color: var(--text);
  }

  .article-content :global(div.code-group) {
    margin: 1.5rem 0;
    border: 1px solid var(--divider);
    border-radius: 12px;
    overflow: hidden;
    background: var(--content-bg);
  }

  .article-content :global(div.code-group__tabs) {
    display: flex;
    overflow-x: auto;
    border-bottom: 1px solid var(--divider);
    background: color-mix(in srgb, var(--sidebar-bg), transparent 35%);
  }

  .article-content :global(button.code-group__tab) {
    padding: 0.55rem 1rem;
    font-size: 0.83rem;
    font-family: var(--mono);
    color: var(--muted);
    background: transparent;
    border: none;
    border-bottom: 2px solid transparent;
    cursor: pointer;
    white-space: nowrap;
    transition: all 0.2s;
  }

  .article-content :global(button.code-group__tab:hover) {
    color: var(--text);
    background: color-mix(in srgb, var(--content-bg), var(--sidebar-bg) 55%);
  }

  .article-content :global(button.code-group__tab.active) {
    color: var(--text);
    border-bottom-color: color-mix(in srgb, var(--text), transparent 45%);
  }

  .article-content :global(.code-group__panel .codeCard) {
    margin: 0;
    border-radius: 0;
    border: none;
    border-top: 1px solid var(--divider);
  }

  .article-content > :global(.codeCard) {
    margin: 1.5rem 0;
  }

  .pf {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    .doc-main-inner {
      margin: 18px auto;
    }

    .article.doc-card {
      padding: 24px;
    }

    .article h1 {
      font-size: 1.85rem;
    }
    .desc {
      font-size: 1rem;
    }
  }

  @media (max-width: 600px) {
    .doc-main-inner {
      margin: 12px auto;
    }

    .article.doc-card {
      padding: 18px 16px;
      border-radius: var(--radius-md);
    }

    .article h1 {
      font-size: 1.65rem;
    }
    .article-content :global(h2) {
      font-size: 1.3rem;
    }
    .article-content :global(h3) {
      font-size: 1.12rem;
    }
    .article-content :global(h4) {
      font-size: 1rem;
    }
    .desc {
      font-size: 1rem;
      margin-bottom: 1.5rem;
    }
    .article-content :global(.doc-cards) {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
    .article-content :global(.doc-card) {
      padding: 1.25rem;
    }
  }

</style>
