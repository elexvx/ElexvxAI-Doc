---
import BaseLayout from "./BaseLayout.astro";
import Header from "../components/Header.astro";
import Sidebar from "../components/Sidebar.astro";
import Toc from "../components/Toc.astro";
import CopyPageFab from "../components/CopyPageFab.astro";
import { t } from "../i18n/ui";
import type { Lang } from "../config/site";
import type { SidebarGroup } from "../lib/docs";
import { ChevronRight } from "@lucide/astro";

type Heading = { depth: number; slug: string; text: string };

type Props = {
  lang: Lang;
  version: string;
  slug?: string;
  title: string;
  description?: string;
  sidebarGroups: SidebarGroup[];
  headings: Heading[];
};

const { lang, version, slug, title, description, sidebarGroups, headings } =
  Astro.props;
const path = Astro.url.pathname;

let breadcrumbs: { text: string; href?: string }[] = [];

// Try to find the current page in sidebar groups to build breadcrumbs
for (const group of sidebarGroups) {
  const item = group.items.find(
    (i) => i.href === path || i.href === `${path}/` || path === `${i.href}/`,
  );
  if (item) {
    breadcrumbs = [
      { text: group.title }, // Group title usually isn't a link in this structure
      { text: item.title, href: item.href },
    ];
    break;
  }
}
// Fallback if not found in sidebar (e.g. some root page)
if (breadcrumbs.length === 0) {
  breadcrumbs = [{ text: title }];
}
---

<BaseLayout
  lang={lang}
  title={`${title} · ${version}`}
  description={description}
>
  <Header lang={lang} version={version} slug={slug} />
  <div class="wrap container">
    <Sidebar groups={sidebarGroups} currentPath={path} lang={lang} />
    <main class="content" data-pagefind-body>
      <span class="pf" data-pagefind-filter="Type">Docs</span>
      <span class="pf" data-pagefind-filter="Version">{version}</span>
      <span class="pf" data-pagefind-filter="Language">{lang}</span>

      <nav class="breadcrumbs">
        <span class="crumb">Docs</span>
        {
          breadcrumbs.map((crumb) => (
            <>
              <span class="sep">
                <ChevronRight size={12} />
              </span>
              <span class={`crumb ${crumb.href ? "active" : ""}`}>
                {crumb.text}
              </span>
            </>
          ))
        }
      </nav>

      <article class="article">
        <h1 data-pagefind-meta="title">{title}</h1>
        {description ? <p class="desc">{description}</p> : null}
        <div class="article-content">
          <slot />
        </div>
      </article>
    </main>
    <Toc headings={headings} title={t(lang, "onThisPage")} />
  </div>
  <CopyPageFab />
</BaseLayout>

<script>
  function setupDocFeatures() {
    // 1. Setup Tabs
    const groups = document.querySelectorAll(".code-group");
    groups.forEach((group) => {
      const tabs = group.querySelectorAll(".code-group__tab");
      const panels = group.querySelectorAll(".code-group__panel");

      tabs.forEach((tab) => {
        tab.addEventListener("click", () => {
          tabs.forEach((t) => {
            t.classList.remove("active");
            t.setAttribute("aria-selected", "false");
            t.setAttribute("tabindex", "-1");
          });
          panels.forEach((p) => {
            p.classList.remove("active");
            if (p instanceof HTMLElement) p.style.display = "none";
          });

          tab.classList.add("active");
          tab.setAttribute("aria-selected", "true");
          tab.setAttribute("tabindex", "0");

          const panelId = tab.getAttribute("aria-controls");
          if (panelId) {
            const panel = group.querySelector(`#${panelId}`);
            if (panel) {
              panel.classList.add("active");
              if (panel instanceof HTMLElement) panel.style.display = "block";
            }
          }
        });
      });
    });

    // 2. Setup Copy Buttons
    const blocks = document.querySelectorAll(".article-content pre");
    blocks.forEach((pre) => {
      const parent = pre.parentElement;
      if (!parent || parent.classList.contains("code-wrapper")) return;

      const container = document.createElement("div");
      container.className = "code-wrapper";
      parent.insertBefore(container, pre);
      container.appendChild(pre);

      const btn = document.createElement("button");
      btn.className = "copy-btn";
      btn.setAttribute("aria-label", "Copy code");
      btn.innerHTML = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>`;

      btn.addEventListener("click", async () => {
        const code = pre.querySelector("code");
        if (!code) return;

        let text = code.innerText.trim();
        try {
          await navigator.clipboard.writeText(text);
          btn.classList.add("copied");
          btn.innerHTML = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>`;
          setTimeout(() => {
            btn.classList.remove("copied");
            btn.innerHTML = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>`;
          }, 1200);
        } catch (err) {
          console.error("Copy failed:", err);
        }
      });
      container.appendChild(btn);
    });
  }

  function initFeatures() {
    if ("requestIdleCallback" in window) {
      requestIdleCallback(setupDocFeatures);
    } else {
      setTimeout(setupDocFeatures, 1);
    }
  }

  document.addEventListener("astro:page-load", initFeatures);
  initFeatures();
</script>

<style>
  .wrap {
    display: grid;
    grid-template-columns: var(--sidebar-w) minmax(0, 1fr) var(--rail-w);
  }

  .content {
    padding-block: 2rem 4rem;
    padding-inline: clamp(16px, 2vw, 48px);
    min-height: calc(100vh - var(--header-h));
  }

  .breadcrumbs {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--muted);
    margin-bottom: 1.5rem;
  }

  .sep {
    opacity: 0.4;
    display: flex;
    align-items: center;
  }

  .crumb.active {
    color: var(--fg);
    font-weight: 500;
  }

  .article h1 {
    font-size: 2.75rem;
    font-weight: 780;
    line-height: 1.15;
    margin: 0 0 1rem;
    letter-spacing: -0.03em;
  }

  .article-content :global(h2) {
    font-size: 1.75rem;
    font-weight: 700;
    margin: 2.5rem 0 1rem;
    line-height: 1.3;
    letter-spacing: -0.02em;
  }

  .article-content :global(h3) {
    font-size: 1.35rem;
    font-weight: 650;
    margin: 2rem 0 0.75rem;
    line-height: 1.4;
  }

  .article-content :global(h4) {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 1.5rem 0 0.5rem;
  }

  /* Improve typography for the article content */
  .article-content :global(p) {
    margin: 0 0 1.15rem;
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--muted);
  }

  .article-content :global(li) {
    margin-bottom: 0.5rem;
  }

  .article-content :global(ul),
  .article-content :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .desc {
    color: var(--muted-2);
    font-size: 1.25rem;
    line-height: 1.6;
    margin-top: 0;
    margin-bottom: 2.25rem;
  }

  /* Document Cards for Markdown content */
  .article-content :global(.doc-cards) {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    margin: 2rem 0;
  }

  .article-content :global(.doc-card) {
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    text-decoration: none;
    color: inherit;
    transition: all 0.2s ease;
    box-shadow: var(--shadow-sm);
  }

  .article-content :global(.doc-card:hover) {
    border-color: color-mix(in srgb, var(--accent), transparent 45%);
    box-shadow: var(--shadow-md);
    text-decoration: none;
  }

  .article-content :global(.doc-card-icon) {
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--accent-dim);
    border-radius: 0.5rem;
    color: var(--accent);
    margin-bottom: 1.25rem;
    border: 1px solid var(--border);
  }

  .article-content :global(.doc-card h3) {
    margin: 0 0 0.5rem 0 !important;
    font-size: 1.15rem !important;
    font-weight: 600 !important;
    border: none !important;
    padding: 0 !important;
  }

  .article-content :global(.doc-card p) {
    margin: 0 0 1.25rem 0 !important;
    font-size: 0.95rem !important;
    color: var(--muted) !important;
    line-height: 1.5 !important;
    flex: 1;
  }

  .article-content :global(.doc-card-link) {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--accent);
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .article-content :global(.doc-card-link svg) {
    transition: transform 0.2s ease;
  }

  .article-content :global(.doc-card:hover .doc-card-link svg) {
    transform: translateX(4px);
  }

  /* Callouts / Admonitions */
  .article-content :global(.callout) {
    padding: 1rem 1.25rem;
    border-radius: 0.5rem;
    background: var(--accent-dim);
    border: 1px solid color-mix(in srgb, var(--accent), transparent 80%);
    margin: 1.5rem 0;
    display: flex;
    gap: 0.75rem;
  }

  .article-content :global(.callout-icon) {
    color: var(--accent);
    margin-top: 0.1rem;
  }

  .article-content :global(.callout-content p) {
    margin: 0 !important;
    color: var(--accent);
    font-size: 0.95rem !important;
  }

  .article-content :global(.callout-title) {
    font-weight: 600;
    margin-bottom: 0.25rem;
    color: var(--accent);
  }

  /* Code Group & Copy Styles */
  .article-content :global(div.code-group) {
    margin: 1.5rem 0;
    border: 1px solid var(--border-2);
    border-radius: 0.5rem;
    overflow: hidden;
    background: var(--panel);
  }

  .article-content :global(div.code-group__tabs) {
    display: flex;
    overflow-x: auto;
    border-bottom: 1px solid var(--border-2);
    background: var(--bg);
  }

  .article-content :global(button.code-group__tab) {
    padding: 0.5rem 1rem;
    font-size: 0.85rem;
    font-family: var(--font-mono);
    color: var(--muted);
    background: transparent;
    border: none;
    border-bottom: 2px solid transparent;
    cursor: pointer;
    white-space: nowrap;
    transition: all 0.2s;
  }

  .article-content :global(button.code-group__tab:hover) {
    color: var(--fg);
    background: var(--panel-2);
  }

  .article-content :global(button.code-group__tab.active) {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  .article-content :global(div.code-group__panel pre) {
    margin: 0 !important;
    border: none !important;
    border-radius: 0 !important;
    background: transparent !important;
  }

  .article-content :global(.code-wrapper) {
    position: relative;
    border-radius: 0.5rem;
    overflow: hidden;
  }

  .article-content > :global(.code-wrapper) {
    margin: 1.5rem 0;
    border: 1px solid var(--border-2);
  }

  .article-content :global(.copy-btn) {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    background: var(--panel);
    border: 1px solid var(--border-2);
    border-radius: 0.35rem;
    color: var(--muted);
    cursor: pointer;
    opacity: 0;
    transition: all 0.2s;
    z-index: 10;
  }

  .article-content :global(.code-wrapper:hover .copy-btn),
  .article-content :global(.copy-btn:focus) {
    opacity: 1;
  }

  .article-content :global(.copy-btn:hover) {
    color: var(--fg);
    border-color: var(--border);
    background: var(--panel-2);
  }

  .article-content :global(.copy-btn.copied) {
    color: #10b981;
    border-color: #10b981;
  }

  .pf {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
  }

  @media (max-width: 1024px) {
    .wrap {
      grid-template-columns: var(--sidebar-w) minmax(0, 1fr);
    }
    :global(.toc) {
      display: none;
    }
    .content {
      padding: 1.5rem 2rem 3rem;
    }
  }

  @media (max-width: 768px) {
    .wrap {
      grid-template-columns: 1fr;
      padding: 0 12px;
    }
    .content {
      padding: 1.5rem 0 3rem;
    }
    .article h1 {
      font-size: 2rem;
    }
    .desc {
      font-size: 1.1rem;
    }
  }

  @media (max-width: 600px) {
    .wrap {
      padding: 0 8px;
    }
    .content {
      padding: 1rem 0 2rem;
    }
    .article h1 {
      font-size: 1.75rem;
    }
    .article-content :global(h2) {
      font-size: 1.4rem;
    }
    .article-content :global(h3) {
      font-size: 1.15rem;
    }
    .article-content :global(h4) {
      font-size: 1rem;
    }
    .breadcrumbs {
      font-size: 0.8rem;
      margin-bottom: 1rem;
    }
    .desc {
      font-size: 1rem;
      margin-bottom: 1.5rem;
    }
    .article-content :global(.doc-cards) {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
    .article-content :global(.doc-card) {
      padding: 1.25rem;
    }
  }
</style>
