---
import BaseLayout from "./BaseLayout.astro";
import Header from "../components/Header.astro";
import Sidebar from "../components/Sidebar.astro";
import Toc from "../components/Toc.astro";
import CopyPageFab from "../components/CopyPageFab.astro";
import { t } from "../i18n/ui";
import type { Lang } from "../config/site";
import type { SidebarGroup } from "../lib/docs";

type Heading = { depth: number; slug: string; text: string };

type Props = {
  lang: Lang;
  version: string;
  slug?: string;
  title: string;
  description?: string;
  sidebarGroups: SidebarGroup[];
  headings: Heading[];
};

const { lang, version, slug, title, description, sidebarGroups, headings } =
  Astro.props;
const path = Astro.url.pathname;
---

<BaseLayout
  lang={lang}
  title={`${title} · ${version}`}
  description={description}
>
  <Header lang={lang} version={version} slug={slug} />
  <div class="doc-shell">
    <Sidebar groups={sidebarGroups} currentPath={path} lang={lang} />
    <main class="doc-main" data-pagefind-body>
      <span class="pf" data-pagefind-filter="Type">Docs</span>
      <span class="pf" data-pagefind-filter="Version">{version}</span>
      <span class="pf" data-pagefind-filter="Language">{lang}</span>

      <article class="article">
        <h1 data-pagefind-meta="title">{title}</h1>
        {description ? <p class="desc">{description}</p> : null}
        <div class="article-content">
          <slot />
        </div>
      </article>
    </main>
    <Toc headings={headings} title={t(lang, "onThisPage")} />
  </div>
  <CopyPageFab />
</BaseLayout>

<script>
  function setupDocFeatures() {
    const articleContent = document.querySelector(".article-content");
    if (!articleContent) return;

    // 1) Setup tabs (idempotent)
    const groups = articleContent.querySelectorAll(".code-group");
    groups.forEach((group) => {
      const tabs = group.querySelectorAll(".code-group__tab");
      const panels = group.querySelectorAll(".code-group__panel");

      tabs.forEach((tab) => {
        if (!tab.hasAttribute("data-tab-listener")) {
          tab.setAttribute("data-tab-listener", "true");
          tab.addEventListener("click", () => {
            tabs.forEach((t) => {
              t.classList.remove("active");
              t.setAttribute("aria-selected", "false");
              t.setAttribute("tabindex", "-1");
            });
            panels.forEach((p) => {
              p.classList.remove("active");
              if (p instanceof HTMLElement) p.style.display = "none";
            });

            tab.classList.add("active");
            tab.setAttribute("aria-selected", "true");
            tab.setAttribute("tabindex", "0");

            const panelId = tab.getAttribute("aria-controls");
            if (panelId) {
              const panel = group.querySelector(`#${panelId}`);
              if (panel) {
                panel.classList.add("active");
                if (panel instanceof HTMLElement) panel.style.display = "block";
              }
            }
          });
        }
      });
    });

    // 2) Setup copy buttons (idempotent)
    const blocks = articleContent.querySelectorAll("pre");
    blocks.forEach((pre) => {
      const parent = pre.parentElement;
      if (!parent || parent.classList.contains("code-wrapper")) return;

      const container = document.createElement("div");
      container.className = "code-wrapper";
      parent.insertBefore(container, pre);
      container.appendChild(pre);

      const btn = document.createElement("button");
      btn.className = "copy-btn";
      btn.setAttribute("aria-label", "Copy code");
      btn.innerHTML = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>`;

      btn.addEventListener("click", async () => {
        const code = pre.querySelector("code");
        if (!code) return;

        let text = code.innerText.trim();
        try {
          await navigator.clipboard.writeText(text);
          btn.classList.add("copied");
          btn.innerHTML = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>`;
          setTimeout(() => {
            btn.classList.remove("copied");
            btn.innerHTML = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>`;
          }, 1200);
        } catch (err) {
          console.error("Copy failed:", err);
        }
      });
      container.appendChild(btn);
    });

    // 3) Setup table wrapping (idempotent)
    const tables = articleContent.querySelectorAll("table");
    tables.forEach((table) => {
      const parent = table.parentElement;
      if (parent?.classList.contains("table-wrap")) return;

      const container = document.createElement("div");
      container.className = "table-wrap";
      parent?.insertBefore(container, table);
      container.appendChild(table);
    });
  }

  function initFeatures() {
    const state = window as Window & {
      __docFeatureIdleId?: number;
      __docFeatureTimeoutId?: number;
    };

    if ("cancelIdleCallback" in window && state.__docFeatureIdleId) {
      cancelIdleCallback(state.__docFeatureIdleId);
    }
    if (state.__docFeatureTimeoutId) {
      clearTimeout(state.__docFeatureTimeoutId);
    }

    if ("requestIdleCallback" in window) {
      state.__docFeatureIdleId = requestIdleCallback(setupDocFeatures, {
        timeout: 1200,
      });
    } else {
      state.__docFeatureTimeoutId = window.setTimeout(setupDocFeatures, 16);
    }
  }

  function initWebVitals() {
    const state = window as Window & {
      __docVitalsInit?: boolean;
      __docVitalsData?: Array<Record<string, unknown>>;
    };
    if (state.__docVitalsInit) return;
    state.__docVitalsInit = true;

    const collect = async () => {
      const { onCLS, onFCP, onINP, onLCP, onTTFB } = await import(
        "web-vitals/attribution"
      );
      const report = (metric) => {
        if (!state.__docVitalsData) state.__docVitalsData = [];
        const data = {
          id: metric.id,
          name: metric.name,
          value: metric.value,
          rating: metric.rating,
          path: window.location.pathname,
          timestamp: Date.now(),
        };
        state.__docVitalsData.push(data);
        document.dispatchEvent(new CustomEvent("doc:web-vitals", { detail: data }));
      };

      onCLS(report, { reportAllChanges: false });
      onFCP(report);
      onINP(report);
      onLCP(report);
      onTTFB(report);
    };

    if ("requestIdleCallback" in window) {
      requestIdleCallback(() => {
        void collect();
      }, { timeout: 2000 });
    } else {
      setTimeout(() => {
        void collect();
      }, 500);
    }
  }

  if (!document.documentElement.hasAttribute("data-doc-page-load-bound")) {
    document.documentElement.setAttribute("data-doc-page-load-bound", "true");
    document.addEventListener("astro:page-load", initFeatures);
  }

  initWebVitals();
  initFeatures();
</script>

<style>
  .article h1 {
    font-size: clamp(2.6rem, 2rem + 1.65vw, 4.05rem);
    font-weight: 620;
    line-height: 1.08;
    margin: 0 0 0.8rem;
    letter-spacing: -0.03em;
  }

  .article-content :global(h2) {
    font-size: clamp(1.85rem, 1.55rem + 0.7vw, 2.65rem);
    font-weight: 630;
    margin: 2.9rem 0 0.9rem;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  .article-content :global(h3) {
    font-size: clamp(1.35rem, 1.2rem + 0.35vw, 1.8rem);
    font-weight: 610;
    margin: 2rem 0 0.75rem;
    line-height: 1.3;
  }

  .article-content :global(h4) {
    font-size: 1.08rem;
    font-weight: 600;
    margin: 1.5rem 0 0.5rem;
  }

  .article-content :global(p) {
    margin: 0 0 1.15rem;
    font-size: clamp(1.02rem, 0.98rem + 0.08vw, 1.12rem);
    line-height: 1.6;
    color: color-mix(in srgb, var(--fg), transparent 13%);
  }

  .article-content :global(li) {
    margin-bottom: 0.38rem;
    font-size: clamp(1.01rem, 0.96rem + 0.08vw, 1.09rem);
    color: color-mix(in srgb, var(--fg), transparent 13%);
  }

  .article-content :global(ul),
  .article-content :global(ol) {
    padding-left: 1.35rem;
    margin-bottom: 1.25rem;
  }

  .desc {
    color: var(--muted);
    font-size: clamp(1.32rem, 1.2rem + 0.35vw, 1.7rem);
    line-height: 1.36;
    margin-top: 0;
    margin-bottom: 2.2rem;
    letter-spacing: -0.01em;
  }

  .article-content :global(.doc-cards) {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    margin: 2rem 0;
  }

  .article-content :global(.doc-card) {
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 14px;
    text-decoration: none;
    color: inherit;
    transition: all 0.2s ease;
  }

  .article-content :global(.doc-card:hover) {
    border-color: var(--border-strong);
    background: color-mix(in srgb, var(--panel), var(--fg) 1.8%);
    text-decoration: none;
  }

  .article-content :global(.doc-card-icon) {
    width: 2.35rem;
    height: 2.35rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: color-mix(in srgb, var(--fg), transparent 94%);
    border-radius: 10px;
    color: var(--fg);
    margin-bottom: 1rem;
    border: 1px solid var(--border);
  }

  .article-content :global(.doc-card h3) {
    margin: 0 0 0.5rem 0 !important;
    font-size: 1.15rem !important;
    font-weight: 600 !important;
    border: none !important;
    padding: 0 !important;
  }

  .article-content :global(.doc-card p) {
    margin: 0 0 1.25rem 0 !important;
    font-size: 0.95rem !important;
    color: var(--muted) !important;
    line-height: 1.5 !important;
    flex: 1;
  }

  .article-content :global(.doc-card-link) {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--fg);
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .article-content :global(.doc-card-link svg) {
    transition: transform 0.2s ease;
  }

  .article-content :global(.doc-card:hover .doc-card-link svg) {
    transform: translateX(4px);
  }

  .article-content :global(.callout) {
    padding: 1rem 1.25rem;
    border-radius: 12px;
    background: color-mix(in srgb, var(--fg), transparent 94%);
    border: 1px solid var(--border);
    margin: 1.5rem 0;
    display: flex;
    gap: 0.75rem;
  }

  .article-content :global(.callout-icon) {
    color: var(--fg);
    margin-top: 0.1rem;
  }

  .article-content :global(.callout-content p) {
    margin: 0 !important;
    color: var(--fg);
    font-size: 0.95rem !important;
  }

  .article-content :global(.callout-title) {
    font-weight: 600;
    margin-bottom: 0.25rem;
    color: var(--fg);
  }

  .article-content :global(div.code-group) {
    margin: 1.5rem 0;
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    background: var(--panel);
  }

  .article-content :global(div.code-group__tabs) {
    display: flex;
    overflow-x: auto;
    border-bottom: 1px solid var(--border-2);
    background: var(--bg);
  }

  .article-content :global(button.code-group__tab) {
    padding: 0.5rem 1rem;
    font-size: 0.85rem;
    font-family: var(--font-mono);
    color: var(--muted);
    background: transparent;
    border: none;
    border-bottom: 2px solid transparent;
    cursor: pointer;
    white-space: nowrap;
    transition: all 0.2s;
  }

  .article-content :global(button.code-group__tab:hover) {
    color: var(--fg);
    background: var(--panel-2);
  }

  .article-content :global(button.code-group__tab.active) {
    color: var(--fg);
    border-bottom-color: color-mix(in srgb, var(--fg), transparent 25%);
  }

  .article-content :global(div.code-group__panel pre) {
    margin: 0 !important;
    border: none !important;
    border-radius: 0 !important;
    background: transparent !important;
  }

  .article-content :global(.code-wrapper) {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
  }

  .article-content > :global(.code-wrapper) {
    margin: 1.5rem 0;
    border: 1px solid var(--border);
  }

  .article-content :global(.copy-btn) {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--muted);
    cursor: pointer;
    opacity: 0;
    transition: all 0.2s;
    z-index: 10;
  }

  .article-content :global(.code-wrapper:hover .copy-btn),
  .article-content :global(.copy-btn:focus) {
    opacity: 1;
  }

  .article-content :global(.copy-btn:hover) {
    color: var(--fg);
    border-color: var(--border-strong);
    background: var(--panel-2);
  }

  .article-content :global(.copy-btn.copied) {
    color: #10b981;
    border-color: #10b981;
  }

  .pf {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    .article h1 {
      font-size: 2rem;
    }
    .desc {
      font-size: 1.1rem;
    }
  }

  @media (max-width: 600px) {
    .article h1 {
      font-size: 1.75rem;
    }
    .article-content :global(h2) {
      font-size: 1.4rem;
    }
    .article-content :global(h3) {
      font-size: 1.15rem;
    }
    .article-content :global(h4) {
      font-size: 1rem;
    }
    .desc {
      font-size: 1rem;
      margin-bottom: 1.5rem;
    }
    .article-content :global(.doc-cards) {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
    .article-content :global(.doc-card) {
      padding: 1.25rem;
    }
  }

</style>
