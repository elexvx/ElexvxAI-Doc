---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import { SITE } from "../../../config/site";
import { t } from "../../../i18n/ui";
import {
  getBlogUrl,
  isSupportedLang,
  parseBlogId,
  sortBlog,
} from "../../../lib/blog";
import { ArrowRight } from "@lucide/astro";
import Footer from "../../../components/landing/Footer.astro";

export function getStaticPaths() {
  return SITE.langs.map((lang) => ({ params: { lang } }));
}

const langParam = Astro.params.lang ?? SITE.defaultLang;
if (!isSupportedLang(langParam))
  throw new Error(`Unsupported lang: ${langParam}`);
const lang = langParam;

const allEntries = (await getCollection("blog"))
  .filter((e) => parseBlogId(e.id).lang === lang && !e.data.draft)
  .sort(sortBlog);

const featuredPost = allEntries.length > 0 ? allEntries[0] : null;
const remainingPosts = allEntries.length > 0 ? allEntries.slice(1) : [];

// Helper to format date
const formatDate = (date: Date) => {
  return date.toLocaleDateString("en-GB", {
    day: "numeric",
    month: "short",
    year: "numeric",
  });
};
---

<BaseLayout lang={lang} title={`${t(lang, "blog")} · ${SITE.title}`}>
  <Header lang={lang} kind="blog" />
  <main class="wrap container">
    {
      featuredPost && (
        <section class="featured-section">
          <div class="featured-content">
            <span class="featured-label">Featured</span>
            <h1 class="featured-title">
              <a
                href={getBlogUrl({
                  lang,
                  slug: parseBlogId(featuredPost.id).slug,
                })}
              >
                {featuredPost.data.title}
              </a>
            </h1>
            <div class="featured-meta">
              <span class="meta-date">
                {formatDate(featuredPost.data.pubDate)}
              </span>
              <span class="meta-cat">
                {featuredPost.data.category || "Product"}
              </span>
            </div>
            <a
              href={getBlogUrl({
                lang,
                slug: parseBlogId(featuredPost.id).slug,
              })}
              class="read-btn"
            >
              Read blog
            </a>
          </div>
          <div class="featured-media">
            {featuredPost.data.image && (
              <img
                src={featuredPost.data.image}
                alt={featuredPost.data.title}
                class="featured-img"
              />
            )}
          </div>
        </section>
      )
    }

    <div class="filter-section">
      <div class="filter-tabs" id="blog-filters">
        <button class="filter-btn active" data-filter="all">All</button>
        <button class="filter-btn" data-filter="Product">Product</button>
        <button class="filter-btn" data-filter="Engineering">Engineering</button
        >
        <button class="filter-btn" data-filter="Research">Research</button>
      </div>
    </div>

    <div class="list" id="blog-list">
      {
        remainingPosts.map((e) => {
          const p = parseBlogId(e.id);
          const href = getBlogUrl({ lang, slug: p.slug });
          const cat = e.data.category || "Product";
          return (
            <div class="card blog-card-item" data-category={cat}>
              <div class="card-body">
                <h2 class="card-title">
                  <a href={href}>{e.data.title}</a>
                </h2>
                <div class="card-meta">
                  <span class="meta-date">{formatDate(e.data.pubDate)}</span>
                  <span class="meta-cat">{cat}</span>
                </div>
                <a href={href} class="read-btn sm">
                  Read blog
                </a>
              </div>
              {e.data.image && (
                <div class="card-img-wrapper">
                  <img src={e.data.image} alt={e.data.title} class="card-img" />
                </div>
              )}
            </div>
          );
        })
      }
    </div>
  </main>
  <Footer />
</BaseLayout>

<script>
  document.addEventListener("astro:page-load", () => {
    const filters = document.querySelectorAll(".filter-btn");
    const cards = document.querySelectorAll(".blog-card-item");

    filters.forEach((btn) => {
      btn.addEventListener("click", () => {
        // Update active state
        filters.forEach((f) => f.classList.remove("active"));
        btn.classList.add("active");

        const filterValue = btn.getAttribute("data-filter");

        cards.forEach((card) => {
          if (filterValue === "all") {
            (card as HTMLElement).style.display = "flex";
          } else {
            const cat = card.getAttribute("data-category");
            if (cat && cat.toLowerCase() === filterValue!.toLowerCase()) {
              (card as HTMLElement).style.display = "flex";
            } else {
              (card as HTMLElement).style.display = "none";
            }
          }
        });
      });
    });
  });
</script>

<style>
  .wrap {
    padding: 2rem 1.5rem 6rem;
    font-family: "Inter", sans-serif; /* Ensure a clean font */
  }

  /* Featured Section */
  .featured-section {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 4rem;
    margin-bottom: 6rem;
    padding-top: 2rem;
  }

  .featured-content {
    flex: 1;
    max-width: 500px;
  }

  .featured-label {
    display: block;
    font-size: 1rem;
    font-weight: 500;
    color: var(--fg);
    margin-bottom: 1rem;
  }

  .featured-title {
    font-size: 3.5rem;
    font-weight: 500; /* Lighter weight as per design */
    line-height: 1.1;
    color: var(--fg);
    margin: 0 0 1.5rem;
    letter-spacing: -0.03em;
  }

  .featured-title a {
    text-decoration: none;
    color: inherit;
    transition: color 0.2s;
  }

  .featured-title a:hover {
    color: var(--primary, #3b82f6);
  }

  .featured-meta {
    display: flex;
    gap: 1rem;
    color: var(--muted);
    font-size: 0.9rem;
    margin-bottom: 2rem;
    font-weight: 500;
  }

  .featured-media {
    flex: 1.2;
    border-radius: 1rem;
    overflow: hidden;
    background: #000; /* Fallback */
    aspect-ratio: 16 / 9;
  }

  .featured-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Read Button */
  .read-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.5rem;
    background: #f3f4f6; /* Light gray background */
    color: #1f2937;
    border-radius: 999px;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.2s ease;
    font-size: 0.95rem;
  }

  html[data-theme="dark"] .read-btn {
    background: #1f2937;
    color: #f3f4f6;
  }

  .read-btn:hover {
    background: #e5e7eb;
  }

  html[data-theme="dark"] .read-btn:hover {
    background: #374151;
  }

  .read-btn.sm {
    padding: 0.5rem 1.25rem;
    font-size: 0.875rem;
  }

  /* Filters */
  .filter-section {
    margin-bottom: 3rem;
    border-bottom: 1px solid var(--border);
    padding-bottom: 0;
  }

  .filter-tabs {
    display: flex;
    gap: 2rem;
  }

  .filter-btn {
    background: transparent;
    border: none;
    padding: 0.75rem 0;
    color: var(--muted);
    font-size: 1rem;
    font-weight: 500;
    cursor: pointer;
    position: relative;
    transition: color 0.2s;
  }

  .filter-btn:hover {
    color: var(--fg);
  }

  .filter-btn.active {
    color: var(--primary, #3b82f6);
  }

  .filter-btn.active::after {
    content: "";
    position: absolute;
    bottom: -1px; /* Align with border-bottom */
    left: 0;
    width: 100%;
    height: 2px;
    background: var(--primary, #3b82f6);
  }

  /* List Grid */
  .list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem; /* Reduced gap */
    row-gap: 4rem;
  }

  /* Horizontal Card Styles */
  .card {
    display: flex;
    justify-content: space-between;
    gap: 1.5rem;
    text-decoration: none;
    color: inherit;
    align-items: flex-start;
  }

  .card-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding-top: 0.5rem; /* Align visually with image top */
  }

  .card-title {
    font-size: 1.5rem;
    font-weight: 500;
    line-height: 1.3;
    color: var(--fg);
    margin: 0 0 0.75rem;
    letter-spacing: -0.02em;
  }

  .card-title a {
    text-decoration: none;
    color: inherit;
    transition: color 0.2s;
  }

  .card-title a:hover {
    color: var(--primary, #3b82f6);
  }

  .card-meta {
    display: flex;
    gap: 0.75rem;
    color: var(--muted);
    font-size: 0.875rem;
    margin-bottom: 1.5rem;
    font-weight: 500;
  }

  .card-img-wrapper {
    width: 200px; /* Fixed width for image */
    height: 200px;
    flex-shrink: 0;
    border-radius: 1rem;
    overflow: hidden;
    background: #f1f5f9;
  }

  .card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .card:hover .card-img {
    transform: scale(1.05);
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .featured-section {
      flex-direction: column;
      gap: 2rem;
      margin-bottom: 4rem;
    }

    .featured-content {
      max-width: 100%;
    }

    .list {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .featured-title {
      font-size: 2.5rem;
    }

    .card {
      flex-direction: column-reverse; /* Image on top for mobile */
    }

    .card-img-wrapper {
      width: 100%;
      height: auto;
      aspect-ratio: 16/9;
    }
  }
</style>
