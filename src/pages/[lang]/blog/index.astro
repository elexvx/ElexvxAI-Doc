---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import { SITE } from '../../../config/site';
import { t } from '../../../i18n/ui';
import { getBlogUrl, isSupportedLang, parseBlogId, sortBlog } from '../../../lib/blog';

export function getStaticPaths() {
  return SITE.langs.map((lang) => ({ params: { lang } }));
}

const langParam = Astro.params.lang ?? SITE.defaultLang;
if (!isSupportedLang(langParam)) throw new Error(`Unsupported lang: ${langParam}`);
const lang = langParam;

const entries = (await getCollection('blog'))
  .filter((e) => parseBlogId(e.id).lang === lang && !e.data.draft)
  .sort(sortBlog);
---

<BaseLayout lang={lang} title={`${t(lang, 'blog')} · ${SITE.title}`}>
  <Header lang={lang} kind="blog" />
  <main class="wrap">
    <div class="head">
      <h1 class="title">{t(lang, 'blog')}</h1>
      <p class="sub">{lang === 'zh' ? '独立于文档的文章列表。' : 'Posts separate from docs.'}</p>
    </div>

    <div class="list">
      {entries.map((e) => {
        const p = parseBlogId(e.id);
        const href = getBlogUrl({ lang, slug: p.slug });
        return (
          <a class="card" href={href}>
            <div class="meta">
              <div class="name">{e.data.title}</div>
              <time class="date" datetime={e.data.pubDate.toISOString()}>
                {e.data.pubDate.toISOString().slice(0, 10)}
              </time>
            </div>
            {e.data.description ? <div class="desc">{e.data.description}</div> : null}
            {e.data.tags?.length ? (
              <div class="tags">
                {e.data.tags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            ) : null}
          </a>
        );
      })}
    </div>
  </main>
</BaseLayout>

<style>
  .wrap {
    max-width: 1100px;
    margin: 0 auto;
    padding: 2rem 1rem 4rem;
  }

  .head {
    margin-bottom: 1.25rem;
  }

  .title {
    margin: 0;
  }

  .sub {
    margin: 0.35rem 0 0;
    color: var(--muted);
  }

  .list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .card {
    display: block;
    padding: 1rem 1rem 0.95rem;
    border: 1px solid var(--border);
    border-radius: 1rem;
    background: color-mix(in srgb, var(--card), transparent 8%);
    box-shadow: 0 20px 60px var(--shadow);
    text-decoration: none;
    color: var(--fg);
  }

  .card:hover {
    filter: brightness(1.05);
  }

  .meta {
    display: flex;
    justify-content: space-between;
    gap: 0.75rem;
    align-items: baseline;
  }

  .name {
    font-weight: 650;
    letter-spacing: 0.2px;
  }

  .date {
    color: var(--muted);
    font-size: 0.95rem;
    white-space: nowrap;
  }

  .desc {
    margin-top: 0.5rem;
    color: var(--muted);
    line-height: 1.6;
  }

  .tags {
    margin-top: 0.75rem;
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .tag {
    padding: 0.15rem 0.45rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: color-mix(in srgb, var(--card), transparent 10%);
    color: var(--muted);
  }

  @media (max-width: 900px) {
    .list {
      grid-template-columns: 1fr;
    }
  }
</style>
