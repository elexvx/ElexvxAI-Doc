---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import { SITE } from "../../../config/site";
import { t } from "../../../i18n/ui";
import {
  getBlogUrl,
  isSupportedLang,
  parseBlogId,
  sortBlog,
} from "../../../lib/blog";
import { ArrowRight } from "@lucide/astro";
import Footer from "../../../components/landing/Footer.astro";

export function getStaticPaths() {
  return SITE.langs.map((lang) => ({ params: { lang } }));
}

const langParam = Astro.params.lang ?? SITE.defaultLang;
if (!isSupportedLang(langParam))
  throw new Error(`Unsupported lang: ${langParam}`);
const lang = langParam;

const allEntries = (await getCollection("blog"))
  .filter((e) => parseBlogId(e.id).lang === lang && !e.data.draft)
  .sort(sortBlog);

const featuredPost = allEntries.length > 0 ? allEntries[0] : null;
const remainingPosts = allEntries.length > 0 ? allEntries.slice(1) : [];

// Helper to format date
const formatDate = (date: Date) => {
  return date.toLocaleDateString("en-GB", {
    day: "numeric",
    month: "short",
    year: "numeric",
  });
};
---

<BaseLayout lang={lang} title={`${t(lang, "blog")} · ${SITE.title}`}>
  <Header lang={lang} kind="blog" />
  <main class="wrap container">
    {
      featuredPost && (
        <section class="featured-section">
          <div class="featured-content">
            <span class="featured-label">Featured</span>
            <h1 class="featured-title">
              <a
                href={getBlogUrl({
                  lang,
                  slug: parseBlogId(featuredPost.id).slug,
                })}
              >
                {featuredPost.data.title}
              </a>
            </h1>
            <div class="featured-meta">
              <span class="meta-date">
                {formatDate(featuredPost.data.pubDate)}
              </span>
              <span class="meta-cat">
                {featuredPost.data.category || "Product"}
              </span>
            </div>
            <a
              href={getBlogUrl({
                lang,
                slug: parseBlogId(featuredPost.id).slug,
              })}
              class="read-btn"
            >
              Read blog
            </a>
          </div>
          <div class="featured-media">
            {featuredPost.data.image && (
              <img
                src={featuredPost.data.image}
                alt={featuredPost.data.title}
                class="featured-img"
              />
            )}
          </div>
        </section>
      )
    }

    <div class="filter-section">
      <div class="filter-tabs" id="blog-filters">
        <button class="filter-btn active" data-filter="all">All</button>
        <button class="filter-btn" data-filter="Product">Product</button>
        <button class="filter-btn" data-filter="Engineering">Engineering</button
        >
        <button class="filter-btn" data-filter="Research">Research</button>
      </div>
    </div>

    <div class="list" id="blog-list">
      {
        remainingPosts.map((e) => {
          const p = parseBlogId(e.id);
          const href = getBlogUrl({ lang, slug: p.slug });
          const cat = e.data.category || "Product";
          return (
            <div class="card blog-card-item" data-category={cat}>
              <div class="card-body">
                <h2 class="card-title">
                  <a href={href}>{e.data.title}</a>
                </h2>
                <div class="card-meta">
                  <span class="meta-date">{formatDate(e.data.pubDate)}</span>
                  <span class="meta-cat">{cat}</span>
                </div>
                <a href={href} class="read-btn sm">
                  Read blog
                </a>
              </div>
              {e.data.image && (
                <div class="card-img-wrapper">
                  <img src={e.data.image} alt={e.data.title} class="card-img" />
                </div>
              )}
            </div>
          );
        })
      }
    </div>
  </main>
  <Footer />
</BaseLayout>

<script>
  document.addEventListener("astro:page-load", () => {
    const filters = document.querySelectorAll(".filter-btn");
    const cards = document.querySelectorAll(".blog-card-item");

    filters.forEach((btn) => {
      btn.addEventListener("click", () => {
        // Update active state
        filters.forEach((f) => f.classList.remove("active"));
        btn.classList.add("active");

        const filterValue = btn.getAttribute("data-filter");

        cards.forEach((card) => {
          if (filterValue === "all") {
            (card as HTMLElement).style.display = "flex";
          } else {
            const cat = card.getAttribute("data-category");
            if (cat && cat.toLowerCase() === filterValue!.toLowerCase()) {
              (card as HTMLElement).style.display = "flex";
            } else {
              (card as HTMLElement).style.display = "none";
            }
          }
        });
      });
    });
  });
</script>

<style>
  .wrap {
    padding-block: clamp(40px, 6vw, 80px) clamp(80px, 12vw, 160px);
    font-family: inherit;
  }

  /* Featured Section */
  .featured-section {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: clamp(32px, 6vw, 80px);
    align-items: center;
    margin-bottom: clamp(40px, 8vw, 80px);
  }

  .featured-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .featured-label {
    font-size: clamp(12px, 1.2vw, 14px);
    font-weight: 500;
    color: var(--muted);
    margin-bottom: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .featured-title {
    font-size: clamp(36px, 4.2vw, 64px);
    font-weight: 650;
    line-height: 1.1;
    color: var(--fg);
    margin: 0 0 1rem;
    letter-spacing: -0.02em;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .featured-title a {
    text-decoration: none;
    color: inherit;
    transition: color 0.2s;
  }

  .featured-title a:hover {
    color: var(--accent);
  }

  .featured-meta {
    display: flex;
    gap: 1rem;
    color: var(--muted);
    font-size: clamp(12px, 1.2vw, 14px);
    margin-bottom: 2rem;
  }

  .featured-media {
    border-radius: 16px;
    overflow: hidden;
    aspect-ratio: 2 / 1;
    box-shadow:
      0 4px 6px -1px rgba(0, 0, 0, 0.1),
      0 2px 4px -1px rgba(0, 0, 0, 0.06);
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease;
  }

  .featured-section:hover .featured-media {
    transform: translateY(-2px);
    box-shadow:
      0 10px 15px -3px rgba(0, 0, 0, 0.1),
      0 4px 6px -2px rgba(0, 0, 0, 0.05);
  }

  .featured-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Read Button */
  .read-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem 1.25rem;
    background: transparent;
    color: var(--fg);
    border: 1px solid var(--border);
    border-radius: 999px;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.2s ease;
    font-size: 0.875rem;
  }

  .read-btn:hover {
    background: var(--panel-2);
    border-color: var(--border-2);
  }

  /* Filters */
  .filter-section {
    margin-top: clamp(28px, 4vw, 40px);
    padding-bottom: clamp(14px, 2vw, 20px);
    border-bottom: 1px solid var(--border-2);
    margin-bottom: 0;
  }

  .filter-tabs {
    display: flex;
    gap: 2rem;
  }

  .filter-btn {
    background: transparent;
    border: none;
    padding: 0;
    color: var(--muted);
    font-size: clamp(14px, 1.5vw, 16px);
    font-weight: 500;
    cursor: pointer;
    position: relative;
    transition: color 0.2s;
  }

  .filter-btn:hover {
    color: var(--fg);
  }

  .filter-btn.active {
    color: var(--fg);
  }

  .filter-btn.active::after {
    content: "";
    position: absolute;
    bottom: calc((clamp(14px, 2vw, 20px) * -1) - 1px);
    left: 0;
    width: 100%;
    height: 2px;
    background: var(--fg);
  }

  /* List Grid */
  .list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    column-gap: clamp(24px, 4vw, 64px);
    row-gap: 0;
  }

  /* Row Card Styles */
  .card {
    display: flex;
    justify-content: space-between;
    gap: 1.5rem;
    text-decoration: none;
    color: inherit;
    align-items: flex-start;
    padding-block: clamp(28px, 3.5vw, 36px);
    border-bottom: 1px solid var(--border-2);
    transition: background-color 0.2s ease;
  }

  .card:hover {
    background-color: var(--panel-2);
    margin-inline: -1rem;
    padding-inline: 1rem;
    border-radius: var(--radius-md);
    border-bottom-color: transparent;
  }

  .card-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    min-width: 0;
  }

  .card-title {
    font-size: clamp(18px, 1.6vw, 24px);
    font-weight: 600;
    line-height: 1.3;
    color: var(--fg);
    margin: 0 0 0.5rem;
    letter-spacing: -0.01em;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-title a {
    text-decoration: none;
    color: inherit;
    transition: color 0.2s;
  }

  .card:hover .card-title {
    color: var(--accent);
  }

  .card-meta {
    display: flex;
    gap: 0.75rem;
    color: var(--muted);
    font-size: clamp(12px, 1vw, 13px);
    margin-bottom: 1rem;
  }

  .card-img-wrapper {
    width: clamp(96px, 10vw, 120px);
    height: clamp(96px, 10vw, 120px);
    flex-shrink: 0;
    border-radius: 16px;
    overflow: hidden;
    background: var(--panel-2);
  }

  .card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .featured-section {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .featured-media {
      order: -1; /* Move image above text */
    }

    .filter-tabs {
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      padding-bottom: 4px; /* for scrollbar */
    }

    .filter-btn {
      scroll-snap-align: start;
      white-space: nowrap;
    }
  }

  @media (max-width: 640px) {
    .list {
      grid-template-columns: 1fr;
    }

    .card-img-wrapper {
      width: clamp(88px, 20vw, 96px);
      height: clamp(88px, 20vw, 96px);
    }

    .card:hover {
      margin-inline: -0.5rem;
      padding-inline: 0.5rem;
    }
  }
</style>
