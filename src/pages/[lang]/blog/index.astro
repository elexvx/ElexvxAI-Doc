---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import { SITE } from "../../../config/site";
import { t } from "../../../i18n/ui";
import {
  getBlogUrl,
  isSupportedLang,
  parseBlogId,
  sortBlog,
} from "../../../lib/blog";

export function getStaticPaths() {
  return SITE.langs.map((lang) => ({ params: { lang } }));
}

const langParam = Astro.params.lang ?? SITE.defaultLang;
if (!isSupportedLang(langParam))
  throw new Error(`Unsupported lang: ${langParam}`);
const lang = langParam;

const entries = (await getCollection("blog"))
  .filter((e) => parseBlogId(e.id).lang === lang && !e.data.draft)
  .sort(sortBlog);
---

<BaseLayout lang={lang} title={`${t(lang, "blog")} · ${SITE.title}`}>
  <Header lang={lang} kind="blog" />
  <main class="wrap">
    <section class="hero-section">
      <div class="hero-content">
        <span class="hero-badge"
          ><span class="badge-dot"></span> Featured Research</span
        >
        <h1 class="hero-title">
          {lang === "zh" ? "最新研究与洞见" : "Latest Research &\nInsights"}
        </h1>
        <p class="hero-sub">
          {
            lang === "zh"
              ? "通过我们最新的实验室出版物，探索人工智能、机器学习和计算机视觉的前沿。"
              : "Exploring the frontiers of Artificial Intelligence, Machine Learning, and Computer Vision through our latest lab publications."
          }
        </p>
        <a href="#" class="hero-btn"
          >Read Featured Article <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"></path></svg
          ></a
        >
      </div>
    </section>

    <div class="filter-section">
      <div class="filter-tabs" id="blog-filters">
        <button class="filter-btn active" data-filter="all">All Posts</button>
        <button class="filter-btn" data-filter="Engineering">Engineering</button
        >
        <button class="filter-btn" data-filter="Research">Research</button>
        <button class="filter-btn" data-filter="Case Study">Case Studies</button
        >
        <button class="filter-btn" data-filter="Tutorial">Tutorials</button>
      </div>
      <div class="sort-dropdown">
        <span class="sort-label">Sort by:</span>
        <select class="sort-select">
          <option>Newest</option>
          <option>Oldest</option>
        </select>
      </div>
    </div>

    <div class="list" id="blog-list">
      {
        entries.map((e) => {
          const p = parseBlogId(e.id);
          const href = getBlogUrl({ lang, slug: p.slug });
          const cat = e.data.category || "Engineering";
          return (
            <a class="card blog-card-item" href={href} data-category={cat}>
              {e.data.image && (
                <div class="card-img-wrapper">
                  <img src={e.data.image} alt={e.data.title} class="card-img" />
                  <span class="card-badge">{cat.toUpperCase()}</span>
                </div>
              )}
              <div class="card-body">
                <div class="card-meta">
                  <span class="meta-item">
                    <svg
                      width="14"
                      height="14"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                    >
                      <>
                        <rect
                          x="3"
                          y="4"
                          width="18"
                          height="18"
                          rx="2"
                          ry="2"
                        />
                        <line x1="16" y1="2" x2="16" y2="6" />
                        <line x1="8" y1="2" x2="8" y2="6" />
                        <line x1="3" y1="10" x2="21" y2="10" />
                      </>
                    </svg>
                    {e.data.pubDate.toLocaleDateString("en-US", {
                      month: "short",
                      day: "numeric",
                      year: "numeric",
                    })}
                  </span>
                  <span class="meta-dot">•</span>
                  <span class="meta-item">
                    <svg
                      width="14"
                      height="14"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                    >
                      <>
                        <circle cx="12" cy="12" r="10" />
                        <polyline points="12 6 12 12 16 14" />
                      </>
                    </svg>
                    {e.data.readTime || "5 min read"}
                  </span>
                </div>
                <h2 class="card-title">{e.data.title}</h2>
                {e.data.description && (
                  <p class="card-desc">{e.data.description}</p>
                )}
              </div>
              <div class="card-footer">
                <div class="card-author">
                  {e.data.authorImg ? (
                    <img
                      src={e.data.authorImg}
                      alt={e.data.author}
                      class="author-avatar"
                    />
                  ) : (
                    <div class="author-avatar-fallback" />
                  )}
                  <span class="author-name">
                    {e.data.author || "ElexvxAI Lab"}
                  </span>
                </div>
                <svg
                  class="card-arrow"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path d="M5 12h14M12 5l7 7-7 7" />
                </svg>
              </div>
            </a>
          );
        })
      }
    </div>

    <div class="load-more-container">
      <button class="load-more-btn">Load More Articles</button>
    </div>
  </main>
</BaseLayout>

<script>
  // Simple filtering logic
  document.addEventListener("astro:page-load", () => {
    const filters = document.querySelectorAll(".filter-btn");
    const cards = document.querySelectorAll(".blog-card-item");

    filters.forEach((btn) => {
      btn.addEventListener("click", () => {
        // Update active state
        filters.forEach((f) => f.classList.remove("active"));
        btn.classList.add("active");

        const filterValue = btn.getAttribute("data-filter");

        cards.forEach((card) => {
          if (filterValue === "all") {
            (card as HTMLElement).style.display = "flex";
          } else {
            const cat = card.getAttribute("data-category");
            if (cat && cat.toLowerCase().includes(filterValue!.toLowerCase())) {
              (card as HTMLElement).style.display = "flex";
            } else {
              (card as HTMLElement).style.display = "none";
            }
          }
        });
      });
    });
  });
</script>

<style>
  .wrap {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1rem 4rem;
  }

  /* Hero Section */
  .hero-section {
    position: relative;
    border-radius: 1.5rem;
    overflow: hidden;
    background: linear-gradient(135deg, #0d121c 0%, #1a2536 100%);
    background-image: url("/images/blog-cover.png");
    background-size: cover;
    background-position: center;
    border: 1px solid var(--border);
    margin-bottom: 3rem;
    min-height: 400px;
    display: flex;
    align-items: center;
  }

  /* Add an overlay to ensure text readability against the background image */
  .hero-section::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      rgba(8, 12, 21, 0.95) 0%,
      rgba(8, 12, 21, 0.7) 50%,
      rgba(8, 12, 21, 0.4) 100%
    );
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    padding: 4rem;
    max-width: 700px;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.25rem 0.75rem;
    background: rgba(30, 64, 175, 0.3);
    border: 1px solid rgba(59, 130, 246, 0.5);
    border-radius: 999px;
    color: #60a5fa;
    font-size: 0.875rem;
    font-weight: 500;
    margin-bottom: 1.5rem;
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    background: #3b82f6;
    border-radius: 50%;
    box-shadow: 0 0 8px #3b82f6;
  }

  .hero-title {
    font-size: 3.5rem;
    font-weight: 700;
    line-height: 1.1;
    color: #ffffff;
    margin: 0 0 1.5rem;
    white-space: pre-line;
    letter-spacing: -0.02em;
  }

  .hero-sub {
    font-size: 1.125rem;
    color: #94a3b8;
    line-height: 1.6;
    margin: 0 0 2.5rem;
    max-width: 550px;
  }

  .hero-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: #3b82f6;
    color: white;
    padding: 0.75rem 1.5rem;
    border-radius: 0.5rem;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .hero-btn:hover {
    background: #2563eb;
    transform: translateY(-2px);
  }

  /* Filters */
  .filter-section {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .filter-tabs {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .filter-btn {
    background: transparent;
    border: 1px solid var(--border);
    padding: 0.5rem 1rem;
    border-radius: 999px;
    color: var(--muted);
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .filter-btn:hover {
    border-color: var(--fg);
    color: var(--fg);
  }

  .filter-btn.active {
    background: var(--fg);
    color: var(--bg);
    border-color: var(--fg);
  }

  .sort-dropdown {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--muted);
  }

  .sort-select {
    background: transparent;
    border: none;
    color: var(--fg);
    font-weight: 500;
    cursor: pointer;
    outline: none;
  }

  /* List Grid */
  .list {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
    margin-bottom: 4rem;
  }

  /* Card Styles */
  .card {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--border);
    border-radius: 1rem;
    background: color-mix(in srgb, var(--card) 40%, transparent);
    backdrop-filter: blur(10px);
    overflow: hidden;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  html[data-theme="light"] .card {
    background: #ffffff;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
  }

  .card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
    border-color: var(--fg);
  }

  html[data-theme="dark"] .card:hover {
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
    border-color: rgba(255, 255, 255, 0.2);
  }

  .card-img-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: #1e293b;
  }

  .card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .card:hover .card-img {
    transform: scale(1.05);
  }

  .card-badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    background: rgba(255, 255, 255, 0.9);
    color: #0f172a;
    padding: 0.25rem 0.6rem;
    border-radius: 0.25rem;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.05em;
  }

  html[data-theme="dark"] .card-badge {
    background: rgba(255, 255, 255, 0.95);
  }

  .card-body {
    padding: 1.5rem;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--muted);
    font-size: 0.8125rem;
    margin-bottom: 1rem;
  }

  .meta-item {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  .meta-dot {
    font-size: 0.75rem;
    opacity: 0.5;
  }

  .card-title {
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1.4;
    color: var(--fg);
    margin: 0 0 0.75rem;
  }

  .card-desc {
    font-size: 0.9375rem;
    color: var(--muted);
    line-height: 1.6;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-footer {
    padding: 1.25rem 1.5rem;
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: color-mix(in srgb, var(--card) 60%, transparent);
  }

  html[data-theme="light"] .card-footer {
    background: #fafafa;
  }

  .card-author {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .author-avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    object-fit: cover;
  }

  .author-avatar-fallback {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--muted);
  }

  .author-name {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--fg);
  }

  .card-arrow {
    color: #3b82f6;
    transition: transform 0.2s ease;
  }

  .card:hover .card-arrow {
    transform: translateX(4px);
  }

  .load-more-container {
    display: flex;
    justify-content: center;
  }

  .load-more-btn {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--fg);
    padding: 0.75rem 2rem;
    border-radius: 0.5rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .load-more-btn:hover {
    background: color-mix(in srgb, var(--fg) 5%, transparent);
  }

  @media (max-width: 1024px) {
    .list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 768px) {
    .list {
      grid-template-columns: 1fr;
    }
    .hero-title {
      font-size: 2.5rem;
    }
    .hero-content {
      padding: 2rem;
    }
  }
</style>
