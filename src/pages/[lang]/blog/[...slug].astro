---
import { getCollection, getEntry, render } from 'astro:content';
import { SITE } from '../../../config/site';
import BlogLayout from '../../../layouts/BlogLayout.astro';
import { getBlogUrl, isSupportedLang, parseBlogId, sortBlog } from '../../../lib/blog';

export async function getStaticPaths() {
  const entries = (await getCollection('blog')).filter((e) => !e.data.draft).sort(sortBlog);

  return entries.map((entry) => {
    const p = parseBlogId(entry.id);
    return {
      params: { lang: p.lang, slug: p.slug },
      props: { id: entry.id },
    };
  });
}

const langParam = Astro.params.lang ?? SITE.defaultLang;
if (!isSupportedLang(langParam)) throw new Error(`Unsupported lang: ${langParam}`);
const lang = langParam;

const { id } = Astro.props;
const entry = await getEntry('blog', id);
if (!entry) throw new Error(`Missing entry: ${id}`);

const p = parseBlogId(id);
const { Content, headings } = await render(entry);
const slug = p.slug;
const canonical = getBlogUrl({ lang, slug });
---

<BlogLayout
  lang={lang}
  slug={slug}
  title={entry.data.title}
  description={entry.data.description}
  headings={headings}
  pubDate={entry.data.pubDate}
  tags={entry.data.tags}
>
  <link rel="canonical" href={canonical} />
  <Content />
</BlogLayout>
