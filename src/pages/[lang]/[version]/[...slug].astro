---
import { getCollection, getEntry, render } from "astro:content";
import { SITE } from "../../../config/site";
import DocLayout from "../../../layouts/DocLayout.astro";
import { buildSidebar, isSupportedLang, parseDocId, sortDocs } from "../../../lib/docs";

export async function getStaticPaths() {
  const entries = (await getCollection("docs"))
    .filter((entry) => !entry.data.draft)
    .sort(sortDocs);

  return entries.flatMap((entry) => {
    const p = parseDocId(entry.id);
    if (!isSupportedLang(p.lang)) return [];
    if (p.slug === "" || p.slug === "index") return [];
    return [
      {
        params: { lang: p.lang, version: p.version, slug: p.slug },
        props: { id: entry.id },
      },
    ];
  });
}

const langParam = Astro.params.lang ?? SITE.defaultLang;
if (!isSupportedLang(langParam)) throw new Error(`Unsupported lang: ${langParam}`);
const lang = langParam;

const version = Astro.params.version ?? SITE.defaultVersion;
if (!(SITE.versions as readonly string[]).includes(version)) {
  throw new Error(`Unsupported version: ${version}`);
}

const { id } = Astro.props;
const entry = await getEntry("docs", id);
if (!entry) throw new Error(`Missing docs entry: ${id}`);

const allDocs = (await getCollection("docs")).filter((item) => !item.data.draft);
const sidebarGroups = buildSidebar(allDocs, { lang, version });

const p = parseDocId(id);
const slug = p.slug === "" || p.slug === "index" ? undefined : p.slug;
const { Content, headings } = await render(entry);
---

<DocLayout
  lang={lang}
  version={version}
  slug={slug}
  title={entry.data.title}
  description={entry.data.description}
  sidebarGroups={sidebarGroups}
  headings={headings}
>
  <Content />
</DocLayout>
