---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import { SITE } from '../../../config/site';
import { isSupportedLang } from '../../../lib/docs';
import { t } from '../../../i18n/ui';

export function getStaticPaths() {
  return SITE.langs.map((lang) => ({ params: { lang } }));
}

const langParam = Astro.params.lang ?? SITE.defaultLang;
if (!isSupportedLang(langParam)) {
  throw new Error(`Unsupported lang: ${langParam}`);
}
const lang = langParam;
const version = SITE.defaultVersion;
---

<BaseLayout lang={lang} title={`${t(lang, 'search')} · ${SITE.title}`}>
  <Header lang={lang} kind="search" />
  <main class="wrap">
    <h1 class="title">{t(lang, 'search')}</h1>
    <p class="hint">Cmd/Ctrl + K</p>
    <div id="search" class="search"></div>
  </main>

  <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
  <script src="/pagefind/pagefind-ui.js" is:inline></script>
  <script is:inline>
    function initPagefindSearch() {
      const root = document.querySelector('#search');
      if (!(root instanceof HTMLElement)) return;
      if (root.hasAttribute('data-pagefind-ready')) return;
      if (!window.PagefindUI) return;
      new window.PagefindUI({
        element: '#search',
        showSubResults: true,
        openFilters: ['Type', 'Version', 'Language'],
      });
      root.setAttribute('data-pagefind-ready', 'true');
    }

    if (!document.documentElement.hasAttribute('data-pagefind-bound')) {
      document.documentElement.setAttribute('data-pagefind-bound', 'true');
      document.addEventListener('astro:page-load', initPagefindSearch);
    }
    initPagefindSearch();
  </script>
</BaseLayout>

<script is:inline>
  if (!document.documentElement.hasAttribute('data-search-hotkey-bound')) {
    document.documentElement.setAttribute('data-search-hotkey-bound', 'true');
    window.addEventListener('keydown', (e) => {
      const isMac = navigator.platform.toLowerCase().includes('mac');
      const hotkey = isMac ? e.metaKey : e.ctrlKey;
      if (hotkey && e.key.toLowerCase() === 'k') {
        e.preventDefault();
        const input = document.querySelector('#search input');
        if (input instanceof HTMLInputElement) input.focus();
      }
    });
  }
</script>

<style>
  .wrap {
    max-width: 900px;
    margin: 0 auto;
    padding: 2rem 1rem 4rem;
  }

  .title {
    margin: 0;
  }

  .hint {
    margin: 0.25rem 0 1.5rem;
    color: var(--muted);
  }

  .search {
    border: 1px solid var(--border);
    border-radius: 1rem;
    padding: 1rem;
    background: color-mix(in srgb, var(--card), transparent 0%);
  }

  :global(.pagefind-ui__result-link) {
    color: var(--fg);
  }
</style>
