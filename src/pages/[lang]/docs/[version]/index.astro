---
import { getCollection, getEntry, render } from 'astro:content';
import DocLayout from '../../../../layouts/DocLayout.astro';
import { buildSidebar, isSupportedLang, parseDocId } from '../../../../lib/docs';

export async function getStaticPaths() {
  const entries = await getCollection('docs');
  const indexEntries = entries.filter((e) => {
    const p = parseDocId(e.id);
    return p.slug === '' || p.slug === 'index';
  });

  return indexEntries.map((entry) => {
    const p = parseDocId(entry.id);
    return {
      params: { lang: p.lang, version: p.version },
      props: { id: entry.id },
    };
  });
}

const { id } = Astro.props;
const entry = await getEntry('docs', id);
if (!entry) throw new Error(`Missing entry: ${id}`);

const { Content, headings } = await render(entry);
const p = parseDocId(id);

if (!isSupportedLang(p.lang)) {
  throw new Error(`Unsupported lang: ${p.lang}`);
}

const entries = await getCollection('docs');
const sidebarGroups = buildSidebar(entries, { lang: p.lang, version: p.version });
---

<DocLayout
  lang={p.lang}
  version={p.version}
  title={entry.data.title}
  description={entry.data.description}
  sidebarGroups={sidebarGroups}
  headings={headings}
>
  <Content />
</DocLayout>
