---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import DialogDemo from "../components/ui-react/DialogDemo";
---

<BaseLayout lang="zh" title="UI Islands Demo">
  <Header lang="zh" version="v2" kind="search" />
  <main class="ui-wrap">
    <h1>UI React Islands Demo</h1>
    <p>Dialog demo is loaded on visibility only.</p>
    <DialogDemo client:visible />
  </main>
</BaseLayout>

<style>
  .ui-wrap {
    max-width: 840px;
    margin: 0 auto;
    padding: 2rem 1rem 3rem;
  }

  .ui-wrap h1 {
    margin: 0 0 0.75rem;
  }

  .ui-wrap p {
    margin: 0 0 1.25rem;
    color: var(--muted);
  }
</style>
