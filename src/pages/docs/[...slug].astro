---
import DocsLayout from "../../layouts/DocsLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
    const docs = await getCollection("docs");
    return docs.map((doc) => ({
        params: { slug: doc.id },
        props: { doc },
    }));
}

const { doc } = Astro.props;
const { Content } = await render(doc);
const currentPath = `/docs/${doc.id}`;
---

<DocsLayout
    title={`${doc.data.title} - ElexvxAI Docs`}
    currentPath={currentPath}
>
    <article class="doc-content">
        <Content />
    </article>
</DocsLayout>

<style>
    .doc-content :global(h1) {
        font-size: 2.4rem;
        font-weight: 700;
        margin-bottom: 16px;
        letter-spacing: -0.02em;
        line-height: 1.2;
    }
    .doc-content :global(h2) {
        font-size: 1.6rem;
        font-weight: 600;
        margin-top: 48px;
        margin-bottom: 16px;
        padding-bottom: 8px;
        border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    }
    .doc-content :global(h3) {
        font-size: 1.2rem;
        font-weight: 600;
        margin-top: 32px;
        margin-bottom: 12px;
    }
    .doc-content :global(p) {
        line-height: 1.75;
        margin-bottom: 16px;
        color: var(--text-secondary, #5f6973);
    }
    .doc-content :global(a) {
        color: #1976d2;
        text-decoration: none;
    }
    .doc-content :global(a:hover) {
        text-decoration: underline;
    }
    .doc-content :global(code) {
        background: rgba(0, 0, 0, 0.06);
        border-radius: 4px;
        padding: 2px 6px;
        font-size: 0.875em;
        font-family: "SFMono-Regular", Consolas, "Liberation Mono", Menlo,
            monospace;
    }
    .doc-content :global(pre) {
        background: #0f172a;
        color: #e2e8f0;
        padding: 20px 24px;
        border-radius: 12px;
        overflow-x: auto;
        margin: 24px 0;
        font-size: 0.875rem;
        line-height: 1.7;
    }
    .doc-content :global(pre code) {
        background: none;
        padding: 0;
        color: inherit;
    }
    .doc-content :global(table) {
        width: 100%;
        border-collapse: collapse;
        margin: 24px 0;
        font-size: 0.9rem;
    }
    .doc-content :global(th) {
        text-align: left;
        padding: 10px 16px;
        background: rgba(0, 0, 0, 0.04);
        font-weight: 600;
        border-bottom: 2px solid rgba(0, 0, 0, 0.1);
    }
    .doc-content :global(td) {
        padding: 10px 16px;
        border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    }
    .doc-content :global(ul),
    .doc-content :global(ol) {
        padding-left: 24px;
        margin-bottom: 16px;
    }
    .doc-content :global(li) {
        margin-bottom: 8px;
        line-height: 1.7;
        color: var(--text-secondary, #5f6973);
    }
    .doc-content :global(blockquote) {
        border-left: 4px solid #1976d2;
        background: rgba(25, 118, 210, 0.06);
        padding: 12px 20px;
        border-radius: 0 8px 8px 0;
        margin: 24px 0;
    }

    /* Dark mode */
    :global(html.dark) .doc-content :global(p),
    :global(html.dark) .doc-content :global(li),
    :global(html[data-theme="dark"]) .doc-content :global(p),
    :global(html[data-theme="dark"]) .doc-content :global(li) {
        color: #aab4be;
    }
    :global(html.dark) .doc-content :global(code),
    :global(html[data-theme="dark"]) .doc-content :global(code) {
        background: rgba(255, 255, 255, 0.1);
        color: #e2e8f0;
    }
    :global(html.dark) .doc-content :global(th),
    :global(html[data-theme="dark"]) .doc-content :global(th) {
        background: rgba(255, 255, 255, 0.05);
        border-bottom-color: rgba(255, 255, 255, 0.1);
    }
    :global(html.dark) .doc-content :global(td),
    :global(html[data-theme="dark"]) .doc-content :global(td) {
        border-bottom-color: rgba(255, 255, 255, 0.06);
    }
    :global(html.dark) .doc-content :global(h2),
    :global(html[data-theme="dark"]) .doc-content :global(h2) {
        border-bottom-color: rgba(255, 255, 255, 0.08);
    }
    :global(html.dark) .doc-content :global(blockquote),
    :global(html[data-theme="dark"]) .doc-content :global(blockquote) {
        background: rgba(25, 118, 210, 0.12);
        color: #aab4be;
    }
</style>
