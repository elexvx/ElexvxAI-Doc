---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import { SITE } from '../config/site';
import Hero from '../components/landing/Hero.astro';
import Features from '../components/landing/Features.astro';
import Stats from '../components/landing/Stats.astro';
import Footer from '../components/landing/Footer.astro';
---

<BaseLayout lang="zh" title={SITE.title} description="Advancing Intelligence for Industrial Innovation">
  <Header lang="zh" version={SITE.defaultVersion} />
  <main class="landing-page">
    <Hero />
    <Features />
    <Stats />
    <Footer />
  </main>
</BaseLayout>

<style is:global>
  :root {
    /* M3 Theme - Blue/Indigo based */
    --md-sys-color-primary: #2563EB;
    --md-sys-color-on-primary: #FFFFFF;
    --md-sys-color-primary-container: #DBE1FF;
    --md-sys-color-on-primary-container: #00174A;
    
    --md-sys-color-secondary: #5A5D72;
    --md-sys-color-on-secondary: #FFFFFF;
    --md-sys-color-secondary-container: #DFE1F9;
    --md-sys-color-on-secondary-container: #171A2C;
    
    --md-sys-color-tertiary: #76546F;
    --md-sys-color-on-tertiary: #FFFFFF;
    --md-sys-color-tertiary-container: #FFD7F5;
    --md-sys-color-on-tertiary-container: #2D1229;
    
    --md-sys-color-surface: #FDFBFF;
    --md-sys-color-on-surface: #1A1B1F;
    --md-sys-color-surface-variant: #E3E2E6;
    --md-sys-color-on-surface-variant: #46464F;
    
    --md-sys-color-outline: #767680;
    --md-sys-color-outline-variant: #C7C6D0;

    --md-sys-color-surface-container-low: #F3F3FA;
    --md-sys-color-surface-container: #EDEDF4;
    --md-sys-color-surface-container-high: #E7E8EE;
    
    /* Typography */
    --md-sys-typescale-display-font: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
    --md-sys-typescale-body-font: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
  }

  :root[data-theme='dark'] {
     /* Dark Theme */
    --md-sys-color-primary: #B4C5FF;
    --md-sys-color-on-primary: #002A78;
    --md-sys-color-primary-container: #0040AB;
    --md-sys-color-on-primary-container: #DBE1FF;
    
    --md-sys-color-secondary: #C3C5DD;
    --md-sys-color-on-secondary: #2C2F42;
    --md-sys-color-secondary-container: #424659;
    --md-sys-color-on-secondary-container: #DFE1F9;
    
    --md-sys-color-surface: #1A1B1F;
    --md-sys-color-on-surface: #E3E2E6;
    --md-sys-color-surface-variant: #46464F;
    --md-sys-color-on-surface-variant: #C7C6D0;
    
    --md-sys-color-outline: #90909A;
    --md-sys-color-outline-variant: #46464F;

    --md-sys-color-surface-container-low: #1C1D22;
    --md-sys-color-surface-container: #202126;
    --md-sys-color-surface-container-high: #2B2C31;
  }

  /* Override BaseLayout defaults for landing page */
  body {
    background-color: var(--md-sys-color-surface);
    color: var(--md-sys-color-on-surface);
  }
  
  /* Ensure header blends in or stands out */
  .hdr {
    background: var(--md-sys-color-surface) !important;
    border-bottom: 1px solid var(--md-sys-color-outline-variant) !important;
  }
</style>
