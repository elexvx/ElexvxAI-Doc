---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import HelpSection from '../components/HelpSection.astro';
import { SITE } from '../config/site';
import { getEntry } from 'astro:content';
import Hero from '../components/landing/Hero.astro';
import LatestNews from '../components/landing/LatestNews.astro';
import Features from '../components/landing/Features.astro';
import Footer from '../components/landing/Footer.astro';

const landingEntry = await getEntry('landing', 'zh');
if (!landingEntry) {
  throw new Error('Missing landing content entry: zh');
}
---

<BaseLayout
  lang="zh"
  title={landingEntry.data.meta.title}
  description={landingEntry.data.meta.description}
>
  <Header lang="zh" version={SITE.defaultVersion} />
  <main class="landing-page">
    <Hero data={landingEntry.data.hero} />
    <Features data={landingEntry.data.features} />
    <LatestNews lang="zh" />
    <HelpSection data={landingEntry.data.help} />
    <Footer data={landingEntry.data.footer} />
  </main>
</BaseLayout>


<style is:global>
  /* Override BaseLayout defaults for landing page */
  body {
    background-color: var(--bg);
    color: var(--fg);
  }
  
  /* Ensure header blends in or stands out */
  .hdr {
    background: var(--bg) !important;
    border-bottom: 1px solid var(--border) !important;
  }

  @media (max-width: 768px) {
    .landing-page .container {
      width: 100%;
      margin-inline: 0;
    }
  }

</style>
